---
import JobCard from './JobCard.astro';
import jobsData from '../data/jobs';

interface Props {
	initialCity?: string;
	initialTag?: string;
	initialSearch?: string;
}

const { initialCity = '', initialTag = 'all', initialSearch = '' } = Astro.props;
const availableJobIds = jobsData.map((job) => job.id);

const filteredJobs = jobsData.filter((job) => {
	const searchTerm = initialSearch.toLowerCase();
	const cityTerm = initialCity.toLowerCase();
	const matchesCity = !initialCity || job.location.toLowerCase().includes(cityTerm) || job.location === 'Вся Россия';
	const matchesTag = initialTag === 'all' || job.tags.includes(initialTag);
	const matchesSearch =
		!searchTerm ||
		job.title.toLowerCase().includes(searchTerm) ||
		job.company.toLowerCase().includes(searchTerm) ||
		job.location.toLowerCase().includes(searchTerm) ||
		job.salary.toLowerCase().includes(searchTerm);

	return matchesCity && matchesTag && matchesSearch;
});
const hasVacancies = jobsData.length > 0;
---

<div class="job-grid-container">
	<div class="compare-inline-alert hidden" id="compare-limit-message" aria-live="polite"></div>

	<section id="vacancies">
		<div class="jobs-grid" id="jobs-grid">
			{filteredJobs.length > 0 ? (
				filteredJobs.map((job) => (
					<JobCard job={job} />
				))
			) : (
				<div class="no-results">
					<h3 data-t={hasVacancies ? 'jobgrid.empty_title' : undefined}>
						{hasVacancies ? 'Ничего не найдено' : 'Вакансии пока не опубликованы'}
					</h3>
					<p data-t={hasVacancies ? 'jobgrid.empty_desc' : undefined}>
						{hasVacancies
							? 'Попробуйте сбросить фильтры или изменить поиск.'
							: 'Текущий список очищен. Новые карточки появятся после публикации вакансий.'}
					</p>
					{hasVacancies && <a class="btn-secondary" href="/" data-t="jobgrid.reset">Сбросить всё</a>}
				</div>
			)}
		</div>
	</section>
</div>

<style>
	.compare-inline-alert {
		margin-bottom: 1rem;
		padding: 0.85rem 1rem;
		border-radius: 8px;
		border: 1px solid rgba(244, 63, 94, 0.22);
		background: rgba(255, 241, 242, 0.9);
		color: #9f1239;
		font-size: 0.92rem;
		font-weight: 600;
		line-height: 1.5;
	}

	.compare-inline-alert.hidden {
		display: none;
	}

	.no-results {
		grid-column: 1 / -1;
		text-align: center;
		padding: 4rem;
		background: var(--bg-card);
		border-radius: 8px;
		border: 1px dashed var(--border-color);
	}
</style>

<script is:inline define:vars={{ initialCity, initialTag, initialSearch, availableJobIds }}>
	let compareList = [];
	const availableJobIdSet = new Set(availableJobIds);
	let selectedCity = initialCity || '';
	const normalizedInitialSearch = initialSearch.toLowerCase();
	let compareNoticeTimeout = null;

	function parseStoredCompareList() {
		try {
			const rawList = JSON.parse(localStorage.getItem('compareList') || '[]');
			if (!Array.isArray(rawList)) return [];

			return rawList
				.map((id) => Number.parseInt(String(id), 10))
				.filter((id) => Number.isFinite(id));
		} catch {
			return [];
		}
	}

	function normalizeCompareList(ids) {
		return ids
			.filter((id, index, list) => availableJobIdSet.has(id) && list.indexOf(id) === index)
			.slice(0, 4);
	}

	function syncCompareList({ emitEvent = true } = {}) {
		const rawList = parseStoredCompareList();
		const normalizedList = normalizeCompareList(rawList);
		compareList = normalizedList;

		if (JSON.stringify(rawList) !== JSON.stringify(normalizedList)) {
			localStorage.setItem('compareList', JSON.stringify(normalizedList));
			if (emitEvent) {
				window.dispatchEvent(new CustomEvent('compareUpdate'));
			}
		}

		return normalizedList;
	}

	function getTranslation(key, defaultText) {
		const lang = window.kurieros_i18n?.currentLang || 'ru';
		const dict = window.translations ? (window.translations[lang] || window.translations['ru']) : null;
		if (!dict) return defaultText;
		return key.split('.').reduce((prev, curr) => prev && prev[curr], dict) || defaultText;
	}

	function showCompareNotice(message) {
		const compareNotice = document.getElementById('compare-limit-message');
		if (!compareNotice) return;

		compareNotice.textContent = message;
		compareNotice.classList.remove('hidden');

		if (compareNoticeTimeout) {
			window.clearTimeout(compareNoticeTimeout);
		}

		compareNoticeTimeout = window.setTimeout(() => {
			compareNotice.classList.add('hidden');
		}, 3200);
	}

	function getCompareButtonLabel(isActive) {
		return isActive
			? `<span data-t="job.in_compare">${getTranslation('job.in_compare', 'В сравнении')}</span> ✓`
			: `<span data-t="job.compare">${getTranslation('job.compare', '+ Сравнить')}</span>`;
	}

	function setCompareButtonState(button, isActive) {
		if (!button) return;
		button.classList.toggle('active', isActive);
		button.innerHTML = getCompareButtonLabel(isActive);
	}

	function matchesSearch(card, searchTerm) {
		if (!searchTerm) return true;

		const title = card.querySelector('.job-title')?.textContent?.toLowerCase() || '';
		const company = card.querySelector('.company-name')?.textContent?.toLowerCase() || '';
		const location = (card.dataset.location || '').toLowerCase();

		return title.includes(searchTerm) || company.includes(searchTerm) || location.includes(searchTerm);
	}

	function mapAgeFilterToTag(value) {
		if (value === '16plus') return '16plus';
		if (value === '18plus') return '18+';
		return 'all';
	}

	function hasTag(card, tag) {
		if (!tag || tag === 'all') return true;
		const tags = (card.dataset.tags || '')
			.split(',')
			.map((item) => item.trim().toLowerCase())
			.filter(Boolean);

		return tags.includes(tag.toLowerCase());
	}

	function toggleCompare(id) {
		syncCompareList({ emitEvent: false });
		const index = compareList.indexOf(id);
		if (index === -1) {
			if (compareList.length >= 4) {
				showCompareNotice(getTranslation('compare.limit_reached', 'Можно сравнивать не более 4 вакансий одновременно.'));
				return;
			}
			compareList = [...compareList, id];
		} else {
			compareList = compareList.filter((item) => item !== id);
		}

		localStorage.setItem('compareList', JSON.stringify(compareList));
		window.dispatchEvent(new CustomEvent('compareUpdate'));

		setCompareButtonState(
			document.querySelector(`.btn-compare[data-id="${id}"]`),
			compareList.includes(id)
		);
	}

	document.addEventListener('DOMContentLoaded', () => {
		const jobCards = document.querySelectorAll('.job-card');
		const ageFilterSelect = document.getElementById('vacancy-age-filter');
		const transportFilterSelect = document.getElementById('vacancy-transport-filter');
		syncCompareList();

		document.querySelectorAll('.btn-compare').forEach((btn) => {
			const id = Number.parseInt(btn.dataset.id || '', 10);
			setCompareButtonState(btn, compareList.includes(id));
			btn.addEventListener('click', (e) => {
				e.preventDefault();
				toggleCompare(id);
			});
		});

		window.addEventListener('kurieros:city-selected', (event) => {
			selectedCity = event.detail?.city || '';
			filterJobs();
		});

		window.addEventListener('storage', (event) => {
			if (event.key !== 'compareList') return;
			syncCompareList({ emitEvent: false });
			document.querySelectorAll('.btn-compare').forEach((btn) => {
				const id = Number.parseInt(btn.dataset.id || '', 10);
				setCompareButtonState(btn, compareList.includes(id));
			});
		});

		ageFilterSelect?.addEventListener('change', () => {
			filterJobs();
		});

		transportFilterSelect?.addEventListener('change', () => {
			filterJobs();
		});

		function filterJobs() {
			const term = normalizedInitialSearch;
			const selectedAgeTag = mapAgeFilterToTag(ageFilterSelect?.value || 'all');
			const selectedTransportTag = transportFilterSelect?.value || 'all';

			jobCards.forEach((card) => {
				const location = (card.dataset.location || '').toLowerCase();
				const matchesCity = !selectedCity || location.includes(selectedCity.toLowerCase()) || location === 'вся россия';
				const matchesSearchTerm = matchesSearch(card, term);
				const matchesAge = hasTag(card, selectedAgeTag);
				const matchesTransport = hasTag(card, selectedTransportTag);

				if (matchesSearchTerm && matchesCity && matchesAge && matchesTransport) {
					card.style.display = 'flex';
				} else {
					card.style.display = 'none';
				}
			});
		}

		filterJobs();
	});
</script>
