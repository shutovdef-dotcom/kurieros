---
import LanguageSwitcher from './LanguageSwitcher.astro';
---
<header>
    <div class="header-left">
        <a href="/" class="logo">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            Курьерок
        </a>
    </div>
    
    <nav class="main-nav" aria-label="Основная навигация">
        <ul>
            <li><a href="/#vacancies" data-t="nav.vacancies">Вакансии</a></li>
            <li><a href="/companies/" data-t="nav.companies">Компании</a></li>
            <li><a href="/blog/" data-t="nav.blog">Блог</a></li>
            <li><a href="/contacts/" data-t="nav.contacts">Контакты</a></li>
            <li><a href="/cities/" data-t="nav.cities">Города</a></li>
            <li><a href="/calculator/" data-t="nav.calculator">Калькулятор</a></li>
            <li><a href="/compare/" class="compare-nav-link"><span data-t="nav.compare">Сравнение</span> <span class="compare-badge hidden" id="compare-badge">0</span></a></li>
        </ul>
    </nav>

    <div class="header-lang">
        <LanguageSwitcher />
    </div>
</header>

<nav class="bottom-nav" aria-label="Мобильная навигация">
    <a href="/#vacancies" class="bn-item">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
        <span data-t="nav.vacancies">Вакансии</span>
    </a>
    <a href="/companies/" class="bn-item">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><path d="M9 22v-4h6v4"></path><path d="M8 6h.01"></path><path d="M16 6h.01"></path><path d="M8 10h.01"></path><path d="M16 10h.01"></path><path d="M8 14h.01"></path><path d="M16 14h.01"></path></svg>
        <span data-t="nav.companies">Компании</span>
    </a>
    <a href="/compare/" class="bn-item">
        <div class="bn-icon-wrap">
            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><path d="M16 3h5v5M4 20L21 3M21 16v5h-5M15 15l6 6M4 4l5 5"></path></svg>
            <span class="bn-badge hidden" id="compare-badge-bottom">0</span>
        </div>
        <span data-t="nav.compare">Сравнение</span>
    </a>
    <a href="/cities/" class="bn-item">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
        <span data-t="nav.cities">Города</span>
    </a>
    <a href="/calculator/" class="bn-item">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><line x1="8" y1="18" x2="16" y2="18"></line><line x1="8" y1="14" x2="16" y2="14"></line><line x1="8" y1="10" x2="16" y2="10"></line><line x1="8" y1="6" x2="16" y2="6"></line></svg>
        <span data-t="vacancy.income">Доход</span>
    </a>
    <a href="/blog/" class="bn-item">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
        <span data-t="nav.blog">Блог</span>
    </a>
</nav>

<script is:inline>
    function updateHeaderCompareBadge() {
        const compareList = JSON.parse(localStorage.getItem('compareList') || '[]');
        const badges = [
            document.getElementById('compare-badge'),
            document.getElementById('compare-badge-bottom')
        ];
        
        badges.forEach(badge => {
            if (badge) {
                badge.textContent = compareList.length;
                if (compareList.length > 0) {
                    badge.classList.remove('hidden');
                } else {
                    badge.classList.add('hidden');
                }
            }
        });
    }
    
    document.addEventListener('DOMContentLoaded', () => {
        updateHeaderCompareBadge();
    });

    window.addEventListener('storage', updateHeaderCompareBadge);
    window.addEventListener('compareUpdate', updateHeaderCompareBadge);
</script>
