---
import { CITIES } from '../data/constants';

// Define base rates per city
const cityRates: Record<string, number> = {
    'moskva': 520,
    'spb': 460,
    'ekaterinburg': 410,
    'kazan': 390,
    'novosibirsk': 380,
    'default': 350
};

const citiesJson = JSON.stringify(CITIES);
const ratesJson = JSON.stringify(cityRates);
---

<section class="calculator-section home-section" id="income-calculator">
    <div class="calculator-card">
        <div class="calc-header">
            <h2 data-t="calculator.title">Калькулятор дохода курьера</h2>
            <p data-t="calculator.subtitle">Узнайте, сколько вы можете заработать в месяц</p>
        </div>

        <div class="calc-grid">
            <div class="calc-inputs">
                <div class="input-group">
                    <div class="label-row">
                        <label for="days-range" data-t="calculator.days">Дней в месяц</label>
                        <span class="value-badge" id="days-val">22</span>
                    </div>
                    <input type="range" id="days-range" min="1" max="30" value="22" class="range-input">
                    <div class="range-labels">
                        <span>1</span>
                        <span>30</span>
                    </div>
                </div>

                <div class="input-group">
                    <div class="label-row">
                        <label for="hours-range" data-t="calculator.hours">Часов в день</label>
                        <span class="value-badge" id="hours-val">8</span>
                    </div>
                    <input type="range" id="hours-range" min="1" max="16" value="8" class="range-input">
                    <div class="range-labels">
                        <span>1</span>
                        <span>16</span>
                    </div>
                </div>

                <div class="input-group">
                    <label for="calc-city-select" data-t="calculator.city">Ваш город</label>
                    <select id="calc-city-select" class="city-select">
                        {CITIES.map(city => (
                            <option value={city.slug}>{city.name}</option>
                        ))}
                    </select>
                </div>
            </div>

            <div class="calc-result">
                <div class="result-title" data-t="calculator.result">Примерный заработок:</div>
                <div class="total-amount" id="total-amount">0 ₽</div>
                <div class="result-footer">
                    *Расчет произведен на основе средних показателей по городу. <br>
                    Реальный доход зависит от компании и типа транспорта.
                </div>
                <a href="/kurieros/#vacancies/" class="apply-btn-calc" data-t="calculator.apply">Выбрать вакансию</a>
            </div>
        </div>
    </div>
</section>

<script is:inline define:vars={{ citiesJson, ratesJson }}>
    const cities = JSON.parse(citiesJson);
    const rates = JSON.parse(ratesJson);

    const daysRange = document.getElementById('days-range');
    const hoursRange = document.getElementById('hours-range');
    const citySelect = document.getElementById('calc-city-select');
    const daysVal = document.getElementById('days-val');
    const hoursVal = document.getElementById('hours-val');
    const totalAmount = document.getElementById('total-amount');

    function calculate() {
        const days = parseInt(daysRange.value);
        const hours = parseInt(hoursRange.value);
        const citySlug = citySelect.value;
        
        const rate = rates[citySlug] || rates['default'];
        const total = days * hours * rate;

        daysVal.textContent = days;
        hoursVal.textContent = hours;
        
        // Formatted number with spaces
        totalAmount.textContent = total.toLocaleString('ru-RU') + ' ₽';
    }

    daysRange.addEventListener('input', calculate);
    hoursRange.addEventListener('input', calculate);
    citySelect.addEventListener('change', calculate);

    // Initial calc
    document.addEventListener('DOMContentLoaded', calculate);
</script>

<style>
    .calculator-section {
        border: 1px solid #ebe5dc !important;
        background: #fffdf8 !important;
        box-shadow: 0 8px 24px rgba(60, 41, 20, 0.05) !important;
    }
    .calculator-card {
        width: 100%;
    }
    .calc-header {
        text-align: left;
        margin-bottom: 2.5rem;
    }
    .calc-header h2 {
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: -0.04em;
        margin-bottom: 0.5rem;
        color: #2b2622;
    }
    .calc-header p {
        color: #7c6f64;
        font-size: 1.05rem;
    }
    .calc-grid {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 4rem;
        align-items: center;
    }
    @media (max-width: 992px) {
        .calc-grid {
            grid-template-columns: 1fr;
            gap: 2.5rem;
        }
    }
    .input-group {
        margin-bottom: 1.75rem;
    }
    .label-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.85rem;
    }
    label {
        font-weight: 700;
        color: #2b2622;
        font-size: 1.05rem;
    }
    .value-badge {
        background: #f7f2ea;
        color: #2b2622;
        padding: 0.35rem 1rem;
        border-radius: 10px;
        font-size: 1rem;
        font-weight: 800;
        border: 1px solid #ebe5dc;
    }
    .range-input {
        width: 100%;
        accent-color: #2b2622;
        cursor: pointer;
    }
    .range-labels {
        display: flex;
        justify-content: space-between;
        font-size: 0.85rem;
        color: #8b7d70;
        margin-top: 0.6rem;
    }
    .city-select {
        width: 100%;
        padding: 1rem;
        border-radius: 12px;
        border: 1px solid #ebe5dc;
        background: white;
        color: #2b2622;
        margin-top: 0.5rem;
        font-size: 1.05rem;
        font-weight: 600;
        cursor: pointer;
        outline: none;
    }
    .calc-result {
        background: #fffdf8;
        padding: 3rem 2rem;
        border-radius: 1.5rem;
        color: #2b2622;
        text-align: center;
        border: 1px solid #ebe5dc;
        box-shadow: 0 8px 24px rgba(60, 41, 20, 0.05);
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    .result-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: #8b7d70;
        margin-bottom: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .total-amount {
        font-family: 'Outfit', sans-serif;
        font-size: 4rem;
        font-weight: 900;
        margin-bottom: 1.5rem;
        letter-spacing: -2px;
        color: #2b2622;
    }
    @media (max-width: 480px) {
        .total-amount {
            font-size: 3rem;
        }
    }
    .result-footer {
        font-size: 0.85rem;
        color: #8b7d70;
        line-height: 1.5;
        margin-bottom: 2.25rem;
    }
    .apply-btn-calc {
        display: inline-flex;
        background: #2b2622;
        color: #fff;
        padding: 1.1rem 2.5rem;
        border-radius: 12px;
        font-weight: 800;
        text-decoration: none;
        transition: all 0.3s ease;
        font-size: 1.1rem;
        justify-content: center;
    }
    .apply-btn-calc:hover {
        transform: translateY(-3px);
        background: #000;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    }
</style>
