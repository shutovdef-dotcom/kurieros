---
import { CITIES } from '../data/constants';

// Define base rates per city
const cityRates: Record<string, number> = {
    'moskva': 520,
    'spb': 460,
    'ekaterinburg': 410,
    'kazan': 390,
    'novosibirsk': 380,
    'default': 350
};

const citiesJson = JSON.stringify(CITIES);
const ratesJson = JSON.stringify(cityRates);
---

<section class="calculator-section" id="income-calculator">
    <div class="container container-narrow">
        <div class="calculator-card">
            <div class="calc-header">
                <h2 data-t="calculator.title">Калькулятор дохода курьера</h2>
                <p data-t="calculator.subtitle">Узнайте, сколько вы можете заработать в месяц</p>
            </div>

            <div class="calc-grid">
                <div class="calc-inputs">
                    <div class="input-group">
                        <div class="label-row">
                            <label for="days-range" data-t="calculator.days">Дней в месяц</label>
                            <span class="value-badge" id="days-val">22</span>
                        </div>
                        <input type="range" id="days-range" min="1" max="30" value="22" class="range-input">
                        <div class="range-labels">
                            <span>1</span>
                            <span>30</span>
                        </div>
                    </div>

                    <div class="input-group">
                        <div class="label-row">
                            <label for="hours-range" data-t="calculator.hours">Часов в день</label>
                            <span class="value-badge" id="hours-val">8</span>
                        </div>
                        <input type="range" id="hours-range" min="1" max="16" value="8" class="range-input">
                        <div class="range-labels">
                            <span>1</span>
                            <span>16</span>
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="city-select" data-t="calculator.city">Ваш город</label>
                        <select id="city-select" class="city-select">
                            {CITIES.map(city => (
                                <option value={city.slug}>{city.name}</option>
                            ))}
                        </select>
                    </div>
                </div>

                <div class="calc-result">
                    <div class="result-title" data-t="calculator.result">Примерный заработок:</div>
                    <div class="total-amount" id="total-amount">0 ₽</div>
                    <div class="result-footer">
                        *Расчет произведен на основе средних показателей по городу. <br>
                        Реальный доход зависит от компании и типа транспорта.
                    </div>
                    <a href="/kurieros/#vacancies/" class="apply-btn-calc" data-t="calculator.apply">Выбрать вакансию</a>
                </div>
            </div>
        </div>
    </div>
</section>

<script is:inline define:vars={{ citiesJson, ratesJson }}>
    const cities = JSON.parse(citiesJson);
    const rates = JSON.parse(ratesJson);

    const daysRange = document.getElementById('days-range');
    const hoursRange = document.getElementById('hours-range');
    const citySelect = document.getElementById('city-select');
    const daysVal = document.getElementById('days-val');
    const hoursVal = document.getElementById('hours-val');
    const totalAmount = document.getElementById('total-amount');

    function calculate() {
        const days = parseInt(daysRange.value);
        const hours = parseInt(hoursRange.value);
        const citySlug = citySelect.value;
        
        const rate = rates[citySlug] || rates['default'];
        const total = days * hours * rate;

        daysVal.textContent = days;
        hoursVal.textContent = hours;
        
        // Formatted number with spaces
        totalAmount.textContent = total.toLocaleString('ru-RU') + ' ₽';
    }

    daysRange.addEventListener('input', calculate);
    hoursRange.addEventListener('input', calculate);
    citySelect.addEventListener('change', calculate);

    // Initial calc
    document.addEventListener('DOMContentLoaded', calculate);
</script>

<style>
    .calculator-section {
        padding: 4rem 0;
        background: linear-gradient(135deg, rgba(79, 70, 229, 0.05) 0%, rgba(6, 182, 212, 0.05) 100%);
        border-top: 1px solid var(--border-color);
        border-bottom: 1px solid var(--border-color);
    }
    .calculator-card {
        background: var(--bg-card);
        border-radius: 2rem;
        padding: 3rem;
        box-shadow: var(--shadow-glass);
        border: 1px solid var(--glass-border);
        max-width: 900px;
        margin: 0 auto;
    }
    .calc-header {
        text-align: center;
        margin-bottom: 3rem;
    }
    .calc-header h2 {
        font-size: 2rem;
        margin-bottom: 0.5rem;
    }
    .calc-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        align-items: center;
    }
    @media (max-width: 768px) {
        .calc-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }
        .calculator-card {
            padding: 2rem 1.5rem;
        }
    }
    .input-group {
        margin-bottom: 2rem;
    }
    .label-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
    }
    label {
        font-weight: 600;
        color: var(--text-color);
    }
    .value-badge {
        background: var(--accent-gradient);
        color: white;
        padding: 0.2rem 0.8rem;
        border-radius: 999px;
        font-size: 0.875rem;
        font-weight: 800;
    }
    .range-input {
        width: 100%;
        accent-color: var(--accent-color);
        cursor: pointer;
    }
    .range-labels {
        display: flex;
        justify-content: space-between;
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-top: 0.5rem;
    }
    .city-select {
        width: 100%;
        padding: 0.8rem 1rem;
        border-radius: 0.8rem;
        border: 1px solid var(--border-color);
        background: var(--bg-color);
        color: var(--text-color);
        margin-top: 0.5rem;
        font-size: 1rem;
        cursor: pointer;
    }
    .calc-result {
        background: var(--accent-gradient);
        padding: 3rem 2rem;
        border-radius: 1.5rem;
        color: white;
        text-align: center;
        box-shadow: 0 20px 40px rgba(79, 70, 229, 0.3);
    }
    .result-title {
        font-size: 1.125rem;
        font-weight: 500;
        opacity: 0.9;
        margin-bottom: 1rem;
    }
    .total-amount {
        font-size: 3.5rem;
        font-weight: 800;
        margin-bottom: 1.5rem;
        letter-spacing: -2px;
    }
    @media (max-width: 480px) {
        .total-amount {
            font-size: 2.5rem;
        }
    }
    .result-footer {
        font-size: 0.75rem;
        opacity: 0.8;
        line-height: 1.4;
        margin-bottom: 2rem;
    }
    .apply-btn-calc {
        display: block;
        background: white;
        color: var(--accent-color);
        padding: 1rem;
        border-radius: 0.8rem;
        font-weight: 700;
        text-decoration: none;
        transition: transform 0.2s;
    }
    .apply-btn-calc:hover {
        transform: translateY(-2px);
    }
</style>
