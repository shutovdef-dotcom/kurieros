---
import '../styles/index.css';
import '../styles/themes.css';
import VPNModal from '../components/VPNModal.astro';
import { SUPPORTED_LANGUAGES, translations, type SupportedLanguage } from '../data/translations';

const supportedLanguages = SUPPORTED_LANGUAGES;
const vacancyTranslationModules = import.meta.glob('../data/vacancy-translations/*.json', {
	eager: true,
}) as Record<string, { default: Record<string, Record<string, string>> }>;
const jobTranslations = Object.fromEntries(
	Object.entries(vacancyTranslationModules)
		.map(([path, module]) => [
			path.match(/\/([^/]+)\.json$/)?.[1],
			module.default,
		])
		.filter(([language]) => supportedLanguages.includes(language as SupportedLanguage)),
) as Partial<Record<SupportedLanguage, Record<string, Record<string, string>>>>;

supportedLanguages.forEach(lang => {
    if (jobTranslations[lang]) {
        translations[lang].vacancies = jobTranslations[lang];
    }
});

interface Props {
	title?: string;
	titleKey?: string;
	description?: string;
	descriptionKey?: string;
	image?: string;
	canonicalURL?: URL | string;
	schemaGraph?: Record<string, any> | Array<Record<string, any>>;
	robots?: string;
}

const {
	title = "Курьерок — Вся работа здесь",
	titleKey,
	description = "Лучшие вакансии для курьеров в России. Работа на авто, мото, вело и пешком. Сравнивайте условия в Яндекс Еда, СДЭК, Ozon и других компаниях.",
	descriptionKey,
	image = "/favicon.svg",
	canonicalURL = new URL(Astro.url.pathname, Astro.site),
	schemaGraph = [],
	robots = "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1",
} = Astro.props;

const resolvedCanonicalUrl = canonicalURL instanceof URL ? canonicalURL : new URL(canonicalURL, Astro.site);
const socialBaseUrl = Astro.site || resolvedCanonicalUrl;
const resolvedImageUrl = new URL(image, socialBaseUrl).toString();

const websiteSchema = {
	"@type": "WebSite",
	name: "Курьерок",
	url: "https://kurerok.ru/",
};

const normalizedSchemaGraph = Array.isArray(schemaGraph)
	? schemaGraph
	: [schemaGraph];

const structuredData = JSON.stringify(
	{
		"@context": "https://schema.org",
		"@graph": [websiteSchema, ...normalizedSchemaGraph.filter(Boolean)],
	},
	null,
	2,
);

const isProduction = import.meta.env.PROD;
const ga4MeasurementId = String(import.meta.env.PUBLIC_GA4_MEASUREMENT_ID ?? '').trim();
const yandexMetrikaId = String(import.meta.env.PUBLIC_YANDEX_METRIKA_ID ?? '').trim();
const yandexVerification = String(import.meta.env.PUBLIC_YANDEX_VERIFICATION ?? 'ac1cd99571b69d37').trim();
const googleSiteVerification = String(import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION ?? 'QIGlMj-JAXkxvnkeFNNu6hWJ5bslKtguuUxY4ty17bI').trim();
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
		<meta name="generator" content={Astro.generator} />
		<title data-t-title={titleKey}>{title}</title>
		<meta name="description" content={description} data-t-content={descriptionKey} />
		<meta name="robots" content={robots} />
		<link rel="canonical" href={resolvedCanonicalUrl} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
			<meta name="yandex-verification" content={yandexVerification} />
			<meta name="google-site-verification" content={googleSiteVerification} />
		<meta name="format-detection" content="telephone=no" />

		<!-- Google Fonts for Logo Experiments -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;700;800;900&family=Playfair+Display:wght@700;900&family=Montserrat:wght@700;900&display=swap" rel="stylesheet">

			<!-- Theme Persistence -->
			<script is:inline>
				(function() {
					const savedTheme = localStorage.getItem('site-theme');
				const bodyClass = savedTheme && savedTheme !== 'default'
					? `theme-${savedTheme}`
					: 'theme-minimal';
				document.documentElement.dataset.initialTheme = bodyClass;
				})();
			</script>

			{isProduction && ga4MeasurementId && (
				<>
					<script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4MeasurementId}`}></script>
					<script is:inline define:vars={{ ga4MeasurementId }}>
						window.dataLayer = window.dataLayer || [];
						function gtag(){window.dataLayer.push(arguments);}
						gtag('js', new Date());
						gtag('config', ga4MeasurementId, {
							anonymize_ip: true,
						});
					</script>
				</>
			)}

			{isProduction && yandexMetrikaId && (
				<script is:inline define:vars={{ yandexMetrikaId }}>
					(function(m,e,t,r,i,k,a){
						m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
						m[i].l=1*new Date();
						for (var j = 0; j < document.scripts.length; j++) {
							if (document.scripts[j].src === r) return;
						}
						k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a);
					})(window, document, 'script', 'https://mc.yandex.ru/metrika/tag.js', 'ym');

					ym(Number(yandexMetrikaId), 'init', {
						clickmap:true,
						trackLinks:true,
						accurateTrackBounce:true,
						webvisor:true
					});
				</script>
			)}

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Курьерок" />
		<meta property="og:locale" content="ru_RU" />
		<meta property="og:url" content={resolvedCanonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={resolvedImageUrl} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={resolvedCanonicalUrl} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={resolvedImageUrl} />

		<meta name="theme-color" content="#16734c" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

		<!-- Schema.org Markup -->
		<script type="application/ld+json" set:html={structuredData}></script>
	</head>
		<body class="theme-minimal">
			{isProduction && yandexMetrikaId && (
				<noscript>
					<div>
						<img src={`https://mc.yandex.ru/watch/${yandexMetrikaId}`} style="position:absolute; left:-9999px;" alt="" />
					</div>
				</noscript>
			)}
			<script is:inline>
				(function() {
					const initialTheme = document.documentElement.dataset.initialTheme;
				document.body.className = initialTheme || 'theme-minimal';
			})();
		</script>
		<div class="bg-blob blob-1"></div>
		<div class="bg-blob blob-2"></div>
		
		<slot />

		<VPNModal />

		<script is:inline>
			(async function() {
				if (window.kurieros_user) return;

				if (['localhost', '127.0.0.1'].includes(window.location.hostname)) {
					return;
				}
				
				async function fetchWithTimeout(resource, options = {}) {
					const { timeout = 5000 } = options;
					const controller = new AbortController();
					const id = setTimeout(() => controller.abort(), timeout);
					const response = await fetch(resource, { ...options, signal: controller.signal });
					clearTimeout(id);
					return response;
				}

				function normalizeGeoData(raw) {
					if (!raw) return null;

					if (raw.country) {
						return {
							city: raw.city,
							country: raw.country,
							country_name: raw.country_name,
						};
					}

					if (raw.success !== false && raw.country_code) {
						return {
							city: raw.city,
							country: raw.country_code,
							country_name: raw.country,
						};
					}

					return null;
				}

				let data = null;
				try {
					const res = await fetchWithTimeout('https://ipapi.co/json/');
					if (res.ok) {
						data = normalizeGeoData(await res.json());
					}
				} catch {
					try {
						const res = await fetchWithTimeout('https://ipwho.is/');
						if (res.ok) {
							data = normalizeGeoData(await res.json());
						}
					} catch {}
				}

				if (data) {
					window.kurieros_user = data;
					window.dispatchEvent(new CustomEvent('kurieros:region-detected', { detail: data }));
				}
			})();
		</script>
		<script is:inline define:vars={{ translations, supportedLanguages }}>
			// Global i18n Manager
			(function() {
				const STORAGE_KEY = 'site-lang';
				const DEFAULT_LANG = 'ru';
				const SUPPORTED_LANGS = supportedLanguages;
				window.translations = translations;
				
				function getSafeLang(lang) {
					return SUPPORTED_LANGS.includes(lang) ? lang : DEFAULT_LANG;
				}

				function getNestedValue(obj, path) {
					return path.split('.').reduce((prev, curr) => prev && prev[curr], obj);
				}

				const savedLang = localStorage.getItem(STORAGE_KEY);
				const initialLang = getSafeLang(savedLang || DEFAULT_LANG);
				if (savedLang !== initialLang) {
					localStorage.setItem(STORAGE_KEY, initialLang);
				}

				window.kurieros_i18n = {
					currentLang: initialLang,
					
					setLanguage(lang) {
						lang = getSafeLang(lang);
						this.currentLang = lang;
						localStorage.setItem(STORAGE_KEY, lang);
						this.applyTranslations();
						window.dispatchEvent(new CustomEvent('kurieros:lang-change', { detail: { lang } }));
					},

					applyTranslations() {
						const elements = document.querySelectorAll('[data-t]');
						const contentElements = document.querySelectorAll('[data-t-content]');
						const titleElement = document.querySelector('[data-t-title]');
						const lang = getSafeLang(this.currentLang);
						const langData = translations[lang] || translations[DEFAULT_LANG];
						
						elements.forEach(el => {
							const key = el.getAttribute('data-t');
							const translation = getNestedValue(langData, key) || getNestedValue(translations[DEFAULT_LANG], key);
							
							if (translation) {
								if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
									el.placeholder = translation;
								} else {
									el.textContent = translation;
								}
							}
						});

						contentElements.forEach(el => {
							const key = el.getAttribute('data-t-content');
							const translation = getNestedValue(langData, key) || getNestedValue(translations[DEFAULT_LANG], key);

							if (translation) {
								el.setAttribute('content', translation);
							}
						});

						if (titleElement) {
							const key = titleElement.getAttribute('data-t-title');
							const translation = getNestedValue(langData, key) || getNestedValue(translations[DEFAULT_LANG], key);

							if (translation) {
								titleElement.textContent = translation;
								document.title = translation;
							}
						}
						
						document.documentElement.setAttribute('lang', lang);
					}
				};

				document.addEventListener('DOMContentLoaded', () => {
					window.kurieros_i18n.applyTranslations();
				});
				
			})();
		</script>
	</body>
</html>
