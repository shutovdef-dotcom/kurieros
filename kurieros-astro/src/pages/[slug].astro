---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import JobGrid from '../components/JobGrid.astro';
import jobsData from '../data/jobs.json';
import { CATEGORIES } from '../data/constants';
import { getCitiesFromJobs } from '../utils/cities';

export async function getStaticPaths() {
	const paths = [];

	// Add cities from vacancies
	getCitiesFromJobs(jobsData).forEach((city) => {
		paths.push({
			params: { slug: `rabota-kurerom-${city.slug}` },
			props: { 
				type: 'city',
				data: city,
				title: `Работа курьером ${city.prep} — Вакансии 2026`,
				description: `Свежие вакансии для курьеров ${city.prep}. Сравнивайте условия, выбирайте лучшие компании и зарабатывайте до 250 000 ₽.`
			},
		});
	});

	// Add categories
	CATEGORIES.forEach((cat) => {
		paths.push({
			params: { slug: `rabota-kurerom-${cat.slug}` },
			props: { 
				type: 'category',
				data: cat,
				title: `Работа курьером: ${cat.name} — Вакансии 2026`,
				description: `Все вакансии для курьеров категории "${cat.name}". Прямые работодатели, удобный фильтр и быстрое трудоустройство.`
			},
		});
	});

	return paths;
}

const { type, data, title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
	<Header />

	<main>
		<section class="hero listing-hero">
			<h1>{title}</h1>
			<p>
				{type === 'city' 
					? `Актуальные предложения о работе курьером ${data.prep}.`
					: `Список всех доступных вакансий в категории "${data.name}".`
				}
			</p>
		</section>

		<JobGrid 
			initialCity={type === 'city' ? data.name : undefined} 
			initialTag={type === 'category' ? data.tag : undefined}
			initialSearch={type === 'category' ? data.query : undefined}
		/>
	</main>

	<Footer />
</BaseLayout>

<style>
	.listing-hero {
		max-width: 980px;
		padding: 1.5rem 1rem 0.75rem;
		margin: 0 auto 1.5rem;
	}

	.listing-hero h1 {
		max-width: 980px;
		margin-inline: auto;
		margin-bottom: 0.75rem;
		text-wrap: balance;
	}

	.listing-hero p {
		max-width: 720px;
		margin-inline: auto;
		margin-bottom: 0;
		font-size: clamp(1rem, 1.2vw + 0.85rem, 1.15rem);
		line-height: 1.6;
	}

	@media (min-width: 768px) {
		.listing-hero {
			padding: 2.5rem 1rem 1rem;
			margin-bottom: 2rem;
		}
	}
</style>
