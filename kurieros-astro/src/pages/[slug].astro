---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import JobGrid from '../components/JobGrid.astro';
import articlesData from '../data/articles.json';
import jobsData from '../data/jobs';
import { CATEGORIES } from '../data/constants';
import { getCitiesFromJobs } from '../utils/cities';
import { slugifyCompany } from '../utils/companies';
import { formatMoney, getVacancyPluralText, humanJoin, parseSalary } from '../utils/format';
import { buildBreadcrumbSchema } from '../utils/schema';

export async function getStaticPaths() {
	const paths = [];

	getCitiesFromJobs(jobsData).forEach((city) => {
		paths.push({
			params: { slug: `rabota-kurerom-${city.slug}` },
			props: {
				type: 'city',
				data: city,
				title: `Работа курьером ${city.prep} — Вакансии 2026`,
				description: `Свежие вакансии для курьеров ${city.prep}. Сравнивайте условия, компании и выплаты до отклика.`,
			},
		});
	});

	CATEGORIES.forEach((cat) => {
		paths.push({
			params: { slug: `rabota-kurerom-${cat.slug}` },
			props: {
				type: 'category',
				data: cat,
				title: `Работа курьером: ${cat.name} — Вакансии 2026`,
				description: `Вакансии курьеров в формате "${cat.name}": выплаты, компании, требования и быстрый переход к подходящим вариантам.`,
			},
		});
	});

	return paths;
}

const { type, data, title, description } = Astro.props;
const searchTerm = type === 'category' ? (data.query || '').toLowerCase() : '';
const tagFilter = type === 'category' ? data.tag || 'all' : 'all';

const filteredJobs = jobsData.filter((job) => {
	const matchesCity =
		type !== 'city' ||
		job.location.toLowerCase().includes(data.name.toLowerCase()) ||
		job.location === 'Вся Россия';
	const matchesTag = tagFilter === 'all' || job.tags.includes(tagFilter);
	const matchesSearch =
		!searchTerm ||
		job.title.toLowerCase().includes(searchTerm) ||
		job.company.toLowerCase().includes(searchTerm) ||
		job.location.toLowerCase().includes(searchTerm) ||
		job.salary.toLowerCase().includes(searchTerm);

	return matchesCity && matchesTag && matchesSearch;
});

const companyNames = Array.from(new Set(filteredJobs.map((job) => job.company)));
const relatedCompanies = companyNames.slice(0, 6).map((company) => ({
	name: company,
	href: `/companies/${slugifyCompany(company)}/`,
}));
const paymentTypes = Array.from(new Set(filteredJobs.map((job) => job.details.payment_freq)));
const transportLabelMap: Record<string, string> = {
	auto: 'На авто',
	bicycle: 'На велосипеде или самокате',
	foot: 'Пеший формат',
};
const transportTypes = Array.from(
	new Set(
		filteredJobs.flatMap((job) =>
			job.tags
				.filter((tag) => tag in transportLabelMap)
				.map((tag) => transportLabelMap[tag]),
		),
	),
);
const availableTags = new Set(filteredJobs.flatMap((job) => job.tags));
const hasDailyPayments = paymentTypes.some((payment) => payment.toLowerCase().includes('ежеднев'));
const hasWeeklyPayments = paymentTypes.some((payment) => payment.toLowerCase().includes('еженед'));
const cityScenarioRoutes =
	type === 'city'
		? ['na-avto', 'peshkom', 'na-velosipede', 'dlya-studentov', 'podrabotka', 'ezhednevnaya-oplata', 'ezhenedelnaya-oplata']
			.filter((slug) => {
				if (slug === 'na-avto') return availableTags.has('auto');
				if (slug === 'peshkom') return availableTags.has('foot');
				if (slug === 'na-velosipede') return availableTags.has('bicycle');
				if (slug === 'dlya-studentov') return availableTags.has('16plus');
				if (slug === 'podrabotka') return availableTags.has('flexible');
				if (slug === 'ezhednevnaya-oplata') return hasDailyPayments;
				if (slug === 'ezhenedelnaya-oplata') return hasWeeklyPayments;
				return false;
			})
			.map((slug) => CATEGORIES.find((category) => category.slug === slug))
			.filter(Boolean)
			.slice(0, 5)
			.map((category) => ({
				name: category!.name,
				href: `/rabota-kurerom-${category!.slug}/`,
			}))
		: [];
const cityCompanyCards =
	type === 'city'
		? Array.from(
			filteredJobs.reduce(
				(map, job) => {
					const existing = map.get(job.company) ?? {
						name: job.company,
						href: `/companies/${slugifyCompany(job.company)}/`,
						vacancyCount: 0,
						maxSalary: 0,
						payments: new Set<string>(),
						transports: new Set<string>(),
					};

					existing.vacancyCount += 1;
					existing.maxSalary = Math.max(existing.maxSalary, parseSalary(job.salary));
					existing.payments.add(job.details.payment_freq);
					job.tags
						.filter((tag) => tag in transportLabelMap)
						.forEach((tag) => existing.transports.add(transportLabelMap[tag]));

					map.set(job.company, existing);
					return map;
				},
				new Map<
					string,
					{
						name: string;
						href: string;
						vacancyCount: number;
						maxSalary: number;
						payments: Set<string>;
						transports: Set<string>;
					}
				>(),
			).values(),
		)
			.map((company) => ({
				name: company.name,
				href: company.href,
				vacancyCount: company.vacancyCount,
				maxSalary: company.maxSalary,
				paymentPreview: Array.from(company.payments).slice(0, 2),
				transportPreview: Array.from(company.transports).slice(0, 2),
			}))
			.sort((a, b) => b.vacancyCount - a.vacancyCount || b.maxSalary - a.maxSalary)
			.slice(0, 4)
		: [];
const salaryLeader =
	type === 'city' ? [...cityCompanyCards].sort((a, b) => b.maxSalary - a.maxSalary)[0] : null;
const localStartPoints =
	type === 'city'
		? [
			cityCompanyCards[0]
				? `Больше всего вариантов сейчас у ${cityCompanyCards[0].name}. Начните с этой компании, если хотите быстро понять рынок ${data.prep}.`
				: `В подборке ${data.prep} уже есть несколько вакансий. Сначала посмотрите компании, где больше открытых позиций.`,
			salaryLeader
				? `Самая высокая заявленная сумма сейчас у ${salaryLeader.name}: до ${formatMoney(salaryLeader.maxSalary)} ₽. Проверьте, из чего складывается эта цифра.`
				: 'Доход зависит от смен, района и транспорта, поэтому лучше сравнить несколько вакансий перед откликом.',
			transportTypes.length
				? `В городе есть варианты: ${humanJoin(transportTypes).toLowerCase()}. Можно сразу сузить список по транспорту и графику.`
				: 'Формат работы зависит от работодателя, поэтому после выбора города полезно открыть страницы по типу доставки.',
		]
		: [];
const updatedDate = new Intl.DateTimeFormat('ru-RU', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
}).format(new Date());
const seoTitle =
	type === 'city'
		? `Работа курьером ${data.prep}: вакансии и зарплата | Курьерок`
		: `Работа курьером ${data.name.toLowerCase()}: вакансии и условия | Курьерок`;
const seoDescription = (
	type === 'city'
		? `Работа курьером ${data.prep}: ${filteredJobs.length} вакансий от ${companyNames.length} компаний, выплаты ${paymentTypes.slice(0, 2).join(' / ') || 'уточняются в карточках'}. Сравните условия и откройте подходящие отклики.`
		: `Подборка "${data.name}": ${filteredJobs.length} вакансий от ${companyNames.length} компаний, форматы ${transportTypes.join(', ') || 'разные'}. Сравните условия и выберите подходящую карточку вакансии.`
).slice(0, 170);
const relatedArticles = articlesData
	.filter((article) => {
		const haystack = `${article.title} ${article.description}`.toLowerCase();
		if (type === 'city') {
			return haystack.includes(data.name.toLowerCase()) || haystack.includes('курьер');
		}
		return haystack.includes(data.name.toLowerCase()) || haystack.includes(searchTerm) || haystack.includes('курьер');
	})
	.slice(0, 3);
const routeLinks =
	type === 'city'
		? [
			{ name: 'Сравнение вакансий', href: '/compare/' },
			{ name: 'Компании', href: '/companies/' },
			...CATEGORIES.filter((cat) => cat.slug !== data.slug).slice(0, 4).map((cat) => ({
				name: cat.name,
				href: `/rabota-kurerom-${cat.slug}/`,
			})),
		]
		: [
			{ name: 'Сравнение вакансий', href: '/compare/' },
			{ name: 'Города', href: '/cities/' },
			...getCitiesFromJobs(jobsData)
				.filter((city) => city.name !== data.name)
				.sort((a, b) => b.vacancyCount - a.vacancyCount)
				.slice(0, 4)
				.map((city) => ({
					name: city.name,
					href: `/rabota-kurerom-${city.slug}/`,
				})),
		];

const quickLaunchLinks =
	type === 'city'
		? [
			...cityScenarioRoutes.slice(0, 4),
			{ name: 'Компании', href: '/companies/' },
			{ name: 'Сравнение', href: '/compare/' },
		]
		: [
			{ name: 'Сравнение', href: '/compare/' },
			{ name: 'Города', href: '/cities/' },
			...routeLinks.slice(2, 5),
		];
const heroIntro =
	type === 'city'
		? `Ниже собраны вакансии ${data.prep}. Смотрите оплату, транспорт, оформление и переходите только в те варианты, где условия похожи на ваши.`
		: `Ниже собраны вакансии по этому формату. Сначала проверьте оплату и требования, затем переходите к компаниям или городам.`;
const launchSummary =
	type === 'city'
		? `Мы уже оставили в списке только предложения ${data.prep}. Используйте фильтры, если важен конкретный транспорт или график.`
		: 'Мы уже применили нужный фильтр. Остаётся сравнить несколько вакансий и открыть те, где условия подходят.';
const factCards = [
	{ label: 'Вакансии', value: `${filteredJobs.length}` },
	{ label: 'Компании', value: `${companyNames.length}` },
	{ label: 'Форматы', value: transportTypes.join(', ') || 'Смешанные форматы' },
	{ label: 'Выплаты', value: paymentTypes.slice(0, 2).join(' / ') || 'Уточняются в карточке' },
];

const fitPoints =
	type === 'city'
		? [
			`Тем, кто ищет работу курьером ${data.prep} и хочет увидеть активные компании в одном списке.`,
			`Кандидатам, которые выбирают между пешей доставкой, велосипедом, самокатом или автомобилем.`,
			`Тем, кто хочет сначала спокойно сравнить условия, а уже потом переходить к анкете работодателя.`,
		]
		: [
			`Тем, кто рассматривает формат "${data.name}" и хочет увидеть несколько вариантов без ручного поиска.`,
			`Кандидатам, которым важно сравнить выплаты, требования и занятость до перехода к анкете.`,
			`Тем, кто хочет отсечь неподходящие вакансии и открыть только близкие по условиям.`,
		];

const cautionPoints = [
	'Финальные условия по выплатам, возрасту, гражданству и оформлению подтверждайте на странице вакансии или у работодателя.',
	'Если вам принципиальны конкретный район, официальный ТК РФ или точный график смен, открывайте карточки вакансий и сравнивайте детали поштучно.',
	'Часть ссылок ведёт на внешнюю анкету работодателя или партнёра. Перед отправкой заявки ещё раз проверьте условия.',
];

const faqItems =
	type === 'city'
		? [
			{
				question: `Какие вакансии курьера есть ${data.prep}?`,
				answer: `На этой странице собраны ${filteredJobs.length} вакансий от ${companyNames.length} компаний. В подборке есть форматы ${transportTypes.join(', ').toLowerCase() || 'с разными типами занятости'} и разные графики работы.`,
			},
			{
				question: `Кому подходит работа курьером ${data.prep}?`,
				answer: `Страница подходит тем, кто хочет сравнить локальные вакансии по выплатам, требованиям и компаниям, а затем открыть только подходящие варианты.`,
			},
			{
				question: 'Что проверить перед откликом?',
				answer: 'Перед откликом стоит открыть карточку вакансии и уточнить выплаты, оформление, возрастной порог, гражданство, медкнижку и формат занятости.',
			},
		]
		: [
			{
				question: `Что входит в подборку "${data.name}"?`,
				answer: `На странице собраны ${filteredJobs.length} вакансий от ${companyNames.length} компаний, которые подходят под формат "${data.name}".`,
			},
			{
				question: `Кому подходит формат "${data.name}"?`,
				answer: `Эта подборка подходит тем, кто хочет сравнить один конкретный формат работы курьером и выбрать вакансию по графику, выплатам и базовым требованиям.`,
			},
			{
				question: 'Нужно ли сразу откликаться?',
				answer: 'Нет. Сначала стоит открыть карточки вакансий, проверить ограничения и только потом переходить по ссылке отклика на сайт работодателя или партнёра.',
			},
		];

const pageSchemaGraph = [
	{
		'@type': 'CollectionPage',
		name: title,
		description: seoDescription,
		url: Astro.url.href,
		dateModified: new Date().toISOString(),
		mainEntity: {
			'@type': 'ItemList',
			itemListElement: filteredJobs.slice(0, 10).map((job, index) => ({
				'@type': 'ListItem',
				position: index + 1,
				name: job.title,
				url: new URL(`/v/${job.slug}/`, Astro.site).toString(),
			})),
		},
	},
	{
		'@type': 'FAQPage',
		mainEntity: faqItems.map((item) => ({
			'@type': 'Question',
			name: item.question,
			acceptedAnswer: {
				'@type': 'Answer',
				text: item.answer,
			},
		})),
	},
	buildBreadcrumbSchema(
		type === 'city'
			? [
				{ name: 'Главная', url: '/' },
				{ name: 'Города', url: '/cities/' },
				{ name: title, url: Astro.url.pathname },
			]
			: [
				{ name: 'Главная', url: '/' },
				{ name: title, url: Astro.url.pathname },
			],
		Astro.site,
	),
];
---

<BaseLayout title={seoTitle} description={seoDescription} schemaGraph={pageSchemaGraph}>
	<Header />

	<main>
		<section class="hero listing-hero">
			<div class="listing-hero-panel">
				<nav class="listing-breadcrumb" aria-label="Хлебные крошки">
					<a href="/">Главная</a>
					{type === 'city' && (
						<>
							<span>&gt;</span>
							<a href="/cities/">Города</a>
						</>
					)}
					<span>&gt;</span>
					<span>{type === 'city' ? `Работа курьером ${data.prep}` : data.name}</span>
				</nav>
				<p class="section-eyebrow">{type === 'city' ? 'Вакансии в городе' : 'Готовый фильтр'}</p>
				<h1>{title}</h1>
				<p>{heroIntro}</p>
				<div class="listing-hero-actions">
					<a href="#vacancies" class="listing-primary-link">Смотреть вакансии</a>
					<a href="/compare/" class="listing-secondary-link">Сравнить условия</a>
				</div>
				<div class="listing-fact-grid listing-fact-grid-hero">
					{factCards.map((fact) => (
						<article class="listing-fact-card">
							<span>{fact.label}</span>
							<strong>{fact.value}</strong>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="listing-vacancy-launch">
			<div class="listing-vacancy-launch-copy">
				<p class="section-eyebrow">Список вакансий</p>
				<h2>Начните с условий, а не с обещаний</h2>
				<p>{launchSummary}</p>
			</div>
			<div class="listing-vacancy-launch-actions">
				<a href="#vacancies" class="listing-primary-link">Перейти к ленте</a>
				<div class="link-chip-row">
					{quickLaunchLinks.map((link) => (
						<a href={link.href} class="link-chip">{link.name}</a>
					))}
				</div>
			</div>
		</section>

		<JobGrid
			initialCity={type === 'city' ? data.name : undefined}
			initialTag={type === 'category' ? data.tag : undefined}
			initialSearch={type === 'category' ? data.query : undefined}
		/>

		{type === 'city' && (
			<>
				<section class="listing-local-grid">
					<article class="listing-local-card">
						<p class="section-eyebrow">Старт в городе</p>
						<h2>Как быстрее сузить выбор {data.prep}?</h2>
						<ul class="listing-bullet-list">
							{localStartPoints.map((point) => (
								<li>{point}</li>
							))}
						</ul>
					</article>

					{cityScenarioRoutes.length > 0 && (
						<article class="listing-local-card">
							<p class="section-eyebrow">Форматы работы</p>
							<h2>Какие варианты уже есть {data.prep}?</h2>
							<div class="link-chip-row">
								{cityScenarioRoutes.map((route) => (
									<a href={route.href} class="link-chip">{route.name}</a>
								))}
							</div>
						</article>
					)}
				</section>

				{cityCompanyCards.length > 0 && (
					<section class="listing-company-section" aria-label="Компании в городе">
						<p class="section-eyebrow">Компании</p>
						<h2>Какие компании уже активны {data.prep}?</h2>
						<div class="listing-company-grid">
							{cityCompanyCards.map((company) => (
								<a href={company.href} class="listing-company-card">
									<strong>{company.name}</strong>
									<span>{company.vacancyCount} {getVacancyPluralText(company.vacancyCount)} в подборке</span>
									<small>
										До {formatMoney(company.maxSalary)} ₽
										{company.paymentPreview.length ? ` · ${company.paymentPreview.join(' / ')}` : ''}
									</small>
									<small>
										Форматы: {company.transportPreview.length ? company.transportPreview.join(', ') : 'смешанные'}
									</small>
								</a>
							))}
						</div>
					</section>
				)}
			</>
		)}

		<section class="listing-geo-grid">
			<article class="listing-geo-card">
				<p class="section-eyebrow">Кому подходит</p>
				<h2>
					{type === 'city'
						? `Кому подойдут вакансии ${data.prep}?`
						: `Кому подойдёт формат "${data.name}"?`}
				</h2>
				<ul class="listing-bullet-list">
					{fitPoints.map((point) => (
						<li>{point}</li>
					))}
				</ul>
			</article>

			<article class="listing-geo-card listing-geo-card-caution">
				<p class="section-eyebrow">Что уточнить</p>
				<h2>Что нужно проверить перед откликом?</h2>
				<ol class="listing-bullet-list numbered-list">
					{cautionPoints.map((point) => (
						<li>{point}</li>
					))}
				</ol>
			</article>
		</section>

		<section class="listing-faq-section" aria-label="Частые вопросы по подборке">
			<p class="section-eyebrow">FAQ</p>
			<h2>
				{type === 'city'
					? `Короткие ответы о работе курьером ${data.prep}`
					: `Короткие ответы по формату "${data.name}"`}
			</h2>
			<div class="listing-faq-grid">
				{faqItems.map((item) => (
					<article class="listing-faq-item">
						<h3>{item.question}</h3>
						<p>{item.answer}</p>
					</article>
				))}
			</div>
		</section>

		<section class="listing-trust-panel">
			<div>
				<p class="section-eyebrow">Важно помнить</p>
				<h2>Как читать эту страницу</h2>
			</div>
			<p>
				Данные на странице обновлены {updatedDate}. Мы показываем удобную сводку, но условия могут отличаться по городу,
				району и смене. Перед откликом откройте карточку вакансии и проверьте выплаты, оформление и ограничения.
			</p>
		</section>

		<section class="listing-link-grid">
			<article class="listing-link-card">
				<p class="section-eyebrow">Компании</p>
				<h2>
					{type === 'city'
						? `Какие компании есть ${data.prep}?`
						: `Какие компании есть в формате "${data.name}"?`}
				</h2>
				<div class="link-chip-row">
					{relatedCompanies.length > 0 ? (
						relatedCompanies.map((company) => (
							<a href={company.href} class="link-chip">{company.name}</a>
						))
					) : (
