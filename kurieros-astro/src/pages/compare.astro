---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import jobsData from '../data/jobs.json';
import articlesData from '../data/articles.json';
import { slugifyCompany } from '../utils/companies';
import { buildBreadcrumbSchema } from '../utils/schema';

const companyColors: Record<string, string> = {
  'Яндекс Еда': '#FFCC00',
  'Ozon': '#005BFF',
  'Самокат': '#FF4063',
  'СДЭК': '#00B050',
  'ВкусВилл': '#1A9A50',
  'ВТБ': '#0A2896',
};

const transportLabelMap: Record<string, string> = {
  auto: 'Авто',
  bicycle: 'Велосипед / самокат',
  foot: 'Пешком',
};

const parseSalary = (salary: string) => Number(salary.replace(/[^\d]/g, '')) || 0;
const getTransportLabel = (tags: string[]) =>
  tags.find((tag) => tag in transportLabelMap)
    ? transportLabelMap[tags.find((tag) => tag in transportLabelMap) as string]
    : 'Смешанный формат';

const compareJobs = jobsData.slice(0, 4).map((job) => ({
  id: job.id,
  slug: job.slug,
  title: job.title,
  company: job.company,
  companyHref: `/companies/${slugifyCompany(job.company)}/`,
  logoColor: companyColors[job.company] || '#6366F1',
  salary: job.salary,
  location: job.location,
  transport: getTransportLabel(job.tags),
  contract: job.details.employment_type,
  payout: job.details.payment_freq,
  bonus: job.benefits[0] || 'Условия уточняются при отклике',
  age: job.details.age,
  link: `/v/${job.slug}/`,
}));

const compareCompanies = Array.from(
  new Map(compareJobs.map((job) => [job.company, { name: job.company, href: job.companyHref }])).values(),
);
const relatedArticles = articlesData
  .filter((article) => /срав|выбрать|курьер|доход|компан/i.test(`${article.title} ${article.description}`))
  .slice(0, 3)
  .map((article) => ({
    title: article.title,
    href: `/blog/${article.slug}/`,
  }));

const features = [
  { key: 'salary', name: 'Зарплата' },
  { key: 'location', name: 'Район работы' },
  { key: 'transport', name: 'Транспорт' },
  { key: 'contract', name: 'Оформление' },
  { key: 'payout', name: 'Выплаты' },
  { key: 'bonus', name: 'Особенности' },
];

const topIncomeJob = [...compareJobs].sort((a, b) => parseSalary(b.salary) - parseSalary(a.salary))[0];
const studentFriendlyJob = compareJobs.find((job) => job.age.includes('16')) || compareJobs[0];
const stableContractJob = compareJobs.find((job) => /тк|официаль/i.test(job.contract)) || compareJobs[0];

const verdictCards = [
  {
    label: 'Лучше для дохода',
    title: topIncomeJob.title,
    text: `${topIncomeJob.company} выглядит самым сильным вариантом по верхней планке дохода, но финальные цифры всё равно нужно подтверждать перед откликом.`,
  },
  {
    label: 'Лучше для старта',
    title: studentFriendlyJob.title,
    text: `${studentFriendlyJob.company} лучше подходит тем, кто ищет вход в профессию с более мягким возрастным порогом и понятным стартом.`,
  },
  {
    label: 'Лучше для стабильности',
    title: stableContractJob.title,
    text: `${stableContractJob.company} стоит смотреть тем, кому важнее понятное оформление и предсказуемый формат занятости.`,
  },
];

const fitPoints = [
  'Сравнение полезно тем, кто уже выбрал 2-4 похожих вакансии и хочет быстро увидеть разницу по выплатам, транспорту и оформлению.',
  'Такой экран особенно помогает перед откликом, когда нужно отсечь неподходящие условия без лишних переходов между страницами.',
  'Если выбор уже сузился до одной компании, после сравнения лучше открыть её карточку и проверить ограничения детально.',
];

const cautionPoints = [
  'Верхняя зарплатная планка не равна гарантированному доходу: проверяйте формулу выплат и частоту начислений.',
  'Если для вас критичны ТК РФ, гражданство, медкнижка или точный район, эти пункты лучше сверять в карточке вакансии.',
  'Сравнение помогает принять решение быстрее, но финальные условия подтверждаются уже у работодателя или в анкете партнера.',
];

const faqItems = [
  {
    question: 'Как читать это сравнение вакансий?',
    answer: 'Сначала посмотрите на формат транспорта, выплаты и оформление, а затем откройте подходящие карточки вакансий, чтобы проверить ограничения и детали отклика.',
  },
  {
    question: 'Что сравнивать в первую очередь?',
    answer: 'Обычно первыми стоит сравнить выплаты, формат занятости, требования к транспорту и возрастной порог. Именно эти параметры быстрее всего отсеивают неподходящие варианты.',
  },
  {
    question: 'Можно ли выбирать только по зарплате?',
    answer: 'Нет. Верхняя планка дохода без графика, условий оформления и частоты выплат почти всегда даёт неполную картину, поэтому лучше смотреть на набор факторов сразу.',
  },
];

const pageSchemaGraph = [
  {
    '@type': 'WebPage',
    name: 'Сравнение вакансий курьеров',
    description: 'Сравнение условий по нескольким вакансиям курьеров: выплаты, транспорт, оформление и особенности работы.',
    url: Astro.url.href,
    dateModified: new Date().toISOString(),
  },
  {
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  },
  buildBreadcrumbSchema(
    [
      { name: 'Главная', url: '/' },
      { name: 'Сравнение вакансий', url: '/compare/' },
    ],
    Astro.site,
  ),
];
---

<BaseLayout title="Сравнение вакансий курьеров" description="Сравните вакансии курьеров по выплатам, транспорту, оформлению и ключевым условиям перед откликом." schemaGraph={pageSchemaGraph}>
  <Header />

  <main class="compare-page">
    <div class="compare-container">
      <div class="compare-header">
        <div>
          <nav class="compare-breadcrumb" aria-label="Breadcrumb">
            <a href="/">Главная</a>
            <span>/</span>
            <span>Сравнение вакансий</span>
          </nav>
          <h1>Сравнение вакансий</h1>
          <p class="compare-subtitle">Сначала короткий вывод и правила выбора, потом детальная таблица по условиям.</p>
        </div>
        <a href="/" class="back-link">← К списку вакансий</a>
      </div>

      <section class="compare-answer-panel">
        <div>
          <p class="section-eyebrow">AI GEO TL;DR</p>
          <h2>Что важнее всего в этом сравнении?</h2>
        </div>
        <p>
          Это экран для быстрого выбора между похожими вакансиями курьера. Сначала сравните выплаты, формат транспорта и
          оформление, а затем переходите только в те карточки, которые подходят вам по реальным ограничениям, а не только
          по верхней зарплатной вилке.
        </p>
      </section>

      <section class="compare-verdict-grid" aria-label="Быстрые выводы по сравнению">
        {verdictCards.map((card) => (
          <article class="compare-verdict-card">
            <span>{card.label}</span>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </section>

      <section class="compare-geo-grid">
        <article class="compare-geo-card">
          <p class="section-eyebrow">Кому подходит</p>
          <h2>Когда это сравнение реально полезно?</h2>
          <ul class="compare-list">
            {fitPoints.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
        </article>

        <article class="compare-geo-card compare-geo-card-caution">
          <p class="section-eyebrow">Что уточнить</p>
          <h2>Что проверить перед откликом?</h2>
          <ol class="compare-list numbered-list">
            {cautionPoints.map((point) => (
              <li>{point}</li>
            ))}
          </ol>
        </article>
      </section>

      <section class="compare-link-grid" aria-label="Связанные хабы">
        <article class="compare-link-card">
          <p class="section-eyebrow">По компаниям</p>
          <h2>Куда идти после короткого сравнения?</h2>
          <div class="compare-chip-row">
            {compareCompanies.map((company) => (
              <a href={company.href} class="compare-chip-link">{company.name}</a>
            ))}
          </div>
        </article>

        <article class="compare-link-card">
          <p class="section-eyebrow">По материалам</p>
          <h2>Что прочитать перед откликом?</h2>
          <div class="compare-article-stack">
            {relatedArticles.map((article) => (
              <a href={article.href} class="compare-article-link">{article.title}</a>
            ))}
          </div>
        </article>
      </section>

      <div class="compare-table-wrapper">
        <div class="compare-grid">
          <div class="compare-row compare-head">
            <div class="compare-cell feature-col empty-cell">
              Параметры
            </div>
            {compareJobs.map((job, index) => (
              <div class="compare-cell job-col" data-col={index}>
                <div class="job-card-mini">
                  <button class="remove-col-btn" aria-label="Удалить" title="Удалить из сравнения" data-col-target={index}>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                  </button>
                  <div class="company-logo" style={`--compare-logo-bg: ${job.logoColor}20; --compare-logo-color: ${job.logoColor};`}>
                    <span class="company-logo-letter">
                      {job.company.charAt(0)}
                    </span>
                  </div>
                  <h3>{job.title}</h3>
                  <span class="company-name">{job.company}</span>
                </div>
              </div>
            ))}
          </div>

          {features.map((feature) => (
            <div class="compare-row">
              <div class="compare-cell feature-col">
                {feature.name}
              </div>
              {compareJobs.map((job, index) => (
                <div class="compare-cell job-col" data-col={index}>
                  {job[feature.key as keyof typeof job]}
                </div>
              ))}
            </div>
          ))}

          <div class="compare-row compare-actions">
            <div class="compare-cell feature-col"></div>
            {compareJobs.map((job, index) => (
              <div class="compare-cell job-col" data-col={index}>
                <a href={job.link} class="btn-primary">Открыть карточку</a>
              </div>
            ))}
          </div>
        </div>
      </div>

      <section class="compare-faq-section">
        <p class="section-eyebrow">FAQ</p>
        <h2>Короткие ответы перед выбором вакансии</h2>
        <div class="compare-faq-grid">
          {faqItems.map((item) => (
            <article class="compare-faq-item">
              <h3>{item.question}</h3>
              <p>{item.answer}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="compare-trust-panel">
        <div>
          <p class="section-eyebrow">Прозрачность</p>
          <h2>Как использовать это сравнение</h2>
        </div>
        <p>
          Эта страница помогает быстро понять различия между форматами работы, но не заменяет карточку вакансии. После выбора
          подходящего варианта откройте его страницу и подтвердите выплаты, оформление, возрастной порог и ограничения уже по
          актуальным условиям работодателя.
        </p>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const grid = document.querySelector('.compare-grid');
    if (!grid) return;

    const allJobCols = document.querySelectorAll('.compare-head .job-col');
    let totalCols = allJobCols.length;

    const updateGridState = () => {
      grid.style.setProperty('--cols', totalCols.toString());

      if (totalCols === 0) {
        grid.innerHTML = `
          <div class="compare-empty-state">
            <h3>Нет вакансий для сравнения</h3>
            <a href="/" class="btn-primary compare-empty-state-link">Вернуться к списку</a>
          </div>
        `;
      }
    };

    grid.style.setProperty('--cols', totalCols.toString());

    grid.addEventListener('click', (e) => {
      const btn = e.target.closest('.remove-col-btn');
      if (!btn) return;

      const targetCol = btn.getAttribute('data-col-target');
      if (targetCol === null) return;

      const cells = document.querySelectorAll(`.compare-cell[data-col="${targetCol}"]`);
      cells.forEach(cell => cell.remove());

      totalCols--;
      updateGridState();
    });
  });
</script>

<style>
  .compare-page {
    padding: 2.5rem 1.5rem;
    max-width: 1560px;
    margin: 0 auto;
    width: 100%;
    flex: 1;
  }

  .compare-container {
    background: var(--surface-color);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    padding: 2rem;
    box-shadow: var(--shadow-sm);
  }

  .compare-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .compare-header h1 {
    font-size: 2rem;
    font-weight: 800;
    margin: 0 0 0.35rem;
  }

  .compare-subtitle {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 60ch;
  }

  .compare-breadcrumb {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 0.8rem;
    color: var(--text-muted);
    font-size: 0.92rem;
  }

  .compare-breadcrumb a {
    color: inherit;
    text-decoration: none;
  }

  .compare-breadcrumb a:hover {
    color: var(--primary-color);
  }

  .section-eyebrow {
    margin: 0 0 0.55rem;
    font-size: 0.74rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-color);
  }

  .back-link {
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 600;
    font-size: 1.05rem;
    transition: var(--transition);
  }

  .back-link:hover {
    color: var(--primary-color);
  }

  .compare-answer-panel,
  .compare-trust-panel {
    display: grid;
    grid-template-columns: minmax(220px, 0.32fr) minmax(0, 1fr);
    gap: 1.5rem;
    align-items: start;
    margin-bottom: 1rem;
    padding: 1.5rem;
    border: 1px solid rgba(148, 163, 184, 0.16);
    border-radius: 1.5rem;
    background: rgba(255, 255, 255, 0.74);
    box-shadow: var(--shadow-sm);
  }

  .compare-answer-panel h2,
  .compare-answer-panel p,
  .compare-trust-panel h2,
  .compare-trust-panel p {
    margin: 0;
  }

  .compare-answer-panel p,
  .compare-trust-panel p {
    color: var(--text-muted);
    line-height: 1.8;
  }

  .compare-verdict-grid,
  .compare-geo-grid,
  .compare-link-grid,
  .compare-faq-grid {
    display: grid;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .compare-verdict-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .compare-verdict-card,
  .compare-geo-card,
  .compare-link-card,
  .compare-faq-item {
    padding: 1.25rem;
    border-radius: 1.25rem;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(148, 163, 184, 0.16);
    box-shadow: var(--shadow-sm);
  }

  .compare-verdict-card span {
    display: inline-block;
    margin-bottom: 0.6rem;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .compare-verdict-card h3,
  .compare-geo-card h2,
  .compare-link-card h2,
  .compare-faq-section h2 {
    margin: 0 0 0.7rem;
  }

  .compare-verdict-card p,
  .compare-faq-item p {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .compare-geo-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .compare-link-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .compare-geo-card {
    border: 1px solid rgba(99, 102, 241, 0.12);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.96)),
      var(--bg-card);
  }

  .compare-geo-card-caution {
    border-color: rgba(249, 115, 22, 0.16);
  }

  .compare-link-card {
    border-color: rgba(99, 102, 241, 0.12);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(244, 247, 255, 0.96)),
      var(--bg-card);
  }

  .compare-chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .compare-chip-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.25rem;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid rgba(99, 102, 241, 0.14);
    color: var(--text-main);
    text-decoration: none;
    font-weight: 700;
    transition: var(--transition);
  }

  .compare-chip-link:hover,
  .compare-article-link:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
    color: var(--primary-color);
  }

  .compare-article-stack {
    display: grid;
    gap: 0.7rem;
  }

  .compare-article-link {
    display: block;
    padding: 0.85rem 1rem;
    border-radius: 1rem;
    text-decoration: none;
    color: var(--text-main);
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(148, 163, 184, 0.18);
    font-weight: 700;
    line-height: 1.5;
    transition: var(--transition);
  }

  .compare-list {
    margin: 0;
    padding-left: 1.35rem;
  }

  .compare-list li {
    margin-bottom: 0.7rem;
    line-height: 1.7;
  }

  .numbered-list li::marker {
    color: var(--accent-color);
    font-weight: 900;
  }

  .compare-table-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    background: var(--surface-color);
    margin-bottom: 1.5rem;
  }

  .compare-grid {
    --cols: 4;
    --feature-col-width: 160px;
    --job-col-width: 220px;
    --mobile-feature-col-width: 96px;
    --mobile-job-col-width: 94px;
    --mobile-feature-col-width-narrow: 80px;
    --mobile-job-col-width-narrow: 76px;
    display: grid;
    grid-template-columns: minmax(var(--feature-col-width), 200px) repeat(var(--cols), minmax(var(--job-col-width), 1fr));
    min-width: max(100%, calc(var(--feature-col-width) + var(--cols) * var(--job-col-width)));
    background: var(--border-color);
    gap: 1px;
  }

  .compare-row {
    display: contents;
  }

  .compare-cell {
    padding: 1.5rem;
    background: var(--surface-color);
    display: flex;
    align-items: center;
    color: var(--text-main);
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .feature-col {
    font-weight: 700;
    color: var(--text-muted);
    font-size: 0.95rem;
    background: #fdfdfd;
    position: sticky;
    left: 0;
    z-index: 10;
  }

  @media (prefers-color-scheme: dark) {
    .feature-col {
      background: #151e2e;
    }
  }

  .compare-head .compare-cell {
    align-items: flex-start;
    padding-top: 1.5rem;
    padding-bottom: 1.5rem;
  }

  .compare-head .feature-col {
    z-index: 15;
  }

  .empty-cell {
    display: flex;
    align-items: center;
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }

  .job-card-mini {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
    position: relative;
  }

  .remove-col-btn {
    position: absolute;
    top: -0.75rem;
    right: -0.75rem;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: var(--transition);
    z-index: 10;
    box-shadow: var(--shadow-sm);
  }

  .remove-col-btn:hover {
    color: #ef4444;
    border-color: #ef4444;
    background: #fef2f2;
    transform: scale(1.1);
  }

  .company-logo {
    background: var(--compare-logo-bg);
