---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Test data for 4 jobs
const compareJobs = [
  {
    id: 1,
    title: "Курьер на авто",
    company: "Яндекс Еда",
    logoColor: "#FFCC00",
    salary: "до 160 000 ₽",
    location: "Любой район",
    transport: "Авто",
    contract: "Самозанятость",
    payout: "Ежедневно",
    bonus: "Быстрый старт",
    link: "#"
  },
  {
    id: 2,
    title: "Водитель-курьер",
    company: "Ozon",
    logoColor: "#005BFF",
    salary: "до 180 000 ₽",
    location: "Склады ПВЗ",
    transport: "Грузовик",
    contract: "ИП / Самозанятость",
    payout: "Раз в неделю",
    bonus: "Стабильный доход",
    link: "#"
  },
  {
    id: 3,
    title: "Велокурьер",
    company: "Самокат",
    logoColor: "#FF4063",
    salary: "до 120 000 ₽",
    location: "Даркстор",
    transport: "Велосипед",
    contract: "ГПХ / Самозанятость",
    payout: "Раз в неделю",
    bonus: "Форма бесплатно",
    link: "#"
  },
  {
    id: 4,
    title: "Пеший курьер",
    company: "СДЭК",
    logoColor: "#00B050",
    salary: "до 90 000 ₽",
    location: "Один район",
    transport: "Пешком",
    contract: "ТК РФ",
    payout: "2 раза в месяц",
    bonus: "Скидки от партнеров",
    link: "#"
  }
];

const features = [
  { key: 'salary', name: 'Зарплата' },
  { key: 'location', name: 'Район работы' },
  { key: 'transport', name: 'Транспорт' },
  { key: 'contract', name: 'Оформление' },
  { key: 'payout', name: 'Выплаты' },
  { key: 'bonus', name: 'Особенности' }
];
---

<BaseLayout title="Сравнение вакансий курьеров">
  <Header />

  <main class="compare-page">
    <div class="compare-container">
      <div class="compare-header">
        <h1>Сравнение вакансий</h1>
        <a href="/kurieros/" class="back-link">← К списку вакансий</a>
      </div>

      <div class="compare-table-wrapper">
        <div class="compare-grid">
          
          <!-- Шапка таблицы -->
          <div class="compare-row compare-head">
            <div class="compare-cell feature-col empty-cell">
              Параметры
            </div>
            {compareJobs.map((job, index) => (
              <div class="compare-cell job-col" data-col={index}>
                <div class="job-card-mini">
                  <button class="remove-col-btn" aria-label="Удалить" title="Удалить из сравнения" data-col-target={index}>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                  </button>
                  <div class="company-logo" style={`background: ${job.logoColor}20`}>
                    <span style={`color: ${job.logoColor}; font-weight: 800; font-size: 1.25rem;`}>
                      {job.company.charAt(0)}
                    </span>
                  </div>
                  <h3>{job.title}</h3>
                  <span class="company-name">{job.company}</span>
                </div>
              </div>
            ))}
          </div>

          <!-- Строки с характеристиками -->
          {features.map((feature) => (
            <div class="compare-row">
              <div class="compare-cell feature-col">
                {feature.name}
              </div>
              {compareJobs.map((job, index) => (
                <div class="compare-cell job-col" data-col={index}>
                  {job[feature.key as keyof typeof job]}
                </div>
              ))}
            </div>
          ))}

          <!-- Строка с кнопками -->
          <div class="compare-row compare-actions">
            <div class="compare-cell feature-col"></div>
            {compareJobs.map((job, index) => (
              <div class="compare-cell job-col" data-col={index}>
                <a href={job.link} class="btn-primary">Откликнуться</a>
              </div>
            ))}
          </div>

        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const grid = document.querySelector('.compare-grid');
    if (!grid) return;

    // Ищем все уникальные индексы колонок
    const allJobCols = document.querySelectorAll('.compare-head .job-col');
    let totalCols = allJobCols.length;

    const updateGridState = () => {
      grid.style.setProperty('--cols', totalCols.toString());
      
      // Если все удалены, показываем сообщение
      if (totalCols === 0) {
        grid.innerHTML = `
          <div style="padding: 3rem; text-align: center; grid-column: 1 / -1; background: var(--surface-color);">
            <h3 style="margin-bottom: 1rem;">Нет вакансий для сравнения</h3>
            <a href="/kurieros/" class="btn-primary" style="display: inline-block; width: auto;">Вернуться к списку</a>
          </div>
        `;
      }
    };

    grid.style.setProperty('--cols', totalCols.toString());

    // Делегирование событий для кнопок удаления (крестиков)
    grid.addEventListener('click', (e) => {
      const btn = e.target.closest('.remove-col-btn');
      if (!btn) return;
      
      const targetCol = btn.getAttribute('data-col-target');
      if (targetCol === null) return;
      
      // Удаляем все ячейки с данным data-col (для каждой строки)
      const cells = document.querySelectorAll(`.compare-cell[data-col="${targetCol}"]`);
      cells.forEach(cell => cell.remove());
      
      totalCols--;
      updateGridState();
    });
  });
</script>

<style>
  .compare-page {
    padding: 2.5rem 1.5rem;
    max-width: 1560px;
    margin: 0 auto;
    width: 100%;
    flex: 1;
  }

  .compare-container {
    background: var(--surface-color);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    padding: 2rem;
    box-shadow: var(--shadow-sm);
  }

  .compare-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .compare-header h1 {
    font-size: 2rem;
    font-weight: 800;
    margin: 0;
  }

  .back-link {
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 600;
    font-size: 1.05rem;
    transition: var(--transition);
  }

  .back-link:hover {
    color: var(--primary-color);
  }

  .compare-table-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    background: var(--surface-color);
  }

  /* Сетка на CSS Grid */
  .compare-grid {
    --cols: 4;
    --feature-col-width: 160px;
    --job-col-width: 220px;
    --mobile-feature-col-width: 96px;
    --mobile-job-col-width: 94px;
    --mobile-feature-col-width-narrow: 80px;
    --mobile-job-col-width-narrow: 76px;
    display: grid;
    /* 1 колонка характеристик + var(--cols) колонок вакансий */
    grid-template-columns: minmax(var(--feature-col-width), 200px) repeat(var(--cols), minmax(var(--job-col-width), 1fr));
    min-width: max(100%, calc(var(--feature-col-width) + var(--cols) * var(--job-col-width))); /* динамическая ширина */
    background: var(--border-color); /* линии будут формироваться gaps, либо border-bottom/right */
    gap: 1px; /* Тонкая линия разделения через gap! Более надежно, чем рамки */
  }

  .compare-row {
    display: contents; /* Позволяет детям становиться грид-элементами .compare-grid */
  }

  .compare-cell {
    padding: 1.5rem;
    background: var(--surface-color); /* Фон ячеек нужен из-за gap: 1px, который дает цвет бордера */
    display: flex;
    align-items: center;
    color: var(--text-main);
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .feature-col {
    font-weight: 700;
    color: var(--text-muted);
    font-size: 0.95rem;
    background: #fdfdfd;
    position: sticky;
    left: 0;
    z-index: 10;
  }

  @media (prefers-color-scheme: dark) {
    .feature-col {
      background: #151e2e;
    }
  }

  .compare-head .compare-cell {
    align-items: flex-start;
    padding-top: 1.5rem;
    padding-bottom: 1.5rem;
  }

  .compare-head .feature-col {
    z-index: 15;
  }

  .empty-cell {
    display: flex;
    align-items: center;
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }

  .job-card-mini {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
    position: relative;
  }

  .remove-col-btn {
    position: absolute;
    top: -0.75rem;
    right: -0.75rem;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: var(--transition);
    z-index: 10;
    box-shadow: var(--shadow-sm);
  }

  .remove-col-btn:hover {
    color: #ef4444; /* red-500 */
    border-color: #ef4444;
    background: #fef2f2;
    transform: scale(1.1);
  }

  .company-logo {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.75rem;
  }

  .job-card-mini h3 {
    font-size: 1.15rem;
    line-height: 1.3;
    font-weight: 800;
    margin: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .company-name {
    font-size: 0.9rem;
    color: var(--text-muted);
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .compare-actions .compare-cell {
    padding-bottom: 1.5rem;
  }

  /* На мобильных экранах таблица становится плотнее, а лишние вакансии уходят в горизонтальный скролл */
  @media (max-width: 768px) {
    .compare-page {
      padding: 1rem 0.5rem;
    }
    
    .compare-container {
      padding: 0.75rem;
    }

    .compare-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    
    .compare-grid {
      grid-template-columns: var(--mobile-feature-col-width) repeat(var(--cols), var(--mobile-job-col-width));
      min-width: calc(var(--mobile-feature-col-width) + var(--cols) * var(--mobile-job-col-width));
    }

    .compare-cell {
      padding: 0.75rem 0.5rem;
      font-size: 0.82rem;
      line-height: 1.2;
    }

    .feature-col {
      font-size: 0.78rem;
      padding-inline: 0.5rem;
    }

    .job-card-mini {
      gap: 0.35rem;
    }

    .job-card-mini h3 {
      font-size: 0.82rem;
      line-height: 1.15;
    }

    .company-name {
      font-size: 0.72rem;
      line-height: 1.15;
    }

    .btn-primary {
      font-size: 0.74rem;
      padding: 0.65rem 0.35rem;
    }
  }

  @media (max-width: 480px) {
    .compare-page {
      padding: 0.75rem 0.35rem;
    }

    .compare-container {
      padding: 0.5rem;
      border-radius: 24px;
    }

    .compare-header {
      margin-bottom: 1rem;
    }

    .compare-grid {
      grid-template-columns: var(--mobile-feature-col-width-narrow) repeat(var(--cols), var(--mobile-job-col-width-narrow));
      min-width: calc(var(--mobile-feature-col-width-narrow) + var(--cols) * var(--mobile-job-col-width-narrow));
    }

    .company-logo {
      width: 36px;
      height: 36px;
      margin-bottom: 0.45rem;
    }

    .remove-col-btn {
      top: -0.5rem;
      right: -0.5rem;
      width: 22px;
      height: 22px;
    }
  }
</style>
