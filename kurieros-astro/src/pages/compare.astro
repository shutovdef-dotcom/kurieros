---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import jobsData from '../data/jobs.json';

const allJobs = JSON.stringify(jobsData);
---

<BaseLayout title="Сравнение вакансий курьеров — Курьерос" description="Сравните условия работы в разных компаниях: зарплату, график, требования и преимущества. Выберите лучшее предложение для себя.">
    <Header />

    <main>
        <div class="compare-page">
            <section class="compare-hero">
                <span class="compare-eyebrow" data-t="compare.eyebrow">Сравнение вакансий</span>
                <h1 data-t="compare.title">Сравните условия и выберите лучший вариант</h1>
                <p id="compare-count-text" data-t="compare.subtitle">Выберите до 4 вакансий для детального сравнения условий.</p>
            </section>

            <section id="compare-empty" class="compare-empty hidden">
                <div class="compare-empty-mark">+</div>
                <h2 data-t="compare.empty_title">Список сравнения пока пуст</h2>
                <p data-t="compare.empty_text">Добавьте несколько вакансий из общей ленты, чтобы сравнить зарплату, график, выплаты и оформление в одном месте.</p>
                <a href="/kurieros/" class="btn-primary compare-empty-link" data-t="compare.empty_btn">Вернуться к вакансиям</a>
            </section>

            <section id="compare-table-shell" class="compare-table-shell hidden">
                <div class="compare-table-wrap">
                    <table class="compare-table" id="compare-table">
                        <thead id="compare-head"></thead>
                        <tbody id="compare-body"></tbody>
                    </table>
                </div>
            </section>
        </div>
    </main>

    <Footer />
</BaseLayout>

<script is:inline define:vars={{ allJobs }}>
    const jobs = JSON.parse(allJobs);

    const compareRows = [
        { label: 'Зарплата', key: 'salary', highlight: true },
        { label: 'Локация', key: 'location' },
        { label: 'График', path: 'details.schedule' },
        { label: 'Ставка', path: 'details.rate' },
        { label: 'Опыт', getValue: (job) => job.labels.includes('Без опыта') ? 'Без опыта' : 'См. вакансию' },
        { label: 'Возраст', path: 'details.age' },
        { label: 'Выплаты', path: 'details.payment_freq' },
        { label: 'Оформление', path: 'details.employment_type' },
        { label: 'Самозанятость', path: 'details.self_employed' },
        { label: 'Гражданство', path: 'details.citizenship' },
        { label: 'Мед. книжка', path: 'details.medical_book' },
        { label: 'Форма', path: 'details.uniform' },
        { label: 'Устройство', path: 'details.os' }
    ];

    function getValue(job, row) {
        if (typeof row.getValue === 'function') return row.getValue(job);
        if (row.path) return row.path.split('.').reduce((acc, key) => acc?.[key], job);
        return job[row.key];
    }

    function createElement(tag, className, text) {
        const element = document.createElement(tag);
        if (className) element.className = className;
        if (text !== undefined) element.textContent = text;
        return element;
    }

    function updateCompareBadge(compareList) {
        document.querySelectorAll('#compare-badge').forEach((badge) => {
            badge.textContent = compareList.length;
            badge.classList.toggle('hidden', compareList.length === 0);
        });
    }

    function getTranslation(key, defaultText) {
        const lang = window.kurieros_i18n?.currentLang || 'ru';
        const dict = window.translations ? (window.translations[lang] || window.translations['ru']) : null;
        if (!dict) return defaultText;
        return key.split('.').reduce((prev, curr) => prev && prev[curr], dict) || defaultText;
    }

    function renderHeader(selectedJobs) {
        const thead = document.getElementById('compare-head');
        const row = document.createElement('tr');

        const first = createElement('th', 'compare-stub');
        first.scope = 'col';
        first.append(createElement('strong', 'compare-stub-title', getTranslation('job.compare', 'Что сравниваем')));
        row.append(first);

        selectedJobs.forEach((job) => {
            const th = createElement('th', 'compare-job-head');
            th.scope = 'col';
            const titleLink = createElement('a', 'compare-job-title-link', job.title);
            titleLink.href = `/v/${job.slug}/`;
            th.append(titleLink);
            row.append(th);
        });

        thead.replaceChildren(row);
    }

    function renderBody(selectedJobs) {
        const tbody = document.getElementById('compare-body');
        tbody.replaceChildren();

        compareRows.forEach((rowConfig) => {
            const tr = document.createElement('tr');

            const labelCell = createElement('th', 'compare-label-cell', rowConfig.label);
            labelCell.scope = 'row';
            tr.append(labelCell);

            selectedJobs.forEach((job) => {
                const value = getValue(job, rowConfig) || '—';
                const td = createElement('td', rowConfig.highlight ? 'compare-value-cell compare-value-highlight' : 'compare-value-cell');
                td.append(createElement('span', 'compare-value-text', value));
                tr.append(td);
            });

            tbody.append(tr);
        });
    }

    function initCompare() {
        const compareList = JSON.parse(localStorage.getItem('compareList') || '[]');
        const emptyState = document.getElementById('compare-empty');
        const tableShell = document.getElementById('compare-table-shell');
        const countText = document.getElementById('compare-count-text');

        if (compareList.length === 0) {
            tableShell.classList.add('hidden');
            emptyState.classList.remove('hidden');
            countText.innerHTML = `<span data-t="compare.empty_title">${getTranslation('compare.empty_title', 'Список пуст')}</span>`;
            updateCompareBadge(compareList);
            return;
        }

        const selectedJobs = jobs.filter((job) => compareList.includes(job.id)).slice(0, 4);
        tableShell.classList.remove('hidden');
        emptyState.classList.add('hidden');
        countText.innerHTML = `<span data-t="compare.subtitle">${getTranslation('compare.subtitle', 'В сравнении')}</span>: ${selectedJobs.length}`;

        renderHeader(selectedJobs);
        renderBody(selectedJobs);
        updateCompareBadge(compareList);
    }

    document.addEventListener('DOMContentLoaded', initCompare);
    window.addEventListener('compareUpdate', initCompare);
</script>

<style>
    .compare-page {
        max-width: 1440px;
        margin: 0 auto;
        padding: 2rem 1rem 4rem;
    }
    .compare-hero {
        display: grid;
        gap: 0.8rem;
        max-width: 780px;
        margin: 0 auto 2rem;
        text-align: center;
    }
    .compare-eyebrow {
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--text-muted);
    }
    .compare-hero h1 {
        font-size: clamp(2.2rem, 4vw, 3.8rem);
        line-height: 0.98;
        letter-spacing: -0.05em;
    }
    .compare-hero p {
        color: var(--text-muted);
        font-size: 1.02rem;
        line-height: 1.75;
    }
    .compare-empty {
        max-width: 720px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
        border-radius: 32px;
        border: 1px solid rgba(148, 163, 184, 0.18);
        background: linear-gradient(180deg, rgba(255,255,255,0.92), rgba(248,250,252,0.98));
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
        text-align: center;
    }
    .compare-empty-mark {
        width: 72px;
        height: 72px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-weight: 600;
        background: #f7f2ea;
        border: 1px solid var(--border-color);
        margin-bottom: 1.25rem;
    }
    .compare-empty h2 {
        font-size: 2rem;
        line-height: 1.05;
        letter-spacing: -0.04em;
        margin-bottom: 0.85rem;
    }
    .compare-empty p {
        max-width: 56ch;
        margin: 0 auto;
        color: var(--text-muted);
        line-height: 1.8;
    }
    .compare-empty-link {
        max-width: 260px;
        margin: 1.75rem auto 0;
    }
    .compare-table-wrap {
        overflow-x: auto;
        padding-bottom: 0.5rem;
        -webkit-overflow-scrolling: touch;
    }
    .compare-table {
        width: 100%;
        min-width: 920px;
        border-collapse: separate;
        border-spacing: 0;
        border: 1px solid rgba(148, 163, 184, 0.35);
        border-radius: 16px;
        overflow: hidden;
        background: #fff;
    }
    .compare-table th,
    .compare-table td {
        vertical-align: top;
    }
    .compare-stub,
    .compare-label-cell {
        width: 170px;
        min-width: 170px;
        position: sticky;
        left: 0;
        z-index: 3;
        background: #fff;
    }
    .compare-stub {
        padding-right: 1rem;
    }
    .compare-stub-title {
        display: block;
        font-size: 1rem;
        line-height: 1.2;
        letter-spacing: -0.01em;
    }
    .compare-job-head,
    .compare-value-cell {
        min-width: 180px;
        padding-left: 0.65rem;
    }
    .compare-job-title-link {
        display: block;
        padding: 0.9rem;
        font-size: 1.02rem;
        font-weight: 700;
        line-height: 1.3;
        color: #1d4ed8;
        text-decoration: underline;
        overflow-wrap: anywhere;
    }
    .compare-job-title-link:hover {
        color: #1e40af;
    }
    .compare-label-cell,
    .compare-value-cell {
        padding: 0.8rem 0.9rem;
        border-top: 1px solid rgba(148, 163, 184, 0.3);
        border-left: 1px solid rgba(148, 163, 184, 0.3);
        box-shadow: none;
        background: #fff;
    }
    .compare-label-cell {
        font-size: 0.85rem;
        font-weight: 800;
        line-height: 1.35;
        color: var(--text-main);
        border-left: none;
        background: #f8fafc;
    }
    .compare-value-text {
        font-size: 0.91rem;
        line-height: 1.4;
        color: #334155;
        overflow-wrap: anywhere;
    }
    .compare-value-highlight .compare-value-text {
        font-size: 0.98rem;
        font-weight: 800;
        color: #0f172a;
    }
    #compare-body tr {
        background: transparent;
    }
    .hidden {
        display: none;
    }
    @media (max-width: 1100px) {
        .compare-page {
            padding-top: 1.25rem;
        }
        .compare-hero h1 {
            font-size: clamp(1.9rem, 5vw, 2.7rem);
        }
        .compare-table {
            min-width: 760px;
        }
        .compare-stub,
        .compare-label-cell {
            width: 150px;
            min-width: 150px;
        }
        .compare-job-head,
        .compare-value-cell {
            min-width: 150px;
            padding-left: 0.45rem;
        }
        .compare-job-title-link {
            font-size: 0.92rem;
            padding: 0.65rem;
        }
    }
    @media (max-width: 860px) {
        .compare-page {
            padding-top: 1.25rem;
        }
        .compare-table {
            min-width: 700px;
        }
        .compare-stub,
        .compare-label-cell {
            width: 130px;
            min-width: 130px;
        }
        .compare-job-head,
        .compare-value-cell {
            min-width: 140px;
        }
    }
</style>
