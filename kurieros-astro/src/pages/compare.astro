---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { CATEGORIES } from '../data/constants';
import jobsData from '../data/jobs';
import articlesData from '../data/articles.json';
import { getCitiesFromJobs } from '../utils/cities';
import { slugifyCompany } from '../utils/companies';
import { parseSalary } from '../utils/format';
import { buildBreadcrumbSchema } from '../utils/schema';

const transportLabelMap: Record<string, string> = {
  auto: 'Авто',
  bicycle: 'Велосипед / самокат',
  foot: 'Пешком',
};

const getTransportLabel = (tags: string[]) =>
  tags.find((tag) => tag in transportLabelMap)
    ? transportLabelMap[tags.find((tag) => tag in transportLabelMap) as string]
    : 'Смешанный формат';

const getTransportProvisionLabel = (provision: 'own' | 'company') =>
  provision === 'company'
    ? 'Компания выдает транспортное средство'
    : 'Нужно своё транспортное средство';

const normalizeOsRequirement = (value?: string) => {
  const normalized = String(value ?? '').trim().toLowerCase();
  const hasAndroid = /android|андроид/.test(normalized);
  const hasIos = /(?:^|[^a-z])ios(?:[^a-z]|$)|iphone|ipad|айос|айфон/.test(normalized);

  if (hasAndroid && hasIos) return 'Android или iOS';
  if (hasIos) return 'iOS';
  if (hasAndroid) return 'Android';
  return 'Android или iOS';
};

const mapCompareJob = (job: typeof jobsData[number]) => ({
  id: job.id,
  slug: job.slug,
  title: job.title,
  company: job.company,
  companySlug: slugifyCompany(job.company),
  companyHref: `/companies/${slugifyCompany(job.company)}/`,
  salary: job.salary,
  location: job.location,
  transport: getTransportLabel(job.tags),
  transport_provision: getTransportProvisionLabel(job.transportProvision),
  contract: job.details.employment_type,
  payout: job.details.payment_freq,
  bonus: job.benefits[0] || 'Условия уточняются при отклике',
  age: job.details.age,
  os: normalizeOsRequirement(job.details.os),
  link: `/v/${job.slug}/`,
});

const allCompareJobs = jobsData.map(mapCompareJob);
const compareJobs = allCompareJobs.slice(0, 4);

const compareCompanies = Array.from(
  new Map(compareJobs.map((job) => [job.company, { name: job.company, href: job.companyHref }])).values(),
);
const compareCities = getCitiesFromJobs(compareJobs)
  .sort((a, b) => b.vacancyCount - a.vacancyCount)
  .slice(0, 4)
  .map((city) => ({
    name: city.name,
    href: `/rabota-kurerom-${city.slug}/`,
  }));
const compareFormats = ['na-avto', 'peshkom', 'dlya-studentov', 'ezhednevnaya-oplata']
  .map((slug) => CATEGORIES.find((category) => category.slug === slug))
  .filter(Boolean)
  .map((category) => ({
    name: category!.name,
    href: `/rabota-kurerom-${category!.slug}/`,
  }));
const relatedArticles = articlesData
  .filter((article) => /срав|выбрать|курьер|доход|компан/i.test(`${article.title} ${article.description}`))
  .slice(0, 3)
  .map((article) => ({
    title: article.title,
    href: `/blog/${article.slug}/`,
  }));

const features = [
  { key: 'salary', name: 'Зарплата' },
  { key: 'location', name: 'Район работы' },
  { key: 'transport', name: 'Транспорт' },
  { key: 'transport_provision', name: 'Транспортное средство' },
  { key: 'age', name: 'Возраст' },
  { key: 'os', name: 'Операционная система' },
  { key: 'contract', name: 'Оформление' },
  { key: 'payout', name: 'Выплаты' },
  { key: 'bonus', name: 'Особенности' },
];

const compareTitle = 'Сравнение вакансий курьеров: что лучше выбрать | Курьерок';
const compareDescription = 'Сравнение вакансий курьеров по зарплате, выплатам, транспорту и оформлению. Смотрите, что лучше для дохода, старта и стабильности.';

const buildDecisionCards = (jobs: typeof allCompareJobs) => {
  if (jobs.length === 0) {
    return [
      {
        label: 'Список пуст',
        title: 'Вакансии пока не опубликованы',
        hint: 'Сравнение появится после добавления новых карточек.',
        text: 'Сейчас на сайте нет активных вакансий. Когда появятся новые карточки, здесь можно будет сравнить выплаты, транспорт и оформление.',
        href: '/',
      },
    ];
  }

  const topIncomeJob = [...jobs].sort((a, b) => parseSalary(b.salary) - parseSalary(a.salary))[0] ?? jobs[0];
  const studentFriendlyJob = jobs.find((job) => job.age.includes('16')) || jobs[0];
  const stableContractJob = jobs.find((job) => /тк|официаль/i.test(job.contract)) || jobs[0];

  return [
    {
      label: 'Лучше для дохода',
      title: topIncomeJob.title,
      hint: 'Сильнее по верхней вилке дохода.',
      text: `Если сейчас важнее потенциал заработка, начните с карточки ${topIncomeJob.company} и проверьте формулу выплат уже в вакансии.`,
      href: topIncomeJob.link,
    },
    {
      label: 'Лучше для старта',
      title: studentFriendlyJob.title,
      hint: 'Мягче для входа в профессию.',
      text: 'Этот вариант подходит для первого шага в доставке: меньше входных требований и проще понять, подойдёт ли работа.',
      href: studentFriendlyJob.link,
    },
    {
      label: 'Лучше для стабильности',
      title: stableContractJob.title,
      hint: 'Понятнее по оформлению и занятости.',
      text: 'Если вы выбираете по оформлению и предсказуемости занятости, стоит начать именно с этого варианта.',
      href: stableContractJob.link,
    },
  ];
};

const decisionCards = buildDecisionCards(compareJobs);
const answerFocusPoints = ['Выплаты', 'Транспорт', 'Оформление', 'Возрастной порог'];

const fitPoints = [
  'Сравнение полезно тем, кто уже выбрал 2-4 похожих вакансии и хочет быстро увидеть разницу по выплатам, транспорту и оформлению.',
  'Такой экран особенно помогает перед откликом, когда нужно отсечь неподходящие условия без лишних переходов между страницами.',
  'Если выбор уже сузился до одной компании, после сравнения лучше открыть её карточку и проверить ограничения детально.',
];

const cautionPoints = [
  'Верхняя зарплатная планка не равна гарантированному доходу: проверяйте формулу выплат и частоту начислений.',
  'Если для вас критичны ТК РФ, гражданство, медкнижка или точный район, эти пункты лучше сверять в карточке вакансии.',
  'Сравнение помогает принять решение быстрее, но финальные условия подтверждаются уже у работодателя или в анкете партнера.',
];

const faqItems = [
  {
    question: 'Как читать это сравнение вакансий?',
    answer: 'Сначала посмотрите на формат транспорта, выплаты и оформление, а затем откройте подходящие карточки вакансий, чтобы проверить ограничения и детали отклика.',
  },
  {
    question: 'Что сравнивать в первую очередь?',
    answer: 'Обычно первыми стоит сравнить выплаты, формат занятости, требования к транспорту и возрастной порог. Именно эти параметры быстрее всего отсеивают неподходящие варианты.',
  },
  {
    question: 'Можно ли выбирать только по зарплате?',
    answer: 'Нет. Верхняя планка дохода без графика, условий оформления и частоты выплат почти всегда даёт неполную картину, поэтому лучше смотреть на набор факторов сразу.',
  },
];

const pageSchemaGraph = [
  {
    '@type': 'CollectionPage',
    name: 'Сравнение вакансий курьеров',
    description: compareDescription,
    url: Astro.url.href,
    dateModified: new Date().toISOString(),
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: compareJobs.map((job, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: job.title,
        url: new URL(job.link, Astro.site).toString(),
      })),
    },
  },
  {
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  },
  buildBreadcrumbSchema(
    [
      { name: 'Главная', url: '/' },
      { name: 'Сравнение вакансий', url: '/compare/' },
    ],
    Astro.site,
  ),
];
---

<BaseLayout title={compareTitle} description={compareDescription} schemaGraph={pageSchemaGraph}>
  <Header />

  <main class="compare-page">
    <div class="compare-container">
      <div class="compare-header">
        <div class="compare-header-copy">
          <nav class="compare-breadcrumb" aria-label="Breadcrumb">
            <a href="/">Главная</a>
            <span>/</span>
            <span>Сравнение вакансий</span>
          </nav>
          <h1>Сравнение вакансий</h1>
          <p class="compare-subtitle">Сравните базовые условия, а потом открывайте только те карточки, которые действительно подходят.</p>
        </div>
        <div class="compare-header-actions">
          <a href="#compare-table" class="compare-table-link">К таблице</a>
          <a href="/" class="back-link">← К вакансиям</a>
        </div>
      </div>

      <section class="compare-answer-panel">
        <div>
          <p class="section-eyebrow">Короткий вывод</p>
          <h2>Сначала сравните ключевые условия</h2>
        </div>
        <div class="compare-answer-copy">
          <p>
            Сначала смотрите выплаты, транспорт и оформление. Если по этим трем пунктам вакансия подходит, уже потом
            открывайте полную карточку.
          </p>
          <div class="compare-chip-row compare-answer-chip-row">
            {answerFocusPoints.map((point) => (
              <span class="compare-chip-link compare-chip-static">{point}</span>
            ))}
          </div>
        </div>
      </section>

      <div class="compare-table-wrapper" id="compare-table">
        <div class="compare-grid" style={`--cols: ${compareJobs.length};`}>
          {compareJobs.length > 0 ? (
            <>
              <div class="compare-row compare-head">
                <div class="compare-cell feature-col empty-cell">
                  Параметры
                </div>
                {compareJobs.map((job, index) => (
                  <div class="compare-cell job-col" data-col={index}>
                    <div class="job-card-mini">
                      <button class="remove-col-btn" aria-label="Удалить" title="Удалить из сравнения" data-col-target={index} type="button">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                      </button>
                      <div class={`company-logo company-logo-${job.companySlug}`}>
                        <span class="company-logo-letter">
                          {job.company.charAt(0)}
                        </span>
                      </div>
                      <h3>{job.title}</h3>
                      <span class="company-name">{job.company}</span>
                    </div>
                  </div>
                ))}
              </div>

              {features.map((feature) => (
                <div class="compare-row">
                  <div class="compare-cell feature-col">
                    {feature.name}
                  </div>
                  {compareJobs.map((job, index) => (
                    <div class="compare-cell job-col" data-col={index}>
                      {job[feature.key as keyof typeof job]}
                    </div>
                  ))}
                </div>
              ))}

              <div class="compare-row compare-actions">
                <div class="compare-cell feature-col"></div>
                {compareJobs.map((job, index) => (
                  <div class="compare-cell job-col" data-col={index}>
                    <a href={job.link} class="btn-primary">Открыть карточку</a>
                  </div>
                ))}
              </div>
            </>
          ) : (
            <div class="compare-empty-state">
              <h3>Нет вакансий для сравнения</h3>
              <p>Список активных вакансий очищен. Новые варианты появятся здесь после публикации карточек.</p>
              <a href="/" class="btn-primary compare-empty-state-link">Вернуться на главную</a>
            </div>
          )}
        </div>
      </div>

      <section class="compare-route-grid" aria-label="Что открыть после сравнения">
        {decisionCards.map((card) => (
          <article class="compare-route-card">
            <span>{card.label}</span>
            <h2>{card.title}</h2>
            <p>{card.text}</p>
            <a href={card.href} class="compare-route-link">Открыть вариант</a>
          </article>
        ))}
      </section>

      <section class="compare-geo-grid">
        <article class="compare-geo-card">
          <p class="section-eyebrow">Кому подходит</p>
          <h2>Когда это сравнение реально полезно?</h2>
          <ul class="compare-list">
            {fitPoints.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
        </article>

        <article class="compare-geo-card compare-geo-card-caution">
          <p class="section-eyebrow">Что уточнить</p>
          <h2>Что проверить перед откликом?</h2>
          <ol class="compare-list numbered-list">
            {cautionPoints.map((point) => (
              <li>{point}</li>
            ))}
          </ol>
        </article>
      </section>

      <section class="compare-link-grid" aria-label="Куда перейти после сравнения">
        <article class="compare-link-card">
          <p class="section-eyebrow">По компаниям</p>
          <h2>Куда идти после короткого сравнения?</h2>
          <div class="compare-chip-row" data-compare-companies>
            {compareCompanies.map((company) => (
              <a href={company.href} class="compare-chip-link">{company.name}</a>
            ))}
          </div>
        </article>

        <article class="compare-link-card">
          <p class="section-eyebrow">По материалам</p>
          <h2>Что прочитать перед откликом?</h2>
          <div class="compare-article-stack">
            {relatedArticles.map((article) => (
              <a href={article.href} class="compare-article-link">{article.title}</a>
            ))}
          </div>
        </article>

        <article class="compare-link-card">
          <p class="section-eyebrow">По условиям</p>
          <h2>Куда идти, если формат уже понятен?</h2>
          <div class="compare-chip-row">
            {compareFormats.map((format) => (
              <a href={format.href} class="compare-chip-link">{format.name}</a>
            ))}
            {compareCities.map((city) => (
              <a href={city.href} class="compare-chip-link">{city.name}</a>
            ))}
          </div>
        </article>
      </section>

      <section class="compare-faq-section">
        <p class="section-eyebrow">FAQ</p>
        <h2>Короткие ответы перед выбором вакансии</h2>
        <div class="compare-faq-grid">
          {faqItems.map((item) => (
            <article class="compare-faq-item">
              <h3>{item.question}</h3>
              <p>{item.answer}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="compare-trust-panel">
        <div>
          <p class="section-eyebrow">Прозрачность</p>
          <h2>Как использовать это сравнение</h2>
        </div>
        <p>
          Эта страница помогает быстро понять различия между форматами работы, но не заменяет карточку вакансии. После выбора
          подходящего варианта откройте его страницу и подтвердите выплаты, оформление, возрастной порог и ограничения уже по
          актуальным условиям работодателя.
        </p>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script is:inline define:vars={{ allCompareJobs, features }}>
  document.addEventListener('DOMContentLoaded', () => {
    const grid = document.querySelector('.compare-grid');
    if (!grid) return;

    const decisionGrid = document.querySelector('.compare-route-grid');
    const companyLinks = document.querySelector('[data-compare-companies]');
    const jobsById = new Map(allCompareJobs.map((job) => [job.id, job]));
    const hasAvailableJobs = allCompareJobs.length > 0;
    const scopeAttribute = Array.from(grid.getAttributeNames()).find((name) => name.startsWith('data-astro-cid'));

    function applyScopedStyles(root) {
      if (!scopeAttribute) return;
      root.querySelectorAll('*').forEach((element) => {
        element.setAttribute(scopeAttribute, '');
      });
    }

    function escapeHtml(value) {
      return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function parseSalaryValue(salary) {
      return Number(String(salary).replace(/[^\d]/g, '')) || 0;
    }

    function readStoredCompareIds() {
      try {
        const rawList = JSON.parse(localStorage.getItem('compareList') || '[]');
        if (!Array.isArray(rawList)) return [];

        return rawList
          .map((id) => Number.parseInt(String(id), 10))
          .filter((id, index, ids) => Number.isFinite(id) && ids.indexOf(id) === index)
          .slice(0, 4);
      } catch {
        return [];
      }
    }

    function readCompareIds() {
      return readStoredCompareIds().filter((id) => jobsById.has(id));
    }

    function writeCompareIds(ids) {
      localStorage.setItem('compareList', JSON.stringify(ids));
      window.dispatchEvent(new CustomEvent('compareUpdate'));
    }

    function getSelectedJobs() {
      const storedIds = readStoredCompareIds();
      const validIds = storedIds.filter((id) => jobsById.has(id));

      if (JSON.stringify(storedIds) !== JSON.stringify(validIds)) {
        writeCompareIds(validIds);
      }

      return validIds.map((id) => jobsById.get(id)).filter(Boolean);
    }

    function renderEmptyState() {
      const emptyCopy = hasAvailableJobs
        ? {
          heading: 'Нет вакансий для сравнения',
          text: 'Добавьте 2-4 вакансии из списка, чтобы увидеть разницу по выплатам, транспорту и оформлению.',
          href: '/#vacancies',
          link: 'Вернуться к вакансиям',
        }
        : {
          heading: 'Нет вакансий для сравнения',
          text: 'Список активных вакансий очищен. Новые варианты появятся здесь после публикации карточек.',
          href: '/',
          link: 'Вернуться на главную',
        };

      grid.style.setProperty('--cols', '0');
      grid.innerHTML = `
        <div class="compare-empty-state">
          <h3>${emptyCopy.heading}</h3>
          <p>${emptyCopy.text}</p>
          <a href="${emptyCopy.href}" class="btn-primary compare-empty-state-link">${emptyCopy.link}</a>
        </div>
      `;
      applyScopedStyles(grid);

      if (decisionGrid) {
        const routeCopy = hasAvailableJobs
          ? {
            label: 'Дальше',
            title: 'Сначала добавьте вакансии',
            text: 'Нажмите «Сравнить» в карточках вакансий. Здесь появятся только выбранные варианты.',
            href: '/#vacancies',
            link: 'Открыть список',
          }
          : {
            label: 'Список пуст',
            title: 'Вакансии пока не опубликованы',
            text: 'Сейчас на сайте нет активных вакансий. Когда появятся новые карточки, здесь можно будет сравнить выплаты, транспорт и оформление.',
            href: '/',
            link: 'На главную',
          };

        decisionGrid.innerHTML = `
          <article class="compare-route-card compare-route-card-wide">
            <span>${routeCopy.label}</span>
            <h2>${routeCopy.title}</h2>
            <p>${routeCopy.text}</p>
            <a href="${routeCopy.href}" class="compare-route-link">${routeCopy.link}</a>
          </article>
        `;
        applyScopedStyles(decisionGrid);
      }

      if (companyLinks) {
        companyLinks.innerHTML = '<a href="/companies/" class="compare-chip-link">Все компании</a>';
        applyScopedStyles(companyLinks);
      }
    }

    function renderComparisonTable(jobs) {
      if (jobs.length === 0) {
        renderEmptyState();
        return;
      }

      grid.style.setProperty('--cols', jobs.length.toString());

      const headerCells = jobs.map((job, index) => `
        <div class="compare-cell job-col" data-col="${index}">
          <div class="job-card-mini">
            <button class="remove-col-btn" aria-label="Удалить" title="Удалить из сравнения" data-job-id="${job.id}" type="button">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
            <div class="company-logo company-logo-${escapeHtml(job.companySlug)}">
              <span class="company-logo-letter">${escapeHtml(job.company.charAt(0))}</span>
            </div>
            <h3>${escapeHtml(job.title)}</h3>
            <span class="company-name">${escapeHtml(job.company)}</span>
          </div>
        </div>
      `).join('');

      const featureRows = features.map((feature) => `
        <div class="compare-row">
          <div class="compare-cell feature-col">${escapeHtml(feature.name)}</div>
          ${jobs.map((job, index) => `
            <div class="compare-cell job-col" data-col="${index}">
              ${escapeHtml(job[feature.key])}
            </div>
          `).join('')}
        </div>
      `).join('');

      const actionCells = jobs.map((job, index) => `
        <div class="compare-cell job-col" data-col="${index}">
          <a href="${escapeHtml(job.link)}" class="btn-primary">Открыть карточку</a>
        </div>
      `).join('');

      grid.innerHTML = `
        <div class="compare-row compare-head">
          <div class="compare-cell feature-col empty-cell">Параметры</div>
          ${headerCells}
        </div>
        ${featureRows}
        <div class="compare-row compare-actions">
          <div class="compare-cell feature-col"></div>
          ${actionCells}
        </div>
      `;
      applyScopedStyles(grid);
    }

    function renderDecisionCards(jobs) {
      if (!decisionGrid || jobs.length === 0) return;

      const topIncomeJob = [...jobs].sort((a, b) => parseSalaryValue(b.salary) - parseSalaryValue(a.salary))[0];
      const studentFriendlyJob = jobs.find((job) => String(job.age).includes('16')) || jobs[0];
      const stableContractJob = jobs.find((job) => /тк|официаль/i.test(job.contract)) || jobs[0];
      const cards = [
        {
          label: 'Лучше для дохода',
          title: topIncomeJob.title,
          text: `Если сейчас важнее потенциал заработка, начните с карточки ${topIncomeJob.company} и проверьте формулу выплат уже в вакансии.`,
          href: topIncomeJob.link,
        },
        {
          label: 'Лучше для старта',
          title: studentFriendlyJob.title,
          text: 'Этот вариант подходит для первого шага в доставке: меньше входных требований и проще понять, подойдёт ли работа.',
          href: studentFriendlyJob.link,
        },
        {
          label: 'Лучше для стабильности',
          title: stableContractJob.title,
          text: 'Если вы выбираете по оформлению и предсказуемости занятости, стоит начать именно с этого варианта.',
          href: stableContractJob.link,
        },
      ];

      decisionGrid.innerHTML = cards.map((card) => `
        <article class="compare-route-card">
          <span>${escapeHtml(card.label)}</span>
          <h2>${escapeHtml(card.title)}</h2>
          <p>${escapeHtml(card.text)}</p>
          <a href="${escapeHtml(card.href)}" class="compare-route-link">Открыть вариант</a>
        </article>
      `).join('');
      applyScopedStyles(decisionGrid);
    }

    function renderCompanyLinks(jobs) {
      if (!companyLinks) return;

      const companies = Array.from(new Map(jobs.map((job) => [job.company, {
        name: job.company,
        href: job.companyHref,
      }])).values());

      companyLinks.innerHTML = companies.length
        ? companies.map((company) => `<a href="${escapeHtml(company.href)}" class="compare-chip-link">${escapeHtml(company.name)}</a>`).join('')
        : '<a href="/companies/" class="compare-chip-link">Все компании</a>';
      applyScopedStyles(companyLinks);
    }

    function renderSelectedComparison() {
      const jobs = getSelectedJobs();

      renderComparisonTable(jobs);
      renderDecisionCards(jobs);
      renderCompanyLinks(jobs);
    }

    renderSelectedComparison();

    grid.addEventListener('click', (e) => {
      const btn = e.target instanceof Element ? e.target.closest('.remove-col-btn') : null;
      if (!btn) return;

      const jobId = Number.parseInt(btn.getAttribute('data-job-id') || '', 10);
      if (!Number.isFinite(jobId)) return;

      writeCompareIds(readCompareIds().filter((id) => id !== jobId));
      renderSelectedComparison();
    });

    window.addEventListener('storage', (event) => {
      if (event.key === 'compareList') {
        renderSelectedComparison();
      }
    });
  });
</script>

