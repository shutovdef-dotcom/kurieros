---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import jobsData from '../data/jobs';
import { CATEGORIES } from '../data/constants';
import { getCitiesFromJobs } from '../utils/cities';
import { getCompaniesFromJobs } from '../utils/companies';
import { buildBreadcrumbSchema } from '../utils/schema';

const cities = getCitiesFromJobs(jobsData).map((city) => ({
	...city,
	href: `/rabota-kurerom-${city.slug}/`,
}));

const totalVacancies = cities.reduce((sum, city) => sum + city.vacancyCount, 0);
const topCities = [...cities].sort((a, b) => b.vacancyCount - a.vacancyCount).slice(0, 4);
const topCompanies = getCompaniesFromJobs(jobsData)
	.sort((a, b) => b.vacancyCount - a.vacancyCount || b.maxSalary - a.maxSalary)
	.slice(0, 5);
const featuredCategories = CATEGORIES.filter((category) =>
	['na-avto', 'peshkom', 'dlya-studentov', 'podrabotka', 'samokat', 'eda'].includes(category.slug),
).map((category) => ({
	name: category.name,
	href: `/rabota-kurerom-${category.slug}/`,
}));
const citySnapshots = topCities.map((city) => {
	const localJobs = jobsData.filter(
		(job) => job.location.toLowerCase().includes(city.name.toLowerCase()) || job.location === 'Вся Россия',
	);
	const localCompanies = Array.from(new Set(localJobs.map((job) => job.company)));
	const localFormats = Array.from(
		new Set(
			localJobs.flatMap((job) =>
				job.tags
					.filter((tag) => ['auto', 'foot', 'bicycle', 'flexible', '16plus'].includes(tag))
					.map((tag) => {
						if (tag === 'auto') return 'На авто';
						if (tag === 'foot') return 'Пешком';
						if (tag === 'bicycle') return 'Вело / самокат';
						if (tag === '16plus') return 'С 16 лет';
						return 'Подработка';
					}),
			),
		),
	);

	return {
		...city,
		companyCount: localCompanies.length,
		formats: localFormats.slice(0, 3),
	};
});

const getVacancyPlural = (count: number) => {
	const mod10 = count % 10;
	const mod100 = count % 100;
	if (mod10 === 1 && mod100 !== 11) return { text: 'вакансия', key: 'cities.vacancies_1' };
	if (mod10 >= 2 && mod10 <= 4 && (mod100 < 12 || mod100 > 14)) return { text: 'вакансии', key: 'cities.vacancies_2' };
	return { text: 'вакансий', key: 'cities.vacancies_5' };
};

const getCompanyPlural = (count: number) => {
	const mod10 = count % 10;
	const mod100 = count % 100;
	if (mod10 === 1 && mod100 !== 11) return 'компания';
	if (mod10 >= 2 && mod10 <= 4 && (mod100 < 12 || mod100 > 14)) return 'компании';
	return 'компаний';
};

const faqItems = [
	{
		question: 'Что есть на странице городов?',
		answer: `На странице собраны ${cities.length} городов, где уже есть ${totalVacancies} ${getVacancyPlural(totalVacancies).text} курьеров. Это стартовая навигационная точка для перехода в локальные подборки.`,
	},
	{
		question: 'Какой следующий шаг после выбора города?',
		answer: 'Откройте страницу нужного города, посмотрите активные вакансии, сравните компании и только потом переходите к карточкам конкретных работодателей.',
	},
	{
		question: 'Зачем выбирать город перед откликом?',
		answer: 'Условия курьерской работы зависят от города: отличаются компании, районы, транспорт и график. Поэтому лучше сначала открыть локальную подборку, а уже потом выбирать вакансию.',
	},
];
const pageSchemaGraph = [
	{
		'@type': 'CollectionPage',
		name: 'Города — работа курьером',
		description: 'Каталог городов с локальными подборками вакансий курьеров и быстрым переходом в нужный город.',
		url: Astro.url.href,
		dateModified: new Date().toISOString(),
		mainEntity: {
			'@type': 'ItemList',
			itemListElement: cities.map((city, index) => ({
				'@type': 'ListItem',
				position: index + 1,
				name: city.name,
				url: new URL(city.href, Astro.site).toString(),
			})),
		},
	},
	{
		'@type': 'FAQPage',
		mainEntity: faqItems.map((item) => ({
			'@type': 'Question',
			name: item.question,
			acceptedAnswer: {
				'@type': 'Answer',
				text: item.answer,
			},
		})),
	},
	buildBreadcrumbSchema(
		[
			{ name: 'Главная', url: '/' },
			{ name: 'Города', url: '/cities/' },
		],
		Astro.site,
	),
];
---

<BaseLayout
	title="Работа курьером по городам России: вакансии и компании | Курьерок"
	description="Выберите город и откройте локальную подборку вакансий курьеров: компании, форматы работы, выплаты и быстрые переходы по городам России."
	schemaGraph={pageSchemaGraph}
>
	<Header />

	<main class="cities-page">
		<section class="cities-hero">
			<p class="section-eyebrow">Города</p>
			<h1 data-t="cities.title">Работа курьером по городам России</h1>
			<p data-t="cities.subtitle">
				Выберите город, посмотрите активные бренды, затем откройте локальную подборку вакансий и подходящий формат работы.
			</p>
		</section>

		<section class="cities-answer-panel">
			<div>
				<p class="section-eyebrow">Короткий вывод</p>
				<h2>Зачем выбирать город отдельно?</h2>
			</div>
			<p>
				В разных городах отличаются компании, районы, транспорт и частота выплат. Сначала выберите город, затем
				сравните локальные вакансии и открывайте только те карточки, где условия похожи на ваши.
			</p>
		</section>

		<section class="cities-facts" aria-label="Ключевые факты по городам">
			<article class="fact-card">
				<span>Города</span>
				<strong>{cities.length}</strong>
			</article>
			<article class="fact-card">
				<span>Вакансии</span>
				<strong>{totalVacancies}</strong>
			</article>
			<article class="fact-card">
				<span>Топ города</span>
				<strong>{topCities.map((city) => city.name).join(', ')}</strong>
			</article>
			<article class="fact-card">
				<span>Следующий шаг</span>
				<strong>Открыть город и сравнить вакансии</strong>
			</article>
		</section>

		<section class="cities-link-strip" aria-label="Быстрые переходы">
			<a href="/compare/" class="quick-link">Сравнение вакансий</a>
			<a href="/companies/" class="quick-link">Каталог компаний</a>
			<a href="/blog/" class="quick-link">Блог о работе курьером</a>
		</section>

		<section class="cities-route-grid" aria-label="Переходы по сайту">
			<article class="route-card">
				<p class="section-eyebrow">Шаг 1</p>
				<h2>Выбрать сильный город</h2>
				<p>Если нужен быстрый старт, начинайте с городов, где уже видны несколько брендов и больше карточек вакансий.</p>
			</article>
			<article class="route-card">
				<p class="section-eyebrow">Шаг 2</p>
				<h2>Понять, кто активен</h2>
				<p>После выбора города переходите в локальную страницу и смотрите, какие компании, выплаты и форматы уже есть в подборке.</p>
			</article>
			<article class="route-card">
				<p class="section-eyebrow">Шаг 3</p>
				<h2>Сузить формат</h2>
				<p>Если важны авто, подработка или старт с 16 лет, дальше открывайте тематические страницы и сравнивайте уже внутри формата.</p>
			</article>
		</section>

		<section class="cities-spotlight" aria-label="Приоритетные города">
			<div class="cities-section-head">
				<p class="section-eyebrow">Локальный спрос</p>
				<h2>С каких городов логично начинать</h2>
			</div>
			<div class="cities-spotlight-grid">
				{citySnapshots.map((city) => (
					<a href={city.href} class="spotlight-card">
						<strong>{city.name}</strong>
						<span>
							{city.vacancyCount} {getVacancyPlural(city.vacancyCount).text} и {city.companyCount} {getCompanyPlural(city.companyCount)}
						</span>
						<small>Чаще видны: {city.formats.join(', ') || 'смешанные форматы'}</small>
					</a>
				))}
			</div>
		</section>

		<section class="cities-grid">
			{cities.map((city) => {
				const plural = getVacancyPlural(city.vacancyCount);
				return (
					<a class="city-tile" href={city.href}>
						<strong>{city.name}</strong>
						<span><span class="count-num">{city.vacancyCount}</span> <span data-t={plural.key}>{plural.text}</span></span>
					</a>
				);
			})}
		</section>

		<section class="cities-surfaces" aria-label="Разделы выбора">
			<article class="surface-card">
				<p class="section-eyebrow">Бренды</p>
				<h2>Какие компании чаще встречаются на сайте</h2>
				<div class="surface-chip-row">
					{topCompanies.map((company) => (
						<a href={company.href} class="quick-link">{company.name}</a>
					))}
				</div>
			</article>

			<article class="surface-card">
				<p class="section-eyebrow">Форматы</p>
				<h2>Какие форматы стоит открыть после города</h2>
				<div class="surface-chip-row">
					{featuredCategories.map((category) => (
						<a href={category.href} class="quick-link">{category.name}</a>
					))}
				</div>
			</article>
		</section>

		<section class="cities-faq-section">
			<p class="section-eyebrow">FAQ</p>
			<h2>Короткие ответы по городским страницам</h2>
			<div class="cities-faq-grid">
				{faqItems.map((item) => (
					<article class="faq-card">
						<h3>{item.question}</h3>
						<p>{item.answer}</p>
					</article>
				))}
			</div>
		</section>
	</main>

	<Footer />
</BaseLayout>

<style>
	.cities-page {
		max-width: 1240px;
		margin: 0 auto;
		padding: 2rem 1rem 4rem;
	}
	.cities-hero {
		margin-bottom: 1.5rem;
	}
	.section-eyebrow {
		margin: 0 0 0.55rem;
		font-size: 0.74rem;
		font-weight: 900;
		letter-spacing: 0;
		text-transform: uppercase;
		color: var(--accent-color);
	}
	.cities-hero h1 {
		font-size: 3rem;
		line-height: 1.05;
		letter-spacing: 0;
		margin-bottom: 0.45rem;
	}
	.cities-hero p,
	.cities-answer-panel p,
	.faq-card p,
	.city-tile span {
		color: var(--text-muted);
	}
	.cities-answer-panel,
	.fact-card,
	.city-tile,
	.faq-card {
		border: 1px solid rgba(148, 163, 184, 0.16);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.82);
		box-shadow: var(--shadow-sm);
	}
	.cities-answer-panel {
		display: grid;
		grid-template-columns: minmax(220px, 0.34fr) minmax(0, 1fr);
		gap: 1.5rem;
		align-items: start;
		margin-bottom: 1rem;
		padding: 1.5rem;
	}
	.cities-answer-panel h2,
	.cities-answer-panel p,
	.faq-card h3,
	.faq-card p {
		margin: 0;
	}
	.cities-answer-panel p,
	.faq-card p {
		line-height: 1.8;
	}
	.cities-facts,
	.cities-faq-grid,
	.cities-route-grid,
	.cities-surfaces {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1rem;
		margin-bottom: 1rem;
	}
	.cities-route-grid,
	.cities-surfaces {
		grid-template-columns: repeat(3, minmax(0, 1fr));
		margin-bottom: 1.5rem;
	}
	.fact-card {
		display: grid;
		gap: 0.35rem;
		min-height: 7rem;
		padding: 1rem;
	}
	.fact-card span {
		font-size: 0.72rem;
		font-weight: 900;
		letter-spacing: 0;
		text-transform: uppercase;
		color: var(--text-muted);
	}
	.fact-card strong {
		align-self: end;
		font-size: 0.98rem;
		line-height: 1.35;
	}
	.cities-link-strip {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-bottom: 1rem;
	}
	.quick-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.5rem;
		padding: 0.65rem 1rem;
		border-radius: 8px;
		border: 1px solid rgba(22, 115, 76, 0.16);
		background: rgba(22, 115, 76, 0.08);
		color: var(--text-main);
		text-decoration: none;
		font-weight: 800;
	}
	.cities-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
		gap: 0.8rem;
		margin-bottom: 1.5rem;
	}
	.route-card,
	.surface-card,
	.spotlight-card {
		display: grid;
		gap: 0.55rem;
		padding: 1.25rem;
		border: 1px solid rgba(148, 163, 184, 0.16);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.82);
		box-shadow: var(--shadow-sm);
	}
	.route-card h2,
	.surface-card h2,
	.cities-section-head h2 {
		margin: 0;
		font-size: 1.45rem;
	}
	.route-card p:last-child,
	.surface-card p:last-child,
	.spotlight-card span,
	.spotlight-card small {
		color: var(--text-muted);
		line-height: 1.7;
	}
	.cities-spotlight {
		margin-bottom: 1.5rem;
	}
	.cities-section-head {
		margin-bottom: 0.9rem;
	}
	.cities-spotlight-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1rem;
	}
	.spotlight-card {
		color: var(--text-main);
		text-decoration: none;
		transition: var(--transition);
	}
	.spotlight-card:hover {
		transform: translateY(-2px);
		border-color: var(--text-main);
		box-shadow: var(--shadow-md);
	}
	.spotlight-card strong {
		font-size: 1.05rem;
	}
	.surface-card {
		grid-column: span 1;
	}
	.surface-chip-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}
	.city-tile {
		display: grid;
		gap: 0.35rem;
		padding: 1rem;
		color: var(--text-main);
		text-decoration: none;
		transition: var(--transition);
	}
	.city-tile:hover {
		transform: translateY(-2px);
		border-color: var(--text-main);
		box-shadow: var(--shadow-md);
	}
	.city-tile strong {
		font-size: 1rem;
	}
	.cities-faq-section {
		margin-top: 1.5rem;
	}
	.faq-card {
		padding: 1.25rem;
	}
	.faq-card h3 {
		margin-bottom: 0.45rem;
		font-size: 1rem;
	}
	@media (max-width: 960px) {
		.cities-answer-panel,
		.cities-facts,
		.cities-faq-grid,
		.cities-route-grid,
		.cities-spotlight-grid,
		.cities-surfaces {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
	@media (max-width: 768px) {
		.cities-answer-panel {
			grid-template-columns: 1fr;
		}
	}
	@media (max-width: 560px) {
		.cities-hero h1 {
			font-size: 2.2rem;
		}
		.route-card h2,
		.surface-card h2,
		.cities-section-head h2 {
			font-size: 1.25rem;
		}
		.cities-facts,
		.cities-faq-grid,
		.cities-grid,
		.cities-route-grid,
		.cities-spotlight-grid,
		.cities-surfaces {
			grid-template-columns: 1fr;
		}
	}
</style>
