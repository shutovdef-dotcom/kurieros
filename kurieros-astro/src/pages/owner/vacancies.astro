---
import BaseLayout from '../../layouts/BaseLayout.astro';
import jobsData, { vacancySources } from '../../data/jobs';
import { SUPPORTED_LANGUAGES } from '../../data/translations';

const nextId = vacancySources.reduce((maxId, vacancy) => Math.max(maxId, vacancy.id), 0) + 1;
const supportedLanguages = SUPPORTED_LANGUAGES;
const adminHash = '2a4f4c5e061b8e807525ec8e325e1674c3aaccb740ba61cd92f3c91f7909391c';
const companyExamples = jobsData.slice(0, 8).map((job) => ({
	name: job.company,
	logo: job.companyLogo,
}));
---

<BaseLayout title="Owner Vacancy Admin — Курьерок" description="Закрытая страница владельца для подготовки новых вакансий.">
	<main class="owner-page">
		<section class="owner-shell">
			<div class="owner-hero">
				<p class="owner-eyebrow">Owner Access Only</p>
				<h1>Добавление вакансий</h1>
				<p>Страница не участвует в навигации и открывается только по прямой ссылке. После входа можно подготовить новую вакансию в формате проекта.</p>
			</div>

			<div id="owner-login" class="owner-card">
				<h2>Вход владельца</h2>
				<p class="muted">Введите приватный код доступа, чтобы открыть форму.</p>
				<form id="owner-login-form" class="owner-login-form">
					<label class="field">
						<span>Приватный код</span>
						<input id="owner-password" type="password" autocomplete="current-password" placeholder="Введите код доступа" required />
					</label>
					<button type="submit" class="btn-primary">Открыть форму</button>
				</form>
				<p id="owner-login-error" class="owner-error hidden">Неверный код доступа.</p>
			</div>

			<div id="owner-panel" class="owner-panel hidden">
				<div class="owner-toolbar owner-card">
					<div>
						<h2>Панель владельца</h2>
						<p class="muted">Следующий рекомендованный ID: <strong>{nextId}</strong></p>
					</div>
					<div class="toolbar-actions">
						<button id="owner-save-draft" type="button" class="btn-secondary">Сохранить черновик</button>
						<button id="owner-clear-draft" type="button" class="btn-secondary">Очистить</button>
						<button id="owner-logout" type="button" class="btn-secondary">Выйти</button>
					</div>
				</div>

				<div class="owner-grid">
					<section class="owner-card">
						<h3>Форма вакансии</h3>
						<form id="vacancy-form" class="owner-form">
							<div class="two-col">
								<label class="field">
									<span>ID</span>
									<input id="job-id" type="number" min="1" value={String(nextId)} required />
								</label>
								<label class="field">
									<span>Slug</span>
									<input id="job-slug" type="text" placeholder="Заполнится автоматически" required />
								</label>
							</div>

							<div class="two-col">
								<label class="field">
									<span>Название вакансии</span>
									<input id="job-title" type="text" placeholder="Работа курьером на авто в Яндекс Еда" required />
								</label>
								<label class="field">
									<span>Компания</span>
									<input id="job-company" list="company-examples" type="text" placeholder="Яндекс Еда" required />
								</label>
							</div>

							<datalist id="company-examples">
								{companyExamples.map((company) => (
									<option value={company.name}></option>
								))}
							</datalist>

							<div class="two-col">
								<label class="field">
									<span>Логотип компании</span>
									<input id="job-company-logo" type="url" placeholder="https://..." required />
								</label>
								<label class="field">
									<span>Ссылка отклика</span>
									<input id="job-apply-link" type="url" placeholder="https://..." />
								</label>
							</div>

							<div class="three-col">
								<label class="field">
									<span>Зарплата</span>
									<input id="job-salary" type="text" placeholder="до 180 000 ₽/мес" required />
								</label>
								<label class="field">
									<span>Города найма</span>
									<input id="job-location" type="text" placeholder="Москва, Санкт-Петербург" required />
								</label>
								<label class="field checkbox-field">
									<span>ТОП вакансия</span>
									<input id="job-is-hot" type="checkbox" />
								</label>
							</div>

							<div class="three-col">
								<label class="field">
									<span>Источник условий</span>
									<input id="job-source-url" type="url" placeholder="https://..." />
								</label>
								<label class="field">
									<span>Дата обновления</span>
									<input id="job-updated-at" type="date" />
								</label>
								<label class="field">
									<span>Точность зарплаты</span>
									<select id="job-salary-confidence">
										<option value="partner">partner</option>
										<option value="official">official</option>
										<option value="estimated">estimated</option>
									</select>
								</label>
							</div>

							<div class="two-col">
								<label class="field">
									<span>Районы города через запятую</span>
									<input id="job-city-districts" type="text" placeholder="ЦАО, ЮАО, рядом с метро" />
								</label>
								<label class="field">
									<span>Приоритет оффера</span>
									<input id="job-priority" type="number" min="0" step="1" placeholder="100" />
								</label>
							</div>

							<label class="field">
								<span>Короткое описание (для карточки)</span>
								<input id="job-short-description" type="text" placeholder="Одно предложение для превью в списке вакансий" required />
								<small>Показывается в карточке вакансии. Макс. 1–2 предложения.</small>
							</label>

							<label class="field">
								<span>Полное описание</span>
								<textarea id="job-description" rows="5" placeholder="Развернутое описание вакансии..." required></textarea>
							</label>

							<div class="two-col">
								<label class="field">
									<span>Транспорт через запятую</span>
									<input id="job-tags" type="text" placeholder="auto, foot, bicycle" required />
									<small>Можно писать кодами или словами: `auto`, `foot`, `bicycle`, авто, пеший, вело.</small>
								</label>
								<label class="field">
									<span>Бейджи через запятую</span>
									<input id="job-labels" type="text" placeholder="На авто, Без опыта, Свободный график" required />
								</label>
							</div>

							<label class="field">
								<span>Транспортное средство</span>
								<select id="job-transport-provision">
									<option value="own">Нужно своё транспортное средство (по умолчанию)</option>
									<option value="company">Компания выдает транспортное средство</option>
								</select>
								<small>Если оставить по умолчанию, поле в офферах не записывается и считается, что нужен свой транспорт.</small>
							</label>

							<div class="two-col">
								<label class="field">
									<span>Требования, по одному на строку</span>
									<textarea id="job-requirements" rows="6" placeholder="Наличие автомобиля&#10;Права категории B" required></textarea>
								</label>
								<label class="field">
									<span>Преимущества, по одному на строку</span>
									<textarea id="job-benefits" rows="6" placeholder="Высокий доход&#10;Гибкий график" required></textarea>
								</label>
							</div>

							<label class="field">
								<span>Требуемые документы, по одному на строку</span>
								<textarea id="job-required-documents" rows="5" placeholder="Паспорт&#10;СНИЛС&#10;ИНН&#10;Медицинская книжка, если требуется" required></textarea>
							</label>

							<div class="three-col">
								<label class="field">
									<span>Доп. требования оффера</span>
									<textarea id="job-requirements-override" rows="4" placeholder="Права категории B для авто&#10;Свой велосипед для вело"></textarea>
								</label>
								<label class="field">
									<span>Доп. бенефиты оффера</span>
									<textarea id="job-benefits-override" rows="4" placeholder="Повышенный коэффициент в часы спроса"></textarea>
								</label>
								<label class="field">
									<span>Доп. документы оффера</span>
									<textarea id="job-required-documents-override" rows="4" placeholder="Водительское удостоверение категории B&#10;СТС автомобиля"></textarea>
								</label>
							</div>

							<div class="details-grid">
								<label class="field">
									<span>Ставка</span>
									<input id="detail-rate" type="text" placeholder="Оплата за заказ + бонусы" required />
								</label>
								<label class="field">
									<span>График</span>
									<input id="detail-schedule" type="text" placeholder="Свободный график" required />
								</label>
								<label class="field">
									<span>Образование</span>
									<input id="detail-education" type="text" placeholder="Не требуется" required />
								</label>
								<label class="field">
									<span>Возраст</span>
									<input id="detail-age" type="text" placeholder="от 18 лет" required />
								</label>
								<label class="field">
									<span>Частота выплат</span>
									<input id="detail-payment-freq" type="text" placeholder="Еженедельно" required />
								</label>
								<label class="field">
									<span>Гражданство</span>
									<input id="detail-citizenship" type="text" placeholder="РФ, ЕАЭС" required />
								</label>
								<label class="field">
									<span>Медкнижка</span>
									<input id="detail-medical-book" type="text" placeholder="Требуется" required />
								</label>
								<label class="field">
									<span>Тип оформления</span>
									<input id="detail-employment-type" type="text" placeholder="self_employed, gph, ip, official" required />
								</label>
								<label class="field">
									<span>Форма</span>
									<input id="detail-uniform" type="text" placeholder="Выдается" required />
								</label>
								<label class="field">
									<span>ОС / устройство</span>
									<input id="detail-os" type="text" placeholder="Android или iOS" required />
								</label>
							</div>

							<label class="field">
								<span>Поисковые теги через запятую</span>
								<input id="job-search-tags" type="text" placeholder="#НаАвто, #БезОпыта, #ЯндексЕда" required />
							</label>

							<div class="toolbar-actions">
								<button id="owner-generate" type="submit" class="btn-primary">Сгенерировать объект</button>
								<button id="owner-copy" type="button" class="btn-secondary">Копировать объект</button>
								<button id="owner-download" type="button" class="btn-secondary">Скачать файл</button>
							</div>
						</form>
					</section>

					<aside class="owner-card">
						<h3>Готовый результат</h3>
						<p class="muted">Скопируй объект ниже и добавь его в массив `vacancySources` в [`src/data/vacancies.ts`](/Users/ivan/Documents/scratch/kurieros/kurieros-astro/src/data/vacancies.ts). Блок `content` создается для всех языков сайта; перед публикацией замени автозаполненные тексты на реальные переводы.</p>
						<textarea id="job-output" class="job-output" rows="28" readonly placeholder="После заполнения формы здесь появится объект базовой вакансии"></textarea>
						<p id="owner-copy-status" class="muted"></p>
						<div class="owner-note">
							<strong>Код доступа:</strong> хранится на этой странице в виде хэша. Для настоящей серверной защиты позже лучше вынести админку в backend или закрыть её через reverse proxy/auth.
						</div>
					</aside>
				</div>
			</div>
		</section>
	</main>
</BaseLayout>

<script is:inline define:vars={{ adminHash, nextId, companyExamples, supportedLanguages }}>
	const AUTH_KEY = 'kurieros-owner-auth';
	const DRAFT_KEY = 'kurieros-owner-vacancy-draft';

	const loginCard = document.getElementById('owner-login');
	const panel = document.getElementById('owner-panel');
	const loginForm = document.getElementById('owner-login-form');
	const loginError = document.getElementById('owner-login-error');
	const vacancyForm = document.getElementById('vacancy-form');
	const output = document.getElementById('job-output');
	const copyStatus = document.getElementById('owner-copy-status');

	function setOwnerMode(isOwner) {
		loginCard.classList.toggle('hidden', isOwner);
		panel.classList.toggle('hidden', !isOwner);
	}

	async function sha256(value) {
		const data = new TextEncoder().encode(value);
		const hashBuffer = await crypto.subtle.digest('SHA-256', data);
		return Array.from(new Uint8Array(hashBuffer))
			.map((byte) => byte.toString(16).padStart(2, '0'))
			.join('');
	}

	function slugify(value) {
		const map = {
			а: 'a', б: 'b', в: 'v', г: 'g', д: 'd', е: 'e', ё: 'e', ж: 'zh', з: 'z', и: 'i',
			й: 'y', к: 'k', л: 'l', м: 'm', н: 'n', о: 'o', п: 'p', р: 'r', с: 's', т: 't',
			у: 'u', ф: 'f', х: 'h', ц: 'ts', ч: 'ch', ш: 'sh', щ: 'sch', ъ: '', ы: 'y', ь: '',
			э: 'e', ю: 'yu', я: 'ya'
		};

		return value
			.trim()
			.toLowerCase()
			.split('')
			.map((char) => map[char] ?? char)
			.join('')
			.replace(/[^a-z0-9]+/g, '-')
			.replace(/^-+|-+$/g, '')
			.replace(/--+/g, '-');
	}

	function splitComma(value) {
		return value
			.split(',')
			.map((item) => item.trim())
			.filter(Boolean);
	}

	function splitLines(value) {
		return value
			.split('\n')
			.map((item) => item.trim())
			.filter(Boolean);
	}

	function readLocalizedList(value) {
		if (Array.isArray(value)) {
			return value;
		}

		if (value && typeof value === 'object') {
			return value.ru || Object.values(value).find((item) => Array.isArray(item)) || [];
		}

		return [];
	}

	function normalizeTransport(value) {
		const normalized = value.trim().toLowerCase();
		const map = {
			auto: 'auto',
			авто: 'auto',
			автомобиль: 'auto',
			foot: 'foot',
			пеший: 'foot',
			пешком: 'foot',
			bicycle: 'bicycle',
			вело: 'bicycle',
			велосипед: 'bicycle',
			самокат: 'bicycle'
		};

		return map[normalized] || normalized;
	}

	function normalizeMedicalBook(value) {
		const normalized = value.trim().toLowerCase();
		if (!normalized || normalized.includes('уточ')) return 'unknown';
		if (normalized.includes('компен')) return 'compensated';
		if (normalized.includes('не') || normalized === 'no' || normalized === 'false') return 'not_required';
		return 'required';
	}

	function normalizeEmploymentFormat(value) {
		const normalized = value.trim().toLowerCase();
		const map = {
			gph: 'gph',
			гпх: 'gph',
			self_employed: 'self_employed',
			самозанятость: 'self_employed',
			самозанятый: 'self_employed',
			ip: 'individual_entrepreneur',
			ип: 'individual_entrepreneur',
			individual_entrepreneur: 'individual_entrepreneur',
			official: 'official',
			официальное: 'official',
			'официальное трудоустройство': 'official',
			тк: 'official'
		};

		return map[normalized] || normalized;
	}

	function normalizeTransportProvision(value) {
		const normalized = value.trim().toLowerCase();
		return normalized === 'company' ? 'company' : 'own';
	}

	function readAgeFrom(value) {
		const match = value.match(/\d+/);
		return match ? Number(match[0]) : 18;
	}

	function readMoneyRange(value) {
		const numbers = String(value)
			.match(/\d[\d\s]*/g)
			?.map((item) => Number(item.replace(/\s/g, '')))
			.filter((item) => Number.isFinite(item) && item > 0) || [];
		const range = { text: value.trim() || 'Доход уточняется' };

		if (numbers.length >= 2) {
			range.min = Math.min(numbers[0], numbers[1]);
			range.max = Math.max(numbers[0], numbers[1]);
		} else if (numbers.length === 1) {
			range.max = numbers[0];
		}

		return range;
	}

	function todayDate() {
		return new Date().toISOString().slice(0, 10);
	}

	function setFieldValue(id, value) {
		const field = document.getElementById(id);
		if (!field) return;
		if (field.type === 'checkbox') {
			field.checked = Boolean(value);
			return;
		}
		field.value = value ?? '';
	}

	function readFormData() {
		const employmentFormats = splitComma(document.getElementById('detail-employment-type').value)
			.map(normalizeEmploymentFormat)
			.filter(Boolean);
		const cities = splitComma(document.getElementById('job-location').value);
		const transports = splitComma(document.getElementById('job-tags').value).map(normalizeTransport).filter(Boolean);
		const transportProvision = normalizeTransportProvision(document.getElementById('job-transport-provision').value);
		const monthlyPay = readMoneyRange(document.getElementById('job-salary').value);
		const cityDistricts = splitComma(document.getElementById('job-city-districts').value);
		const priorityRaw = Number(document.getElementById('job-priority').value);
		const requirementsOverride = splitLines(document.getElementById('job-requirements-override').value);
		const benefitsOverride = splitLines(document.getElementById('job-benefits-override').value);
		const requiredDocumentsOverride = splitLines(document.getElementById('job-required-documents-override').value);
		const sourceUrl = document.getElementById('job-source-url').value.trim();
		const updatedAt = document.getElementById('job-updated-at').value || todayDate();
		const applyLink = document.getElementById('job-apply-link').value.trim() || '#';
		const content = {
			title: document.getElementById('job-title').value.trim(),
			shortDescription: document.getElementById('job-short-description').value.trim(),
			description: document.getElementById('job-description').value.trim(),
			requirements: splitLines(document.getElementById('job-requirements').value),
			benefits: splitLines(document.getElementById('job-benefits').value),
			requiredDocuments: splitLines(document.getElementById('job-required-documents').value),
			labels: splitComma(document.getElementById('job-labels').value),
			searchTags: splitComma(document.getElementById('job-search-tags').value)
		};
		const formData = {
			id: Number(document.getElementById('job-id').value || nextId),
			slug: document.getElementById('job-slug').value.trim(),
			company: {
				name: document.getElementById('job-company').value.trim(),
				logo: document.getElementById('job-company-logo').value.trim()
			},
			content: Object.fromEntries(
				supportedLanguages.map((lang) => [
					lang,
					{
						...content,
						requirements: [...content.requirements],
						benefits: [...content.benefits],
						requiredDocuments: [...content.requiredDocuments],
						labels: [...content.labels],
						searchTags: [...content.searchTags]
					}
				])
			),
			defaults: {
				ageFrom: readAgeFrom(document.getElementById('detail-age').value),
				medicalBook: normalizeMedicalBook(document.getElementById('detail-medical-book').value),
				employmentFormats: employmentFormats.length ? employmentFormats : ['self_employed'],
				schedule: document.getElementById('detail-schedule').value.trim(),
				education: document.getElementById('detail-education').value.trim(),
				citizenship: document.getElementById('detail-citizenship').value.trim(),
				uniform: document.getElementById('detail-uniform').value.trim(),
				os: document.getElementById('detail-os').value.trim()
			},
			offers: cities.flatMap((city) =>
				transports.map((transport) => ({
					city,
					transport,
					pay: {
						currency: 'RUB',
						monthly: monthlyPay,
						rate: document.getElementById('detail-rate').value.trim(),
						paymentFrequency: document.getElementById('detail-payment-freq').value.trim()
					},
					isActive: true,
					updatedAt,
					...(sourceUrl ? { sourceUrl } : {}),
					salaryConfidence: document.getElementById('job-salary-confidence').value,
					ageFrom: readAgeFrom(document.getElementById('detail-age').value),
					medicalBook: normalizeMedicalBook(document.getElementById('detail-medical-book').value),
					employmentFormats: employmentFormats.length ? employmentFormats : ['self_employed'],
					schedule: document.getElementById('detail-schedule').value.trim(),
					applyLink,
					...(transportProvision === 'company' ? { transportProvision } : {}),
					...(cityDistricts.length ? { cityDistricts } : {}),
					...(Number.isFinite(priorityRaw) && priorityRaw > 0 ? { priority: priorityRaw } : {}),
					...(requirementsOverride.length ? { requirementsOverride } : {}),
					...(benefitsOverride.length ? { benefitsOverride } : {}),
					...(requiredDocumentsOverride.length ? { requiredDocumentsOverride } : {})
				}))
			)
		};

		if (document.getElementById('job-is-hot').checked) {
			formData.isHot = true;
		}

		return formData;
	}

	function saveDraft() {
		localStorage.setItem(DRAFT_KEY, JSON.stringify(readFormData()));
		copyStatus.textContent = 'Черновик сохранен в браузере.';
	}

	function loadDraft() {
		const raw = localStorage.getItem(DRAFT_KEY);
		if (!raw) {
			return;
		}

		try {
			const draft = JSON.parse(raw);
			const draftContent = draft.content?.ru || {};
			const firstOffer = draft.offers?.[0] || {};
			setFieldValue('job-id', draft.id ?? nextId);
			setFieldValue('job-slug', draft.slug);
			setFieldValue('job-title', draftContent.title ?? draft.title);
			setFieldValue('job-company', draft.company?.name ?? draft.company);
			setFieldValue('job-company-logo', draft.company?.logo ?? draft.companyLogo);
			setFieldValue('job-salary', firstOffer.pay?.monthly?.text ?? draft.pay?.salary ?? draft.salary);
			setFieldValue('job-location', Array.from(new Set((draft.offers || []).map((offer) => offer.city))).join(', ') || (draft.hiring?.cities || []).map((city) => city.name).join(', ') || draft.location);
			setFieldValue('job-tags', Array.from(new Set((draft.offers || []).map((offer) => offer.transport))).join(', ') || (draft.transport || draft.tags || []).join(', '));
			setFieldValue('job-labels', (draftContent.labels || draft.labels || []).join(', '));
			setFieldValue('job-transport-provision', firstOffer.transportProvision ?? 'own');
			setFieldValue('job-apply-link', firstOffer.applyLink === '#' ? '' : firstOffer.applyLink ?? (draft.applyLink === '#' ? '' : draft.applyLink));
			setFieldValue('job-source-url', firstOffer.sourceUrl);
			setFieldValue('job-updated-at', firstOffer.updatedAt);
			setFieldValue('job-salary-confidence', firstOffer.salaryConfidence || 'partner');
			setFieldValue('job-city-districts', (firstOffer.cityDistricts || []).join(', '));
			setFieldValue('job-priority', firstOffer.priority);
			setFieldValue('job-short-description', draftContent.shortDescription ?? draft.description?.short ?? draft.shortDescription);
			setFieldValue('job-description', draftContent.description ?? draft.description?.full ?? draft.description);
			setFieldValue('job-requirements', (draftContent.requirements || draft.description?.requirements || draft.requirements || []).join('\n'));
			setFieldValue('job-benefits', (draftContent.benefits || draft.description?.benefits || draft.benefits || []).join('\n'));
			setFieldValue('job-required-documents', readLocalizedList(draftContent.requiredDocuments || draft.requiredDocuments || draft.documents).join('\n'));
			setFieldValue('job-requirements-override', readLocalizedList(firstOffer.requirementsOverride).join('\n'));
			setFieldValue('job-benefits-override', readLocalizedList(firstOffer.benefitsOverride).join('\n'));
			setFieldValue('job-required-documents-override', readLocalizedList(firstOffer.requiredDocumentsOverride).join('\n'));
			setFieldValue('detail-rate', firstOffer.pay?.rate ?? draft.pay?.rate ?? draft.details?.rate);
			setFieldValue('detail-schedule', firstOffer.schedule ?? draft.defaults?.schedule ?? draft.work?.schedule ?? draft.details?.schedule);
			setFieldValue('detail-education', draft.defaults?.education ?? draft.work?.education ?? draft.details?.education);
			setFieldValue('detail-age', firstOffer.ageFrom ? `от ${firstOffer.ageFrom} лет` : draft.defaults?.ageFrom ? `от ${draft.defaults.ageFrom} лет` : draft.hiring?.defaultAgeFrom ? `от ${draft.hiring.defaultAgeFrom} лет` : draft.details?.age);
			setFieldValue('detail-payment-freq', firstOffer.pay?.paymentFrequency ?? draft.pay?.paymentFrequency ?? draft.details?.payment_freq);
			setFieldValue('detail-citizenship', draft.defaults?.citizenship ?? draft.work?.citizenship ?? draft.details?.citizenship);
			setFieldValue('detail-medical-book', firstOffer.medicalBook ?? draft.defaults?.medicalBook ?? draft.hiring?.medicalBook ?? draft.details?.medical_book);
			setFieldValue('detail-employment-type', (firstOffer.employmentFormats || draft.defaults?.employmentFormats || draft.hiring?.employmentFormats || []).join(', ') || draft.details?.employment_type);
			setFieldValue('detail-uniform', draft.defaults?.uniform ?? draft.work?.uniform ?? draft.details?.uniform);
			setFieldValue('detail-os', draft.defaults?.os ?? draft.work?.os ?? draft.details?.os);
			setFieldValue('job-search-tags', (draftContent.searchTags || draft.searchTags || draft.search_tags || []).join(', '));
			setFieldValue('job-is-hot', Boolean(draft.isHot));
		} catch (error) {
			console.error('Не удалось загрузить черновик', error);
		}
	}

	function generateJson() {
		const vacancy = readFormData();
		output.value = `${JSON.stringify(vacancy, null, 4)},`;
		return vacancy;
	}

	function autofillCompanyLogo(companyName) {
		const match = companyExamples.find((company) => company.name.toLowerCase() === companyName.toLowerCase());
		const logoField = document.getElementById('job-company-logo');
		if (match && logoField && !logoField.value.trim()) {
			logoField.value = match.logo;
		}
	}

	document.getElementById('job-title')?.addEventListener('input', () => {
		const title = document.getElementById('job-title').value;
		if (!document.getElementById('job-slug').dataset.manual) {
			document.getElementById('job-slug').value = slugify(title);
		}
	});

	document.getElementById('job-slug')?.addEventListener('input', () => {
		document.getElementById('job-slug').dataset.manual = 'true';
	});

	document.getElementById('job-company')?.addEventListener('change', (event) => {
		autofillCompanyLogo(event.target.value);
	});

	loginForm?.addEventListener('submit', async (event) => {
		event.preventDefault();
		const password = document.getElementById('owner-password').value;
		const hash = await sha256(password);
		const isValid = hash === adminHash;

		loginError.classList.toggle('hidden', isValid);
		if (!isValid) {
			return;
		}

		sessionStorage.setItem(AUTH_KEY, '1');
		setOwnerMode(true);
		loadDraft();
	});

	vacancyForm?.addEventListener('submit', (event) => {
		event.preventDefault();
		generateJson();
		copyStatus.textContent = 'Объект базовой вакансии сгенерирован.';
	});

	document.getElementById('owner-save-draft')?.addEventListener('click', () => {
		saveDraft();
	});

	document.getElementById('owner-clear-draft')?.addEventListener('click', () => {
		localStorage.removeItem(DRAFT_KEY);
		vacancyForm.reset();
		output.value = '';
		document.getElementById('job-id').value = nextId;
		document.getElementById('job-slug').dataset.manual = '';
		copyStatus.textContent = 'Черновик очищен.';
	});

	document.getElementById('owner-copy')?.addEventListener('click', async () => {
		if (!output.value.trim()) {
			generateJson();
		}

		try {
			await navigator.clipboard.writeText(output.value);
			copyStatus.textContent = 'Объект скопирован в буфер обмена.';
		} catch (error) {
			copyStatus.textContent = 'Не удалось скопировать автоматически. Можно скопировать вручную из окна справа.';
		}
	});

	document.getElementById('owner-download')?.addEventListener('click', () => {
		if (!output.value.trim()) {
			generateJson();
		}

		const blob = new Blob([output.value], { type: 'application/json' });
		const url = URL.createObjectURL(blob);
		const link = document.createElement('a');
		link.href = url;
		link.download = `${document.getElementById('job-slug').value || 'vacancy'}.json`;
		link.click();
		URL.revokeObjectURL(url);
		copyStatus.textContent = 'Файл с объектом скачан.';
	});

	document.getElementById('owner-logout')?.addEventListener('click', () => {
		sessionStorage.removeItem(AUTH_KEY);
		setOwnerMode(false);
		output.value = '';
		copyStatus.textContent = '';
	});

	if (sessionStorage.getItem(AUTH_KEY) === '1') {
		setOwnerMode(true);
		loadDraft();
	}
</script>

