---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import JobGrid from '../components/JobGrid.astro';
import IncomeCalculator from '../components/IncomeCalculator.astro';
import jobsData from '../data/jobs.json';
import { getCitiesFromJobs, getCityNames } from '../utils/cities';

const cities = getCitiesFromJobs(jobsData);
const availableCities = getCityNames(jobsData);
const cityRouteMap = Object.fromEntries(cities.map((city) => [city.name, `/rabota-kurerom-${city.slug}/`]));
---

<BaseLayout title="Курьерос — Работа курьером рядом" description="Выберите город, сравните условия и быстро найдите вакансию курьера с понятной оплатой и графиком.">
	<Header />

	<main>
		<div class="home-shell">
			<section class="hero hero-home">
				<div class="hero-toolbar hero-toolbar-only">
					<div class="city-selector-container">
						<label class="sr-only" for="city-select">Выберите город</label>
						<select id="city-select" class="city-select">
							<option value="" data-t="location.all_cities">Все города</option>
							{availableCities.map((city) => (
								<option value={city}>{city}</option>
							))}
						</select>
					</div>
				</div>
				<p id="location-status" class="hero-status" data-t="location.detecting">Определяем ваш город...</p>
				<a id="city-page-link" class="hero-city-link hidden" href="/" data-t="location.view_jobs">Все вакансии в этом городе</a>
			</section>

			<JobGrid />

			<IncomeCalculator />

			<section class="reviews-section home-section">
				<div class="section-heading">
					<h2 data-t="reviews.title">Отзывы курьеров</h2>
					<p data-t="reviews.subtitle">Коротко о том, как вакансии ощущаются в реальной работе.</p>
				</div>
				<div class="reviews-grid">
					<div class="review-card">
						<div class="review-header">
							<div class="review-avatar">М</div>
							<div>
								<strong>Максим, 21 год</strong>
								<div class="review-meta">Яндекс Еда • На авто</div>
							</div>
						</div>
						<p class="review-text">Удобное приложение, свободный график. Часто выхожу на смену после учебы. На авто получается от 4000 рублей за вечер. Выплаты без задержек.</p>
						<div class="review-rating">★★★★★</div>
					</div>
					<div class="review-card">
						<div class="review-header">
							<div class="review-avatar bg-ozon">А</div>
							<div>
								<strong>Александр, 35 лет</strong>
								<div class="review-meta">Ozon • На авто</div>
							</div>
						</div>
						<p class="review-text">Работы много, загружают по полной. Платят достойно. Главный плюс — стабильность. Машина должна быть вместительной, иначе сложно забирать все посылки.</p>
						<div class="review-rating">★★★★☆</div>
					</div>
					<div class="review-card">
						<div class="review-header">
							<div class="review-avatar bg-sdek">Е</div>
							<div>
								<strong>Екатерина, 25 лет</strong>
								<div class="review-meta">СДЭК • Пешком</div>
							</div>
						</div>
						<p class="review-text">Хорошая подработка в выходные. Выдают форму, заказы обычно в одном районе, не приходится бегать через весь город. Оплата раз в неделю.</p>
						<div class="review-rating">★★★★★</div>
					</div>
				</div>
			</section>

			<section class="faq-section home-section">
				<div class="section-heading">
					<h2 data-t="faq.title">Частые вопросы</h2>
					<p data-t="faq.subtitle">Главное перед тем, как откликаться на вакансию.</p>
				</div>
				<div class="faq-item">
					<div class="faq-question">
						<span data-t="faq.q1">Со скольки лет можно работать курьером?</span> <span>+</span>
					</div>
					<div class="faq-answer" data-t="faq.a1">
						В большинстве компаний можно устроиться пешим курьером или велокурьером уже <strong>с 16 лет</strong>. Для работы на автомобиле обычно нужен возраст 18+ и права категории B.
					</div>
				</div>
				<div class="faq-item">
					<div class="faq-question">
						<span data-t="faq.q2">Сколько реально зарабатывает курьер в 2026 году?</span> <span>+</span>
					</div>
					<div class="faq-answer" data-t="faq.a2">
						Доход зависит от города, транспорта, графика и компании. Пешие курьеры обычно зарабатывают меньше, вело и автоформаты заметно увеличивают итоговый доход.
					</div>
				</div>
				<div class="faq-item">
					<div class="faq-question">
						<span data-t="faq.q3">Нужна ли собственная термосумка?</span> <span>+</span>
					</div>
					<div class="faq-answer" data-t="faq.a3">
						Чаще всего нет: агрегаторы и сервисы доставки выдают экипировку и термосумку после подключения или короткого обучения.
					</div>
				</div>
			</section>
		</div>
	</main>

	<Footer />
</BaseLayout>

<script is:inline define:vars={{ availableCities, cityRouteMap }}>
	document.addEventListener('DOMContentLoaded', () => {
		const STORAGE_KEY = 'kurieros-selected-city';
		const citySelect = document.getElementById('city-select');
		const status = document.getElementById('location-status');
		const cityPageLink = document.getElementById('city-page-link');

		function updateCityLink(city) {
			const href = cityRouteMap[city];
			if (!city || !href) {
				cityPageLink.classList.add('hidden');
				cityPageLink.removeAttribute('href');
				return;
			}

			cityPageLink.href = href;
			cityPageLink.classList.remove('hidden');
		}

		function getTranslation(key, defaultText) {
			const lang = window.kurieros_i18n?.currentLang || 'ru';
			const dict = window.translations ? (window.translations[lang] || window.translations['ru']) : null;
			if (!dict) return defaultText;
			return key.split('.').reduce((prev, curr) => prev && prev[curr], dict) || defaultText;
		}

		function applyCity(city, source = 'manual') {
			const normalizedCity = availableCities.includes(city) ? city : '';
			citySelect.value = normalizedCity;
			updateCityLink(normalizedCity);

			if (normalizedCity) {
				localStorage.setItem(STORAGE_KEY, normalizedCity);
				status.innerHTML = `<span data-t="location.your_city">${getTranslation('location.your_city', 'Ваш город')}</span>: ${normalizedCity}.`;
			} else {
				localStorage.removeItem(STORAGE_KEY);
				status.innerHTML = `<span data-t="filters.all">${getTranslation('filters.all', 'Все вакансии')}</span>`;
			}

			window.dispatchEvent(new CustomEvent('kurieros:city-selected', {
				detail: { city: normalizedCity, source }
			}));
		}

		function normalizeDetectedCity(name) {
			if (!name) return '';
			const directMatch = availableCities.find((city) => city.toLowerCase() === name.toLowerCase());
			if (directMatch) return directMatch;
			const trimmed = name.replace(/^город\s+/i, '').trim();
			return availableCities.find((city) => city.toLowerCase() === trimmed.toLowerCase()) || '';
		}

		async function getIpData() {
			if (window.kurieros_user) {
				return window.kurieros_user;
			}

			return new Promise((resolve) => {
				const timeout = setTimeout(() => resolve(null), 4000);
				window.addEventListener('kurieros:region-detected', (event) => {
					clearTimeout(timeout);
					resolve(event.detail);
				}, { once: true });
			});
		}

		async function detectCityByIP() {
			status.innerHTML = `<span data-t="location.detecting">${getTranslation('location.detecting', 'Определяем ваш город...')}</span>`;

			const ipData = await getIpData();

			if (!ipData) {
				status.textContent = 'Не удалось определить город. Выберите вручную.';
				citySelect.focus();
				return;
			}

			// VPN detected — country is not Russia
			if (ipData.country && ipData.country !== 'RU') {
				status.textContent = 'Похоже, у вас включен VPN. Выберите город вручную.';
				citySelect.focus();
				window.dispatchEvent(new CustomEvent('kurieros:manual-city-required'));
				return;
			}

			const detectedCity = normalizeDetectedCity(ipData.city);
			if (detectedCity) {
				applyCity(detectedCity, 'ip');
				return;
			}

			status.textContent = 'Город не определён. Выберите вручную.';
			citySelect.focus();
		}

		const savedCity = localStorage.getItem(STORAGE_KEY);
		if (savedCity && availableCities.includes(savedCity)) {
			applyCity(savedCity, 'saved');
		} else {
			detectCityByIP();
		}

		citySelect?.addEventListener('change', (event) => {
			applyCity(event.target.value, 'manual');
		});

		document.querySelectorAll('.faq-item').forEach((item) => {
			item.querySelector('.faq-question')?.addEventListener('click', () => {
				item.classList.toggle('active');
			});
		});
	});
</script>

<style>
	main {
		max-width: 1680px;
	}
	.home-shell {
		max-width: 1560px;
		margin: 0 auto;
		padding: 1.25rem 1rem 4rem;
	}
	.hero-home {
		display: grid;
		gap: 0.6rem;
		margin-bottom: 1rem;
	}
	.home-section {
		background: #fffdf8;
		border: 1px solid #ebe5dc;
		border-radius: 1.6rem;
		box-shadow: 0 8px 24px rgba(60, 41, 20, 0.05);
	}
	.hero-toolbar {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		align-items: center;
		margin-top: 0;
	}
	.hero-toolbar-only {
		padding: 0;
	}
	.city-selector-container {
		display: flex;
		align-items: center;
		background: #f7f2ea;
		border: 1px solid #ebe5dc;
		border-radius: 999px;
		padding: 0 0.9rem;
		min-height: 48px;
		min-width: 220px;
		position: relative;
	}
	.city-selector-container::after {
		content: '▼';
		position: absolute;
		right: 1rem;
		font-size: 0.55rem;
		color: #8b7d70;
		pointer-events: none;
	}
	.city-select {
		width: 100%;
		border: none;
		background: transparent;
		appearance: none;
		font: inherit;
		font-size: 0.94rem;
		font-weight: 700;
		color: #2b2622;
		padding-right: 1.25rem;
		outline: none;
	}
	.hero-status {
		margin-top: 0.4rem;
		font-size: 0.9rem;
		color: #8b7d70;
	}
	.hero-city-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		margin-top: 0.8rem;
		padding: 0.75rem 1.25rem;
		border-radius: 999px;
		border: 1px solid var(--text-main);
		background: var(--text-main);
		color: #fff;
		text-decoration: none;
		font-weight: 700;
		font-size: 0.95rem;
		line-height: 1.1;
		transition: var(--transition);
	}
	.hero-city-link:hover {
		transform: translateY(-1px);
		box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
	}
	.home-section {
		padding: 1.6rem;
		margin-top: 1.25rem;
	}
	.section-heading {
		margin-bottom: 1.1rem;
	}
	.section-heading h2 {
		margin-bottom: 0.35rem;
		letter-spacing: -0.03em;
	}
	.section-heading p {
		color: #7c6f64;
	}
	:global(.reviews-section),
	:global(.faq-section) {
		padding-top: 0;
		padding-bottom: 0;
	}
	:global(.reviews-section h2),
	:global(.faq-section h2) {
		text-align: left;
	}
	:global(.review-card),
	:global(.faq-item) {
		background: #f7f2ea;
		border: 1px solid #ebe5dc;
		box-shadow: none;
	}
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
	.hidden {
		display: none;
	}
	@media (max-width: 768px) {
		.home-shell {
			padding-top: 0.75rem;
		}
		.home-section {
			padding: 1.2rem;
			border-radius: 1.25rem;
		}
		.hero-toolbar {
			flex-direction: column;
			align-items: stretch;
		}
		.city-selector-container {
			min-width: 0;
		}
	}
</style>
