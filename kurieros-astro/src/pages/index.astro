---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import JobGrid from '../components/JobGrid.astro';
import IncomeCalculator from '../components/IncomeCalculator.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import ReviewsBlock from '../components/ReviewsBlock.astro';
import jobsData from '../data/jobs';
import { getCompaniesFromJobs } from '../utils/companies';
import { getCitiesFromJobs, getCityNames, sortCityNamesByPopulation } from '../utils/cities';

const cities = getCitiesFromJobs(jobsData);
const availableCities = sortCityNamesByPopulation(getCityNames(jobsData));
const cityRouteMap = Object.fromEntries(cities.map((city) => [city.name, `/rabota-kurerom-${city.slug}/`]));
const companies = getCompaniesFromJobs(jobsData);
const totalVacancies = jobsData.length;
const topCities = [...cities]
	.sort((a, b) => b.vacancyCount - a.vacancyCount)
	.slice(0, 6)
	.map((city) => ({
		name: city.name,
		vacancyCount: city.vacancyCount,
		href: `/rabota-kurerom-${city.slug}/`,
	}));
const featuredCompanies = [...companies]
	.sort((a, b) => b.vacancyCount - a.vacancyCount)
	.slice(0, 6)
	.map((company) => ({
		name: company.name,
		href: company.href,
	}));
const featuredFormats = [
	{ name: 'Авто', href: '/rabota-kurerom-na-avto/' },
	{ name: 'Вело', href: '/rabota-kurerom-na-velosipede/' },
	{ name: 'Пешком', href: '/rabota-kurerom-peshkom/' },
	{ name: 'Подработка', href: '/rabota-kurerom-podrabotka/' },
];
const routeCards = [
	{
		title: 'Подработка после дел',
		text: 'Вечерние смены, выходные и варианты без полного графика.',
		href: '/rabota-kurerom-podrabotka/',
	},
	{
		title: 'Можно с 16 лет',
		text: 'Пешие и вело-варианты, где не нужен автомобиль.',
		href: '/rabota-kurerom-16-let/',
	},
	{
		title: 'Есть автомобиль',
		text: 'Посмотреть, где машина правда помогает заработать больше.',
		href: '/rabota-kurerom-na-avto/',
	},
	{
		title: 'Хочу выбрать компанию',
		text: 'Сравнить сервисы по выплатам, требованиям и городам.',
		href: '/companies/',
	},
];
const heroFacts = [
	{ label: 'Вакансии', value: `${totalVacancies}` },
	{ label: 'Компании', value: `${companies.length}` },
	{ label: 'Города', value: `${cities.length}` },
	{ label: 'Форматы', value: 'Авто, вело, пешком, подработка' },
];
const faqItems = [
	{
		question: 'Со скольки лет можно работать курьером?',
		answer:
			'В большинстве компаний можно устроиться пешим курьером или велокурьером уже с 16 лет. Для работы на автомобиле обычно нужен возраст 18+ и права категории B.',
	},
	{
		question: 'Сколько реально зарабатывает курьер в 2026 году?',
		answer:
			'Доход зависит от города, транспорта, графика и компании. Пешие курьеры обычно зарабатывают меньше, а вело- и автоформаты дают более высокий потенциал дохода.',
	},
	{
		question: 'Нужна ли собственная термосумка?',
		answer:
			'Чаще всего нет: агрегаторы и сервисы доставки выдают экипировку и термосумку после подключения или короткого обучения.',
	},
];
const hubLinks = [
	{
		href: '/compare/',
		title: 'Сравнение вакансий',
		text: 'Поставить рядом зарплату, выплаты, транспорт и оформление.',
	},
	{
		href: '/companies/',
		title: 'Компании',
		text: 'Посмотреть, чем отличаются сервисы доставки и банки.',
	},
	{
		href: '/cities/',
		title: 'Города',
		text: 'Найти вакансии в своём городе без лишнего списка.',
	},
	{
		href: '/blog/',
		title: 'Блог',
		text: 'Разобраться в доходе, расходах и частых ошибках новичков.',
	},
];
const discoveryCards = [
	...routeCards.map((card) => ({
		...card,
		kicker: 'Частый запрос',
		variant: 'route',
	})),
	...hubLinks.map((card) => ({
		...card,
		kicker: 'Раздел сайта',
		variant: 'hub',
	})),
];
const homepageTitle = 'Работа курьером: вакансии, компании и сравнение | Курьерок';
const homepageDescription = `Работа курьером в России: ${totalVacancies} вакансий, ${companies.length} компаний, города, сравнение условий и понятные разборы перед откликом.`.slice(0, 170);
const pageSchemaGraph = [
	{
		'@type': 'CollectionPage',
		name: homepageTitle,
		description: homepageDescription,
		url: Astro.url.href,
		dateModified: new Date().toISOString(),
		mainEntity: {
			'@type': 'ItemList',
			itemListElement: hubLinks.map((link, index) => ({
				'@type': 'ListItem',
				position: index + 1,
				name: link.title,
				url: new URL(link.href, Astro.site).toString(),
			})),
		},
	},
	{
		'@type': 'Organization',
		name: 'Курьерок',
		url: Astro.site,
		description: 'Каталог вакансий курьеров, компаний, городов и практических разборов для спокойного выбора работы.',
	},
	{
		'@type': 'FAQPage',
		mainEntity: faqItems.map((item) => ({
			'@type': 'Question',
			name: item.question,
			acceptedAnswer: {
				'@type': 'Answer',
				text: item.answer,
			},
		})),
	},
];
---

<BaseLayout title={homepageTitle} description={homepageDescription} schemaGraph={pageSchemaGraph}>
	<Header />

	<main>
		<div class="home-shell">
			<section class="hero hero-home">
				<div class="home-hero-panel">
					<div class="home-hero-copy">
						<h1>Четкие условия - честные зарплаты</h1>

						<div class="home-hero-facts">
							{heroFacts.map((fact) => (
								<article class="home-hero-fact">
									<span>{fact.label}</span>
									<strong>{fact.value}</strong>
								</article>
							))}
						</div>
					</div>
				</div>

				<div class="hero-toolbar hero-toolbar-only">
					<div class="toolbar-top">
						<div class="city-selector-container" data-region-autoprompt="manual-only">
							<svg class="city-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
							<label class="sr-only" for="city-select">Выберите город</label>
							<select id="city-select" class="city-select">
								<option value="" data-t="location.all_cities">Все города</option>
								{availableCities.map((city) => (
									<option value={city}>{city}</option>
								))}
							</select>
						</div>
						<div class="hero-lang-switcher">
							<LanguageSwitcher />
						</div>
					</div>
					<a id="city-page-link" class="hero-city-link hidden" href="/" data-t="location.view_jobs">Все вакансии в этом городе</a>
				</div>
			</section>

			<section class="home-section home-vacancy-launch">
				<div class="home-filter-row">
					<select id="vacancy-age-filter" class="home-filter-select" aria-label="Фильтр по возрасту">
						<option value="all">Возраст: любой</option>
						<option value="16plus">Возраст: с 16 лет</option>
						<option value="18plus">Возраст: с 18 лет</option>
					</select>
					<select id="vacancy-transport-filter" class="home-filter-select" aria-label="Фильтр по транспорту">
						<option value="all">Транспорт: любой</option>
						<option value="foot">Транспорт: пешком</option>
						<option value="bicycle">Транспорт: велосипед / самокат</option>
						<option value="auto">Транспорт: авто</option>
					</select>
				</div>
			</section>

			<JobGrid />

			<section class="home-section home-discovery-section">
				<div class="section-heading">
					<h2>Когда список слишком широкий</h2>
					<p>Отфильтруйте поиск по ситуации: подработка, возраст, свой автомобиль, конкретная компания или город.</p>
				</div>
				<div class="home-navigation-grid">
					{discoveryCards.map((card) => (
						<a href={card.href} class={`home-navigation-card ${card.variant === 'route' ? 'home-navigation-card-route' : ''}`}>
							<span>{card.kicker}</span>
							<h3>{card.title}</h3>
							<p>{card.text}</p>
						</a>
					))}
				</div>
				<div class="home-surface-grid">
					<article class="home-surface-card">
						<h3>Популярные города</h3>
						<div class="home-chip-row">
							{topCities.map((city) => (
								<a href={city.href} class="home-chip-link">{city.name} · {city.vacancyCount}</a>
							))}
						</div>
					</article>

					<article class="home-surface-card">
						<h3>Популярные форматы</h3>
						<div class="home-chip-row">
							{featuredFormats.map((format) => (
								<a href={format.href} class="home-chip-link">{format.name}</a>
							))}
						</div>
					</article>

					<article class="home-surface-card">
						<h3>Компании в подборке</h3>
						<div class="home-chip-row">
							{featuredCompanies.map((company) => (
								<a href={company.href} class="home-chip-link">{company.name}</a>
							))}
						</div>
					</article>
				</div>
			</section>

			<IncomeCalculator />

			<ReviewsBlock />

			<section class="faq-section home-section">
				<div class="section-heading">
					<h2 data-t="faq.title">Частые вопросы</h2>
					<p data-t="faq.subtitle">Коротко о том, что обычно важно перед первым откликом.</p>
				</div>
				<div class="faq-item">
					<div class="faq-question">
						<span data-t="faq.q1">{faqItems[0].question}</span> <span>+</span>
					</div>
					<div class="faq-answer" data-t="faq.a1">{faqItems[0].answer}</div>
				</div>
				<div class="faq-item">
					<div class="faq-question">
						<span data-t="faq.q2">{faqItems[1].question}</span> <span>+</span>
					</div>
					<div class="faq-answer" data-t="faq.a2">{faqItems[1].answer}</div>
				</div>
				<div class="faq-item">
					<div class="faq-question">
						<span data-t="faq.q3">{faqItems[2].question}</span> <span>+</span>
					</div>
					<div class="faq-answer" data-t="faq.a3">{faqItems[2].answer}</div>
				</div>
			</section>
		</div>
	</main>

	<Footer />
</BaseLayout>

<script is:inline define:vars={{ availableCities, cityRouteMap }}>
	document.addEventListener('DOMContentLoaded', () => {
		const STORAGE_KEY = 'kurieros-selected-city';
		const DEFAULT_CITY = 'Москва';
		const citySelect = document.getElementById('city-select');
		const cityPageLink = document.getElementById('city-page-link');

		function getFallbackCity() {
			if (availableCities.includes(DEFAULT_CITY)) {
				return DEFAULT_CITY;
			}
			return availableCities[0] || '';
		}

		function updateCityLink(city) {
			const href = cityRouteMap[city];
			if (!city || !href) {
				cityPageLink.classList.add('hidden');
				cityPageLink.removeAttribute('href');
				return;
			}

			cityPageLink.href = href;
			cityPageLink.classList.remove('hidden');
		}

		function applyCity(city, source = 'manual') {
			const normalizedCity = availableCities.includes(city) ? city : '';
			citySelect.value = normalizedCity;
			updateCityLink(normalizedCity);

			if (normalizedCity) {
				localStorage.setItem(STORAGE_KEY, normalizedCity);
			} else {
				localStorage.removeItem(STORAGE_KEY);
			}

			window.dispatchEvent(new CustomEvent('kurieros:city-selected', {
				detail: { city: normalizedCity, source }
			}));
		}

		function normalizeDetectedCity(name) {
			if (!name) return '';
			const directMatch = availableCities.find((city) => city.toLowerCase() === name.toLowerCase());
			if (directMatch) return directMatch;
			const trimmed = name.replace(/^город\s+/i, '').trim();
			const normalizedTrimmed = trimmed.toLowerCase();

			if (['moscow', 'moskva'].includes(normalizedTrimmed) && availableCities.includes(DEFAULT_CITY)) {
				return DEFAULT_CITY;
			}

			return availableCities.find((city) => city.toLowerCase() === normalizedTrimmed) || '';
		}

		async function getIpData() {
			if (['localhost', '127.0.0.1'].includes(window.location.hostname)) {
				return null;
			}

			if (window.kurieros_user) {
				return window.kurieros_user;
			}

			return new Promise((resolve) => {
				const timeout = setTimeout(() => resolve(null), 4000);
				window.addEventListener('kurieros:region-detected', (event) => {
					clearTimeout(timeout);
					resolve(event.detail);
				}, { once: true });
			});
		}

		async function detectCityByGeo() {
			const ipData = await getIpData();

			const detectedCity = normalizeDetectedCity(ipData?.city);
			if (detectedCity) {
				applyCity(detectedCity, 'ip');
				return;
			}

			const fallbackCity = getFallbackCity();
			if (fallbackCity) {
				applyCity(fallbackCity, 'default');
			}
		}

		detectCityByGeo();

		citySelect?.addEventListener('change', (event) => {
			applyCity(event.target.value, 'manual');
		});

		document.querySelectorAll('.faq-item').forEach((item) => {
			item.querySelector('.faq-question')?.addEventListener('click', () => {
				item.classList.toggle('active');
			});
		});
	});
</script>

<style>
	/* --- Layout --- */
	main {
		max-width: 1680px;
		padding-top: 0;
	}
	.home-shell {
		max-width: 1560px;
		margin: 0 auto;
		padding: 4mm 1.5rem 3rem;
	}
	.hero.hero-home {
		display: grid;
		gap: 1.15rem;
		padding: 0;
		margin-bottom: 1.15rem;
	}
	.home-hero-panel {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 0.55rem;
		padding: 0.8rem;
		max-width: 1000px;
		margin: 0 auto;
		border: 1px solid #d9e2d6;
		border-radius: 8px;
		background: linear-gradient(135deg, rgba(245, 249, 242, 0.96) 0%, rgba(255, 255, 255, 0.98) 54%, rgba(242, 250, 253, 0.96) 100%);
		box-shadow: 0 18px 44px rgba(24, 45, 34, 0.08);
	}
	.home-hero-copy {
		display: grid;
		gap: 0.55rem;
		align-content: center;
		max-width: none;
		padding: 0.5rem 0.65rem;
	}
	.home-hero-copy h1 {
		margin: 0;
		font-size: 4rem;
		line-height: 0.96;
		letter-spacing: 0;
		max-width: 16ch;
		text-wrap: balance;
	}
	.home-hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
	}
	.home-hero-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 3rem;
		padding: 0.8rem 1.2rem;
		border-radius: 8px;
		background: #163d2b;
		border: 1px solid #163d2b;
		color: white;
		text-decoration: none;
		font-weight: 800;
		transition: var(--transition);
	}
	.home-hero-link:hover {
		transform: translateY(-1px);
		box-shadow: 0 10px 24px rgba(22, 61, 43, 0.12);
	}
	.home-hero-facts {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.55rem;
	}
	.home-hero-fact {
		display: grid;
		gap: 0.2rem;
		min-height: auto;
		padding: 0.65rem 0.75rem;
		border-radius: 8px;
		border: 1px solid #d9e2d6;
		background: rgba(255, 255, 255, 0.9);
		box-shadow: 0 6px 18px rgba(24, 45, 34, 0.04);
	}
	.home-hero-fact span {
		font-size: 0.72rem;
		font-weight: 900;
		letter-spacing: 0;
		text-transform: uppercase;
		color: #61746b;
	}
	.home-hero-fact strong {
		align-self: start;
		font-size: 1.02rem;
		line-height: 1.3;
		color: #1d2b24;
	}
	.home-section {
		padding: 2.25rem;
		margin: 1.5rem auto;
		max-width: 1560px;
		width: 100%;
		background: #ffffff;
		border: 1px solid #dfe7dd;
		border-radius: 8px;
		box-shadow: 0 8px 24px rgba(24, 45, 34, 0.04);
	}
	.home-vacancy-launch {
		margin: 0 auto 0.65rem;
		padding: 0.75rem 1rem;
	}
	.home-filter-row {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.55rem;
		align-items: center;
	}
	.home-filter-select {
		width: 100%;
		min-height: 2.7rem;
		padding: 0.5rem 0.8rem;
		border-radius: 8px;
		border: 1px solid #cad8ca;
		background: #f9fcf8;
		color: #1d2b24;
		font: inherit;
		font-weight: 600;
	}
	.home-filter-select:focus-visible {
		outline: 2px solid #4b8269;
		outline-offset: 1px;
		border-color: #4b8269;
		background: #fff;
	}
	.home-discovery-section {
		display: grid;
		gap: 1.5rem;
	}

	/* --- Hero Toolbar --- */
	.hero-toolbar {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		margin-top: 0;
		margin-bottom: 0;
		width: 100%;
		max-width: 1000px;
		margin-left: auto;
		margin-right: auto;
	}
	.hero-toolbar-only {
		padding: 0;
	}
	.toolbar-top {
		display: flex;
		gap: 0.75rem;
		width: 100%;
		max-width: 640px;
		margin: 0 auto;
		justify-content: center;
	}
	.city-selector-container {
		display: flex;
		align-items: center;
		padding: 0 1.25rem;
		/* Removing padding-right: 2.75rem; as we'll use absolute pos for arrow */
		background: #f5faf6;
		border: 1px solid #d9e2d6;
		font-size: 1.4rem;
		box-shadow: 0 6px 16px rgba(24, 45, 34, 0.08);
		flex: 1;
		height: 4.2rem;
		box-sizing: border-box;
		border-radius: 8px;
		cursor: pointer;
		position: relative;
		transition: var(--transition);
	}
	.city-selector-container:hover {
		border-color: #a8c8b5;
		background: #ffffff;
		transform: translateY(-2px);
		box-shadow: 0 8px 20px rgba(0,0,0,0.06);
	}
	.city-selector-container::after {
		content: '▼';
		position: absolute;
		right: 1.5rem;
		font-size: 0.75rem;
		color: #61746b;
		pointer-events: none;
	}
	.hero-lang-switcher {
		flex: 0 0 7.5rem;
		min-width: 0;
	}
	.hero-lang-switcher :global(.lang-toggle) {
		width: 100%;
		min-height: 4.2rem;
		background: #f5faf6;
		border-color: #d9e2d6;
		box-shadow: 0 6px 16px rgba(24, 45, 34, 0.08);
		font-size: 1.05rem;
		font-weight: 900;
	}
	.hero-lang-switcher :global(.lang-toggle:hover),
	.hero-lang-switcher :global(.lang-toggle:focus-visible) {
		border-color: #a8c8b5;
		background: #ffffff;
	}
	/* --- City Select & Icon --- */
	.city-icon {
		position: absolute;
		left: 1.25rem;
		color: #61746b;
		flex-shrink: 0;
		width: 20px;
		height: 20px;
		pointer-events: none;
		z-index: 2;
	}
	.city-select {
		width: 100%;
		border: none;
		background: transparent;
		appearance: none;
		font: inherit;
		font-size: inherit !important;
		font-weight: 800 !important;
		color: #1d2b24;
		padding: 0 2.5rem;
		outline: none;
		text-align: center;
		text-align-last: center;
		cursor: pointer;
	}

	/* --- Hero CTA Button --- */
	.hero-city-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		margin-top: 0.25rem;
		padding: 0 2.5rem;
		height: 4.8rem;
		box-sizing: border-box;
		border-radius: 8px;
		border: 1px solid #163d2b;
		background: #163d2b;
		color: #fff;
		text-decoration: none;
		font-size: 1.2rem;
		line-height: 1.2;
		transition: var(--transition);
		width: 100%;
	}
	.hero-city-link:hover {
		transform: translateY(-1px);
