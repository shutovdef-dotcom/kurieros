---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import JobGrid from '../components/JobGrid.astro';
import IncomeCalculator from '../components/IncomeCalculator.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import ReviewsBlock from '../components/ReviewsBlock.astro';
import { CATEGORIES } from '../data/constants';
import jobsData from '../data/jobs';
import { getCompaniesFromJobs } from '../utils/companies';
import { getCitiesFromJobs, getCityNames } from '../utils/cities';

const cities = getCitiesFromJobs(jobsData);
const availableCities = getCityNames(jobsData);
const cityRouteMap = Object.fromEntries(cities.map((city) => [city.name, `/rabota-kurerom-${city.slug}/`]));
const companies = getCompaniesFromJobs(jobsData);
const totalVacancies = jobsData.length;
const topCities = [...cities]
	.sort((a, b) => b.vacancyCount - a.vacancyCount)
	.slice(0, 6)
	.map((city) => ({
		name: city.name,
		vacancyCount: city.vacancyCount,
		href: `/rabota-kurerom-${city.slug}/`,
	}));
const featuredCompanies = [...companies]
	.sort((a, b) => b.vacancyCount - a.vacancyCount)
	.slice(0, 6)
	.map((company) => ({
		name: company.name,
		href: company.href,
	}));
const featuredFormats = ['na-avto', 'peshkom', 'dlya-studentov', 'ezhednevnaya-oplata', 'samokat', 'kuper']
	.map((slug) => CATEGORIES.find((category) => category.slug === slug))
	.filter(Boolean)
	.map((category) => ({
		name: category!.name,
		href: `/rabota-kurerom-${category!.slug}/`,
	}));
const routeCards = [
	{
		title: 'Подработка после дел',
		text: 'Вечерние смены, выходные и варианты без полного графика.',
		href: '/rabota-kurerom-podrabotka/',
	},
	{
		title: 'Можно с 16 лет',
		text: 'Пешие и вело-варианты, где не нужен автомобиль.',
		href: '/rabota-kurerom-16-let/',
	},
	{
		title: 'Есть автомобиль',
		text: 'Посмотреть, где машина правда помогает заработать больше.',
		href: '/rabota-kurerom-na-avto/',
	},
	{
		title: 'Хочу выбрать компанию',
		text: 'Сравнить сервисы по выплатам, требованиям и городам.',
		href: '/companies/',
	},
];
const quickStartLinks = [
	{ label: 'Подработка', href: '/rabota-kurerom-podrabotka/' },
	{ label: 'С 16 лет', href: '/rabota-kurerom-16-let/' },
	{ label: 'На авто', href: '/rabota-kurerom-na-avto/' },
	{ label: 'Компании', href: '/companies/' },
	{ label: 'Сравнение', href: '/compare/' },
];
const heroFacts = [
	{ label: 'Вакансии', value: `${totalVacancies}` },
	{ label: 'Компании', value: `${companies.length}` },
	{ label: 'Города', value: `${cities.length}` },
	{ label: 'Форматы', value: 'Авто, пешком, подработка' },
];
const faqItems = [
	{
		question: 'Со скольки лет можно работать курьером?',
		answer:
			'В большинстве компаний можно устроиться пешим курьером или велокурьером уже с 16 лет. Для работы на автомобиле обычно нужен возраст 18+ и права категории B.',
	},
	{
		question: 'Сколько реально зарабатывает курьер в 2026 году?',
		answer:
			'Доход зависит от города, транспорта, графика и компании. Пешие курьеры обычно зарабатывают меньше, а вело- и автоформаты дают более высокий потенциал дохода.',
	},
	{
		question: 'Нужна ли собственная термосумка?',
		answer:
			'Чаще всего нет: агрегаторы и сервисы доставки выдают экипировку и термосумку после подключения или короткого обучения.',
	},
];
const hubLinks = [
	{
		href: '/compare/',
		title: 'Сравнение вакансий',
		text: 'Поставить рядом зарплату, выплаты, транспорт и оформление.',
	},
	{
		href: '/companies/',
		title: 'Компании',
		text: 'Посмотреть, чем отличаются сервисы доставки и банки.',
	},
	{
		href: '/cities/',
		title: 'Города',
		text: 'Найти вакансии в своём городе без лишнего списка.',
	},
	{
		href: '/blog/',
		title: 'Блог',
		text: 'Разобраться в доходе, расходах и частых ошибках новичков.',
	},
];
const discoveryCards = [
	...routeCards.map((card) => ({
		...card,
		kicker: 'Частый запрос',
		variant: 'route',
	})),
	...hubLinks.map((card) => ({
		...card,
		kicker: 'Раздел сайта',
		variant: 'hub',
	})),
];
const homepageTitle = 'Работа курьером: вакансии, компании и сравнение | Курьерок';
const homepageDescription = `Работа курьером в России: ${totalVacancies} вакансий, ${companies.length} компаний, города, сравнение условий и понятные разборы перед откликом.`.slice(0, 170);
const pageSchemaGraph = [
	{
		'@type': 'CollectionPage',
		name: homepageTitle,
		description: homepageDescription,
		url: Astro.url.href,
		dateModified: new Date().toISOString(),
		mainEntity: {
			'@type': 'ItemList',
			itemListElement: hubLinks.map((link, index) => ({
				'@type': 'ListItem',
				position: index + 1,
				name: link.title,
				url: new URL(link.href, Astro.site).toString(),
			})),
		},
	},
	{
		'@type': 'Organization',
		name: 'Курьерок',
		url: Astro.site,
		description: 'Каталог вакансий курьеров, компаний, городов и практических разборов для спокойного выбора работы.',
	},
	{
		'@type': 'FAQPage',
		mainEntity: faqItems.map((item) => ({
			'@type': 'Question',
			name: item.question,
			acceptedAnswer: {
				'@type': 'Answer',
				text: item.answer,
			},
		})),
	},
];
---

<BaseLayout title={homepageTitle} description={homepageDescription} schemaGraph={pageSchemaGraph}>
	<Header />

	<main>
		<div class="home-shell">
			<section class="hero hero-home">
				<div class="home-hero-panel">
					<div class="home-hero-copy">
						<p class="home-kicker">Курьерская работа без лишнего шума</p>
						<h1>Найдите работу курьером с понятными условиями</h1>
						<p class="home-hero-summary">
							Смотрите вакансии по городу, транспорту, выплатам и компании. Мы выносим важные условия на поверхность,
							чтобы перед откликом было понятно, куда вы идёте и что стоит уточнить.
						</p>
						<div class="home-hero-actions">
							<a href="#vacancies" class="home-hero-link">Смотреть вакансии</a>
							<a href="/compare/" class="home-hero-link home-hero-link-secondary">Сравнить условия</a>
						</div>

						<div class="home-hero-facts">
							{heroFacts.map((fact) => (
								<article class="home-hero-fact">
									<span>{fact.label}</span>
									<strong>{fact.value}</strong>
								</article>
							))}
						</div>
					</div>
					<figure class="home-hero-visual">
						<img src="/blog/skolko-zarabatyvaet-kurer-yandex-eda-2026.jpg" alt="Курьер уточняет условия заказа у стойки выдачи" loading="eager" decoding="async" />
						<figcaption>
							<strong>Сначала условия, потом отклик.</strong>
							<span>Зарплата, график, транспорт и оформление рядом, без прыжков по десяткам вкладок.</span>
						</figcaption>
					</figure>
				</div>

				<div class="hero-toolbar hero-toolbar-only">
					<div class="toolbar-top">
						<div class="city-selector-container" data-region-autoprompt="manual-only">
							<svg class="city-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
							<label class="sr-only" for="city-select">Выберите город</label>
							<select id="city-select" class="city-select">
								<option value="" data-t="location.all_cities">Все города</option>
								{availableCities.map((city) => (
									<option value={city}>{city}</option>
								))}
							</select>
						</div>
						<div class="hero-lang-switcher">
							<LanguageSwitcher />
						</div>
					</div>
					<a id="city-page-link" class="hero-city-link hidden" href="/" data-t="location.view_jobs">Все вакансии в этом городе</a>
				</div>
			</section>

			<section class="home-section home-vacancy-launch">
				<div class="section-heading">
					<h2>Начните с живого списка</h2>
					<p>Ниже все вакансии. Если уже знаете, что ищете, выберите быстрый фильтр или готовую подборку.</p>
				</div>
				<div class="home-vacancy-launch-bar">
					<a href="#vacancies" class="home-vacancy-launch-link">Перейти к ленте вакансий</a>
					<div class="home-quick-chip-row">
						{quickStartLinks.map((link) => (
							<a href={link.href} class="home-chip-link">{link.label}</a>
						))}
					</div>
				</div>
			</section>

			<JobGrid />

			<section class="home-section home-discovery-section">
				<div class="section-heading">
					<h2>Когда список слишком широкий</h2>
					<p>Отфильтруйте поиск по ситуации: подработка, возраст, свой автомобиль, конкретная компания или город.</p>
				</div>
				<div class="home-navigation-grid">
					{discoveryCards.map((card) => (
						<a href={card.href} class={`home-navigation-card ${card.variant === 'route' ? 'home-navigation-card-route' : ''}`}>
							<span>{card.kicker}</span>
							<h3>{card.title}</h3>
							<p>{card.text}</p>
						</a>
					))}
				</div>
				<div class="home-surface-grid">
					<article class="home-surface-card">
						<h3>Популярные города</h3>
						<div class="home-chip-row">
							{topCities.map((city) => (
								<a href={city.href} class="home-chip-link">{city.name} · {city.vacancyCount}</a>
							))}
						</div>
					</article>

					<article class="home-surface-card">
						<h3>Популярные форматы</h3>
						<div class="home-chip-row">
							{featuredFormats.map((format) => (
								<a href={format.href} class="home-chip-link">{format.name}</a>
							))}
						</div>
					</article>

					<article class="home-surface-card">
						<h3>Компании в подборке</h3>
						<div class="home-chip-row">
							{featuredCompanies.map((company) => (
								<a href={company.href} class="home-chip-link">{company.name}</a>
							))}
						</div>
					</article>
				</div>
			</section>

			<IncomeCalculator />

			<ReviewsBlock />

			<section class="faq-section home-section">
				<div class="section-heading">
					<h2 data-t="faq.title">Частые вопросы</h2>
					<p data-t="faq.subtitle">Коротко о том, что обычно важно перед первым откликом.</p>
				</div>
				<div class="faq-item">
					<div class="faq-question">
						<span data-t="faq.q1">{faqItems[0].question}</span> <span>+</span>
					</div>
					<div class="faq-answer" data-t="faq.a1">{faqItems[0].answer}</div>
				</div>
				<div class="faq-item">
					<div class="faq-question">
						<span data-t="faq.q2">{faqItems[1].question}</span> <span>+</span>
					</div>
					<div class="faq-answer" data-t="faq.a2">{faqItems[1].answer}</div>
				</div>
				<div class="faq-item">
					<div class="faq-question">
						<span data-t="faq.q3">{faqItems[2].question}</span> <span>+</span>
					</div>
					<div class="faq-answer" data-t="faq.a3">{faqItems[2].answer}</div>
				</div>
			</section>
		</div>
	</main>

	<Footer />
</BaseLayout>

<script is:inline define:vars={{ availableCities, cityRouteMap }}>
	document.addEventListener('DOMContentLoaded', () => {
		const STORAGE_KEY = 'kurieros-selected-city';
		const citySelect = document.getElementById('city-select');
		const cityPageLink = document.getElementById('city-page-link');
		const citySelectorContainer = citySelect?.closest('.city-selector-container');
		const shouldAutoPromptRegion = citySelectorContainer?.dataset.regionAutoprompt !== 'manual-only';

		function updateCityLink(city) {
			const href = cityRouteMap[city];
			if (!city || !href) {
				cityPageLink.classList.add('hidden');
				cityPageLink.removeAttribute('href');
				return;
			}

			cityPageLink.href = href;
			cityPageLink.classList.remove('hidden');
		}

		function getTranslation(key, defaultText) {
			const lang = window.kurieros_i18n?.currentLang || 'ru';
			const dict = window.translations ? (window.translations[lang] || window.translations['ru']) : null;
			if (!dict) return defaultText;
			return key.split('.').reduce((prev, curr) => prev && prev[curr], dict) || defaultText;
		}

		function applyCity(city, source = 'manual') {
			const normalizedCity = availableCities.includes(city) ? city : '';
			citySelect.value = normalizedCity;
			updateCityLink(normalizedCity);

			if (normalizedCity) {
				localStorage.setItem(STORAGE_KEY, normalizedCity);
			} else {
				localStorage.removeItem(STORAGE_KEY);
			}

			window.dispatchEvent(new CustomEvent('kurieros:city-selected', {
				detail: { city: normalizedCity, source }
			}));
		}

		function normalizeDetectedCity(name) {
			if (!name) return '';
			const directMatch = availableCities.find((city) => city.toLowerCase() === name.toLowerCase());
			if (directMatch) return directMatch;
			const trimmed = name.replace(/^город\s+/i, '').trim();
			return availableCities.find((city) => city.toLowerCase() === trimmed.toLowerCase()) || '';
		}

		async function getIpData() {
			if (window.kurieros_user) {
				return window.kurieros_user;
			}

			return new Promise((resolve) => {
				const timeout = setTimeout(() => resolve(null), 4000);
				window.addEventListener('kurieros:region-detected', (event) => {
					clearTimeout(timeout);
					resolve(event.detail);
				}, { once: true });
			});
		}

		async function detectCityByIP() {
			const ipData = await getIpData();
			if (!ipData) return;

			// VPN detected — country is not Russia
			if (ipData.country && ipData.country !== 'RU') {
				// Change "Все города" to "Выбор города"
				const allCitiesOption = citySelect.querySelector('option[value=""]');
				if (allCitiesOption) {
					const selectText = getTranslation('location.select_city', 'Выбор города');
					allCitiesOption.textContent = selectText;
					allCitiesOption.setAttribute('data-t', 'location.select_city');
				}

				if (shouldAutoPromptRegion) {
					citySelect.focus();
					window.dispatchEvent(new CustomEvent('kurieros:manual-city-required'));
				}
				return;
			}

			const detectedCity = normalizeDetectedCity(ipData.city);
			if (detectedCity) {
				applyCity(detectedCity, 'ip');
				return;
			}

			// City not recognized — let user pick manually
			citySelect.focus();
		}

		const savedCity = localStorage.getItem(STORAGE_KEY);
		if (savedCity && availableCities.includes(savedCity)) {
			applyCity(savedCity, 'saved');
		} else {
			detectCityByIP();
		}

		citySelect?.addEventListener('change', (event) => {
			applyCity(event.target.value, 'manual');
		});

		document.querySelectorAll('.faq-item').forEach((item) => {
			item.querySelector('.faq-question')?.addEventListener('click', () => {
				item.classList.toggle('active');
			});
		});
	});
</script>

<style>
	/* --- Layout --- */
	main {
		max-width: 1680px;
	}
	.home-shell {
		max-width: 1560px;
		margin: 0 auto;
		padding: 1.25rem 1.5rem 4rem;
	}
	.hero-home {
		display: grid;
		gap: 0.6rem;
		margin-bottom: 1rem;
	}
	.home-hero-panel {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(340px, 0.95fr);
		gap: 1rem;
		padding: 1rem;
		border: 1px solid #d9e2d6;
		border-radius: 8px;
		background: linear-gradient(135deg, rgba(245, 249, 242, 0.96) 0%, rgba(255, 255, 255, 0.98) 54%, rgba(242, 250, 253, 0.96) 100%);
		box-shadow: 0 18px 44px rgba(24, 45, 34, 0.08);
	}
	.home-hero-copy {
		display: grid;
		gap: 0.9rem;
		align-content: center;
		max-width: 74rem;
		padding: 1rem;
	}
	.home-kicker {
		margin: 0;
		font-size: 0.78rem;
		font-weight: 900;
		letter-spacing: 0;
		text-transform: uppercase;
		color: #16734c;
	}
	.home-hero-copy h1 {
		margin: 0;
		font-size: 4rem;
		line-height: 0.96;
		letter-spacing: 0;
		max-width: 16ch;
		text-wrap: balance;
	}
	.home-hero-summary {
		max-width: 62ch;
		margin: 0;
		color: #51635c;
		font-size: 1.12rem;
		line-height: 1.72;
	}
	.home-hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
	}
	.home-hero-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 3rem;
		padding: 0.8rem 1.2rem;
		border-radius: 8px;
		background: #163d2b;
		border: 1px solid #163d2b;
		color: white;
		text-decoration: none;
		font-weight: 800;
		transition: var(--transition);
	}
	.home-hero-link-secondary {
		background: #fff;
		color: #163d2b;
		border-color: #a8c8b5;
	}
	.home-hero-link:hover {
		transform: translateY(-1px);
		box-shadow: 0 10px 24px rgba(22, 61, 43, 0.12);
	}
	.home-hero-visual {
		position: relative;
		min-height: 100%;
		margin: 0;
		overflow: hidden;
		border: 1px solid #d9e2d6;
		border-radius: 8px;
		background: #eef6f0;
	}
	.home-hero-visual img {
		display: block;
		width: 100%;
		height: 100%;
		min-height: 430px;
		object-fit: cover;
	}
	.home-hero-visual figcaption {
		position: absolute;
		left: 1rem;
		right: 1rem;
		bottom: 1rem;
		display: grid;
		gap: 0.25rem;
		padding: 0.9rem;
		border: 1px solid rgba(255, 255, 255, 0.72);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.9);
		box-shadow: 0 14px 30px rgba(11, 31, 22, 0.12);
		backdrop-filter: blur(12px);
		color: #1d2b24;
	}
	.home-hero-visual figcaption strong,
	.home-hero-visual figcaption span {
		margin: 0;
	}
	.home-hero-visual figcaption span {
		color: #51635c;
		line-height: 1.45;
	}
	.home-hero-facts {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.75rem;
	}
	.home-hero-fact {
		display: grid;
		gap: 0.2rem;
		min-height: auto;
		padding: 0.8rem 0.9rem;
		border-radius: 8px;
		border: 1px solid #d9e2d6;
		background: rgba(255, 255, 255, 0.9);
		box-shadow: 0 6px 18px rgba(24, 45, 34, 0.04);
	}
	.home-hero-fact span {
		font-size: 0.72rem;
		font-weight: 900;
		letter-spacing: 0;
		text-transform: uppercase;
		color: #61746b;
	}
	.home-hero-fact strong {
		align-self: start;
		font-size: 1.02rem;
		line-height: 1.3;
		color: #1d2b24;
	}
	.home-section {
		padding: 2.25rem;
		margin: 1.5rem auto;
		max-width: 1560px;
		width: 100%;
		background: #ffffff;
		border: 1px solid #dfe7dd;
		border-radius: 8px;
		box-shadow: 0 8px 24px rgba(24, 45, 34, 0.04);
	}
	.home-vacancy-launch {
		margin-top: 0.5rem;
	}
	.home-vacancy-launch-bar {
		display: grid;
		grid-template-columns: minmax(240px, 0.44fr) minmax(0, 1fr);
		gap: 1rem;
		align-items: start;
	}
	.home-vacancy-launch-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 3.1rem;
		padding: 0.85rem 1.2rem;
		border-radius: 8px;
		background: #163d2b;
		border: 1px solid #163d2b;
		color: white;
		text-decoration: none;
		font-weight: 800;
		transition: var(--transition);
