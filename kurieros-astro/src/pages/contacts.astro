---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Контакты и поддержка — Курьерок" description="Свяжитесь с нами по вопросам размещения вакансий, сотрудничества или технической поддержки. Мы всегда рады помочь курьерам и работодателям.">
    <Header />

    <main>
        <div class="contacts-container">
            <section class="contacts-hero">
                <h1 data-t="contacts.title">Связаться с нами</h1>
                <p data-t="contacts.subtitle">Мы открыты для предложений и всегда рады услышать ваш отзыв о сайте.</p>
                <p class="contacts-helper">Для быстрого ответа лучше использовать прямые каналы ниже. Форма справа помогает подготовить сообщение без серверной отправки.</p>
            </section>

            <div class="contacts-grid">
                <div class="contact-info">
                    <div class="contact-card">
                        <h3 data-t="contacts.collab">Сотрудничество</h3>
                        <p data-t="contacts.collab_text">Для компаний и рекламных агентств</p>
                        <a href="mailto:partners@kurerok.ru" class="contact-link">partners@kurerok.ru</a>
                    </div>
                    
                    <div class="contact-card">
                        <h3 data-t="contacts.support">Поддержка</h3>
                        <p data-t="contacts.support_text">Для курьеров и соискателей</p>
                        <a href="https://t.me/kurieros_support" target="_blank" class="contact-link">Написать в Telegram</a>
                    </div>

                    <div class="contact-card">
                        <h3 data-t="contacts.editor">Редакция блога</h3>
                        <p data-t="contacts.editor_text">Предложить статью или прислать историю</p>
                        <a href="mailto:editor@kurerok.ru" class="contact-link">editor@kurerok.ru</a>
                    </div>
                </div>

                <div class="contact-form-card">
                    <h3 data-t="contacts.form_title">Подготовить сообщение</h3>
                    <p class="contact-form-note">После заполнения мы покажем удобные варианты связи: Telegram для быстрых вопросов и email для более подробного запроса.</p>
                    <form class="contact-form" id="contact-form">
                        <div class="form-group">
                            <label for="name" data-t="contacts.form_name">Ваше имя</label>
                            <input type="text" id="name" required placeholder="Иван Иванов" />
                        </div>
                        <div class="form-group">
                            <label for="email" data-t="contacts.form_contact">Email или Telegram</label>
                            <input type="text" id="email" required placeholder="@username или email@example.com" />
                        </div>
                        <div class="form-group">
                            <label for="message" data-t="contacts.form_msg">Сообщение</label>
                            <textarea id="message" rows="5" required placeholder="Ваш вопрос или предложение..."></textarea>
                        </div>
                        <button type="submit" class="btn-primary" data-t="contacts.form_btn">Показать варианты связи</button>
                    </form>
                    <div class="contact-success hidden" id="contact-success" aria-live="polite">
                        <h4>Сообщение подготовлено</h4>
                        <p>Для вопросов по вакансиям быстрее Telegram. Для сотрудничества и редакционных тем удобнее email.</p>
                        <pre class="contact-preview" id="contact-preview"></pre>
                        <div class="contact-success-actions">
                            <a href="https://t.me/kurieros_support" target="_blank" rel="noopener noreferrer" class="btn-primary">Написать в Telegram</a>
                            <a href="mailto:partners@kurerok.ru" class="btn-secondary" id="contact-email-link">Открыть email</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <Footer />
</BaseLayout>

<script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('contact-form');
        const successBox = document.getElementById('contact-success');
        const preview = document.getElementById('contact-preview');
        const emailLink = document.getElementById('contact-email-link');

        form?.addEventListener('submit', (event) => {
            event.preventDefault();

            const name = document.getElementById('name')?.value?.trim() || 'Без имени';
            const contact = document.getElementById('email')?.value?.trim() || 'Контакт не указан';
            const message = document.getElementById('message')?.value?.trim() || 'Сообщение не заполнено';

            const preparedMessage = [
                `Имя: ${name}`,
                `Контакт: ${contact}`,
                '',
                'Сообщение:',
                message,
            ].join('\n');

            if (preview) {
                preview.textContent = preparedMessage;
            }

            if (emailLink) {
                const subject = encodeURIComponent(`Сообщение с сайта от ${name}`);
                const body = encodeURIComponent(preparedMessage);
                emailLink.href = `mailto:partners@kurerok.ru?subject=${subject}&body=${body}`;
            }

            successBox?.classList.remove('hidden');
            successBox?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        });
    });
</script>

<style>
    .contacts-container {
        max-width: 1240px;
        margin: 0 auto;
        padding-top: 4rem;
        padding-bottom: 4rem;
    }
    .contacts-hero {
        text-align: center;
        margin-bottom: 4rem;
    }
    .contacts-hero h1 { margin-bottom: 1rem; }
    .contacts-hero p { color: var(--text-muted); font-size: 1.125rem; }
    .contacts-helper {
        max-width: 720px;
        margin: 1rem auto 0;
        line-height: 1.7;
    }

    .contacts-grid {
        display: grid;
        grid-template-columns: 1fr 1.5fr;
        gap: 3rem;
    }
    @media (max-width: 768px) {
        .contacts-grid {
            grid-template-columns: 1fr;
        }
    }

    .contact-info {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }
    .contact-card {
        background: var(--bg-card);
        padding: 2rem;
        border-radius: 8px;
        border: 1px solid var(--border-color);
        box-shadow: var(--shadow-sm);
    }
    .contact-card h3 { margin-bottom: 0.5rem; font-size: 1.125rem; }
    .contact-card p { color: var(--text-muted); font-size: 0.875rem; margin-bottom: 1rem; }
    .contact-link {
        color: var(--primary-color);
        text-decoration: none;
        font-weight: 700;
        font-size: 1rem;
    }

    .contact-form-card {
        background: var(--bg-card);
        padding: 3rem;
        border-radius: 8px;
        border: 1px solid var(--border-color);
        box-shadow: var(--shadow-glass);
    }
    .contact-form-card h3 { margin-bottom: 2rem; font-size: 1.5rem; }
    .contact-form-note {
        margin: -1rem 0 1.5rem;
        color: var(--text-muted);
        line-height: 1.7;
    }

    .contact-form {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }
    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .form-group label {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--text-main);
    }
    .form-group input, .form-group textarea {
        background: var(--bg-color);
        border: 1px solid var(--border-color);
        padding: 1rem;
        border-radius: 8px;
        font-size: 1rem;
        font-family: inherit;
        outline: none;
        transition: var(--transition);
    }
    .form-group input:focus, .form-group textarea:focus {
        border-color: var(--primary-color);
        box-shadow: 0 0 0 4px rgba(22, 115, 76, 0.1);
    }
    .contact-success {
        margin-top: 1.5rem;
        padding: 1.5rem;
        border-radius: 8px;
        border: 1px solid var(--border-color);
        background: rgba(255, 255, 255, 0.72);
    }
    .contact-success.hidden {
        display: none;
    }
    .contact-success h4 {
        margin-bottom: 0.75rem;
        font-size: 1.05rem;
    }
    .contact-success p {
        color: var(--text-muted);
        line-height: 1.6;
        margin-bottom: 1rem;
    }
    .contact-preview {
        margin: 0 0 1rem;
        padding: 1rem;
        border-radius: 8px;
        background: var(--bg-color);
        border: 1px solid var(--border-color);
        font-family: var(--font-main);
        font-size: 0.92rem;
        line-height: 1.6;
        white-space: pre-wrap;
        word-break: break-word;
    }
    .contact-success-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }
    .contact-success-actions .btn-primary,
    .contact-success-actions .btn-secondary {
        width: auto;
    }
    @media (max-width: 768px) {
        .contacts-container {
            padding-top: 2rem;
            padding-bottom: 2rem;
        }
        .contact-form-card {
            padding: 2rem 1.25rem;
        }
        .contact-success-actions .btn-primary,
        .contact-success-actions .btn-secondary {
            width: 100%;
        }
    }
</style>
