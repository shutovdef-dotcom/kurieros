---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import IncomeCalculator from '../components/IncomeCalculator.astro';
---

<BaseLayout title="Калькулятор дохода курьера — Рассчитать заработок в месяц" description="Узнайте, сколько вы сможете заработать в Яндекс Еда, Самокате и других компаниях. Учитываются город, количество часов и дней работы.">
    <Header />

    <main class="page-shell">
        <section class="calculator-hero">
            <h1 data-t="calculator.title">Калькулятор дохода курьера</h1>
            <p data-t="calculator.subtitle">Узнайте, сколько вы можете заработать в месяц в вашем городе</p>
        </section>

        <div class="calculator-standalone-wrapper">
            <IncomeCalculator />
        </div>

        <section class="calc-info-section">
            <div class="info-grid">
                <div class="info-card">
                    <h3>Как мы считаем?</h3>
                    <p>Берём средние ставки по городам, умножаем их на часы и дни работы, а затем добавляем примерную надбавку за чаевые и пиковые периоды.</p>
                </div>
                <div class="info-card">
                    <h3>Можно ли заработать больше?</h3>
                    <p>Да. Электровелосипед или авто, часы повышенного спроса и стабильные смены обычно дают больше заказов и выше итоговую сумму.</p>
                </div>
                <div class="info-card">
                    <h3>Когда придут деньги?</h3>
                    <p>В вакансиях встречаются ежедневные и еженедельные выплаты. Точный график лучше проверять в карточке работодателя перед откликом.</p>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</BaseLayout>

<style>
    .page-shell {
        max-width: 1560px;
        margin: 0 auto;
        padding: 0 2rem;
    }
    
    .calculator-hero {
        padding: 4rem 1rem 3rem 1rem;
        text-align: center;
    }
    
    .calculator-hero h1 {
        font-size: 3.8rem;
        font-weight: 900;
        letter-spacing: 0;
        margin-bottom: 1rem;
        color: #1d2b24;
    }
    
    .calculator-hero p {
        font-size: 1.25rem;
        color: #51635c;
        max-width: 600px;
        margin: 0 auto;
    }

    .calculator-standalone-wrapper {
        margin-bottom: 4rem;
    }

    .calc-info-section {
        margin-bottom: 6rem;
    }
    
    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
    }
    
    .info-card {
        background: #ffffff;
        border: 1px solid #d9e2d6;
        padding: 2.5rem;
        border-radius: 8px;
        transition: transform 0.3s ease;
    }
    
    .info-card:hover {
        transform: translateY(-5px);
    }
    
    .info-card h3 {
        font-size: 1.5rem;
        font-weight: 800;
        margin-bottom: 1rem;
        color: #1d2b24;
    }
    
    .info-card p {
        color: #51635c;
        line-height: 1.6;
        font-size: 1.05rem;
    }

    @media (max-width: 768px) {
        .page-shell {
            padding: 0 1rem;
        }
        .calculator-hero {
            padding: 3rem 1rem 2rem 1rem;
        }
        .calculator-hero h1 {
            font-size: 2.6rem;
        }
        .info-card {
            padding: 1.5rem;
        }
    }
</style>
