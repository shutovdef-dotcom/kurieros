---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ReviewsBlock from '../../components/ReviewsBlock.astro';
import jobsData from '../../data/jobs.json';

export async function getStaticPaths() {
	return jobsData.map((job) => ({
		params: { slug: job.slug },
		props: { job },
	}));
}

const { job } = Astro.props;
const hasApplyLink = Boolean(job.applyLink && job.applyLink !== '#');
---

<BaseLayout 
	title={`${job.title} — Вакансия в ${job.company}`} 
	description={job.description.substring(0, 160)}
>
	<Header />

	<main class="vacancy-page">
		<div class="container container-narrow">
			<nav class="breadcrumb">
				<a href="/kurieros/" data-t="nav.main">Главная</a> &gt; <span data-t={`vacancies.${job.id}.title`}>{job.title}</span>
			</nav>

			<section class="vacancy-header">
				<div class="vacancy-company-info">
					<img src={job.companyLogo} alt={job.company} class="vacancy-logo" width="80" height="80" loading="eager" decoding="async" />
					<div>
						<h1 data-t={`vacancies.${job.id}.title`}>{job.title}</h1>
						<div class="vacancy-company-name" data-t={`vacancies.${job.id}.company`}>{job.company}</div>
					</div>
				</div>
                <div class="vacancy-salary-badge" data-t={`vacancies.${job.id}.salary`}>{job.salary}</div>
			</section>

			<div class="vacancy-content-grid">
				<div class="vacancy-main">
					<section class="vacancy-section">
						<h2 data-t="vacancy.desc_title">Описание вакансии</h2>
						<p style="white-space: pre-wrap;" data-t={`vacancies.${job.id}.description`}>{job.description}</p>
					</section>

					<section class="vacancy-section">
						<h2 data-t="vacancy.req_title">Требования</h2>
						<ul class="vacancy-list">
							{job.requirements.map((req: string, idx: number) => (
								<li data-t={`vacancies.${job.id}.req_${idx}`}>{req}</li>
							))}
						</ul>
					</section>

					<section class="vacancy-section">
						<h2 data-t="vacancy.ben_title">Преимущества</h2>
						<ul class="vacancy-list">
							{job.benefits.map((benefit: string, idx: number) => (
								<li data-t={`vacancies.${job.id}.ben_${idx}`}>{benefit}</li>
							))}
						</ul>
					</section>
				</div>

				<aside class="vacancy-sidebar">
					<div class="vacancy-card-sidebar">
						<h3 data-t="vacancy.details_title">Детали</h3>
						<div class="detail-item">
							<strong data-t="vacancy.location">Локация:</strong> <span data-t={`vacancies.${job.id}.location`}>{job.location}</span>
						</div>
						<div class="detail-item">
							<strong data-t="job.schedule">График:</strong> <span data-t={`vacancies.${job.id}.details_schedule`}>{job.details.schedule}</span>
						</div>
						<div class="detail-item">
							<strong data-t="vacancy.payment">Оплата:</strong> <span data-t={`vacancies.${job.id}.details_payment_freq`}>{job.details.payment_freq}</span>
						</div>
						<div class="detail-item">
							<strong data-t="vacancy.age">Возраст:</strong> <span data-t={`vacancies.${job.id}.details_age`}>{job.details.age}</span>
						</div>
						<div class="detail-item">
							<strong data-t="vacancy.employment">Оформление:</strong> <span data-t={`vacancies.${job.id}.details_employment_type`}>{job.details.employment_type}</span>
						</div>
						
						{hasApplyLink ? (
							<>
								<a href={job.applyLink} target="_blank" rel="noopener noreferrer" class="apply-btn-large" data-t="vacancy.apply">
									Откликнуться сейчас
								</a>
								<p class="apply-note" data-t="vacancy.apply_note">Вы перейдете на сайт прямого работодателя</p>
							</>
						) : (
							<>
								<a href="/kurieros/contacts/" class="apply-btn-large apply-btn-disabled" data-t="vacancy.apply_disabled">
									Уточнить условия
								</a>
								<p class="apply-note" data-t="vacancy.apply_disabled_note">Для этой вакансии прямая ссылка пока не добавлена</p>
							</>
						)}
					</div>
				</aside>
			</div>

			<ReviewsBlock jobId={job.id} />
		</div>
	</main>

	<Footer />
</BaseLayout>

<style>
	.vacancy-page {
		padding: 2rem 0;
	}
	.container-narrow {
		max-width: 1240px;
		margin: 0 auto;
		padding: 0 1rem;
	}
	.breadcrumb {
		margin-bottom: 2rem;
		font-size: 0.875rem;
		color: var(--text-muted);
	}
	.breadcrumb a {
		color: var(--accent-color);
		text-decoration: none;
	}
	.vacancy-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		background: var(--bg-card);
		padding: 2rem;
		border-radius: 1.5rem;
		margin-bottom: 2rem;
		box-shadow: var(--shadow-sm);
	}
	.vacancy-company-info {
		display: flex;
		gap: 1.5rem;
		align-items: center;
	}
	.vacancy-logo {
		width: 80px;
		height: 80px;
		object-fit: contain;
		border-radius: 1rem;
		background: white;
		padding: 0.5rem;
	}
	.vacancy-salary-badge {
		background: var(--accent-color);
		color: white;
		padding: 0.75rem 1.5rem;
		border-radius: 2rem;
		font-weight: 800;
		font-size: 1.25rem;
	}
	.vacancy-content-grid {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 2rem;
	}
	@media (max-width: 768px) {
		.vacancy-content-grid {
			grid-template-columns: 1fr;
		}
		.vacancy-header {
			flex-direction: column;
			gap: 1rem;
		}
	}
	.vacancy-section {
		background: var(--bg-card);
		padding: 2rem;
		border-radius: 1.5rem;
		margin-bottom: 1.5rem;
		box-shadow: var(--shadow-sm);
	}
	.vacancy-section h2 {
		margin-top: 0;
		margin-bottom: 1rem;
		font-size: 1.5rem;
	}
	.vacancy-list {
		padding-left: 1.5rem;
	}
	.vacancy-list li {
		margin-bottom: 0.5rem;
	}
	.vacancy-card-sidebar {
		background: var(--bg-card);
		padding: 2rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-sm);
		position: sticky;
		top: 2rem;
	}
	.detail-item {
		display: flex;
		justify-content: space-between;
		padding: 0.75rem 0;
		border-bottom: 1px solid var(--border-color);
	}
	.apply-btn-large {
		display: block;
		width: 100%;
		background: var(--accent-gradient);
		color: white;
		text-align: center;
		padding: 1rem;
		border-radius: 1rem;
		font-weight: 700;
		margin-top: 2rem;
		text-decoration: none;
		transition: transform 0.2s;
	}
	.apply-btn-large:hover {
		transform: scale(1.02);
	}
	.apply-btn-disabled {
		background: var(--surface-color);
		color: var(--text-main);
		border: 1px solid var(--border-color);
	}
	.apply-btn-disabled:hover {
		transform: none;
	}
	.apply-note {
		text-align: center;
		font-size: 0.75rem;
		color: var(--text-muted);
		margin-top: 0.5rem;
	}
</style>
