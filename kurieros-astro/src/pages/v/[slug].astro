---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ReviewsBlock from '../../components/ReviewsBlock.astro';
import jobsData from '../../data/jobs';
import { slugifyCompany } from '../../utils/companies';
import { getCityHref } from '../../utils/cities';
import { buildBreadcrumbSchema } from '../../utils/schema';

export async function getStaticPaths() {
	return jobsData.map((job) => ({
		params: { slug: job.slug },
		props: { job },
	}));
}

const { job } = Astro.props;
const hasApplyLink = Boolean(job.applyLink && job.applyLink !== '#');
const companyUrl = `/companies/${slugifyCompany(job.company)}/`;
const parseSalaryValue = (salary: string) => Number(salary.replace(/[^\d]/g, '')) || 0;
const salaryValue = parseSalaryValue(job.salary);
const jobCities = job.location
	.split(',')
	.map((city: string) => city.trim())
	.filter((city: string) => city && city !== 'Вся Россия');
const cityLinks = jobCities.map((city) => ({
	name: city,
	href: getCityHref(city),
}));
const primaryTransportTag = job.tags.find((tag: string) => ['auto', 'bicycle', 'foot'].includes(tag));
const currentCitySet = new Set(jobCities);
const scoredRelatedJobs = jobsData
	.filter((item) => item.slug !== job.slug)
	.map((item) => {
		const itemCities = item.location
			.split(',')
			.map((city) => city.trim())
			.filter((city) => city && city !== 'Вся Россия');
		const score =
			(item.company === job.company ? 5 : 0) +
			(primaryTransportTag && item.tags.includes(primaryTransportTag) ? 3 : 0) +
			(itemCities.some((city) => currentCitySet.has(city)) ? 2 : 0) +
			(item.details.payment_freq === job.details.payment_freq ? 1 : 0);

		return { ...item, score };
	})
	.sort((a, b) => b.score - a.score || parseSalaryValue(b.salary) - parseSalaryValue(a.salary));
const prioritizedRelatedJobs = scoredRelatedJobs.filter((item) => item.score > 0);
const relatedJobs = prioritizedRelatedJobs.length ? prioritizedRelatedJobs.slice(0, 4) : scoredRelatedJobs.slice(0, 4);
const vacancyTitle = `${job.title} — зарплата, условия и отклик | Курьерок`;
const vacancyDescription = `Вакансия "${job.title}" в ${job.company}: ${job.salary}, ${job.details.schedule.toLowerCase()}, ${job.details.payment_freq.toLowerCase()}. Сравните условия и переходите к отклику.`.slice(0, 170);
const jobLocationSchema = (jobCities.length ? jobCities : ['Россия']).map((city) => ({
	'@type': 'Place',
	address: {
		'@type': 'PostalAddress',
		...(city !== 'Россия' ? { addressLocality: city } : {}),
		addressCountry: 'RU',
	},
}));
const factCards = [
	{ label: 'Доход', labelKey: 'vacancy.fact_income', value: job.salary, valueKey: `vacancies.${job.id}.salary` },
	{ label: 'График', labelKey: 'vacancy.fact_schedule', value: job.details.schedule, valueKey: `vacancies.${job.id}.details_schedule` },
	{ label: 'Возраст', labelKey: 'vacancy.fact_age', value: job.details.age, valueKey: `vacancies.${job.id}.details_age` },
	{ label: 'Выплаты', labelKey: 'vacancy.fact_payments', value: job.details.payment_freq, valueKey: `vacancies.${job.id}.details_payment_freq` },
	{ label: 'Гражданство', labelKey: 'vacancy.fact_citizenship', value: job.details.citizenship, valueKey: `vacancies.${job.id}.details_citizenship` },
	{ label: 'Оформление', labelKey: 'vacancy.fact_employment', value: job.details.employment_type, valueKey: `vacancies.${job.id}.details_employment_type` },
];
const fitPoints = [
	`Тем, кто хочет рассмотреть работу в ${job.company} без долгого отбора условий.`,
	`Кандидатам, которым важны ${job.details.schedule.toLowerCase()} и понятный формат оформления.`,
	`Соискателям, которые сравнивают вакансии курьера по выплатам, требованиям и графику.`,
];
const importantPoints = [
	`Перед откликом проверьте актуальные условия по выплатам: для этой вакансии указано "${job.details.payment_freq}".`,
	`Уточните требования к оформлению: сейчас в карточке указано "${job.details.employment_type}".`,
	`Если условия на сайте работодателя отличаются от карточки, ориентируйтесь на финальные условия при подключении.`,
];
const antiFitPoints = [
	`Если вам не подходит формат оформления "${job.details.employment_type}", лучше сразу сравнить эту вакансию с альтернативами.`,
	`Если критичны точные ограничения по возрасту, гражданству или медкнижке, подтверждайте эти условия до перехода к анкете.`,
	`Если нужен строго официальный формат по ТК РФ или другой тип выплат, карточку стоит сравнить с более подходящими вариантами.`,
];
const faqItems = [
	{
		question: `Кому подходит вакансия "${job.title}"?`,
		answer: `Эта вакансия подходит кандидатам, которые рассматривают работу в ${job.company}, готовы к формату "${job.details.schedule}" и хотят заранее сравнить доход, требования и оформление.`,
	},
	{
		question: 'Что нужно проверить перед откликом?',
		answer: `Перед откликом стоит проверить график, выплаты, требования к возрасту, гражданству и оформлению. Для этой вакансии указаны выплаты: ${job.details.payment_freq}.`,
	},
	{
		question: 'Куда ведёт кнопка отклика?',
		answer: hasApplyLink
			? 'Кнопка отклика ведёт на внешний сайт работодателя или партнёра, где нужно заполнить анкету и подтвердить актуальные условия.'
			: 'Для этой вакансии прямая ссылка пока не добавлена, поэтому кнопка ведёт на страницу контактов для уточнения условий.',
	},
];
const updatedDate = new Intl.DateTimeFormat('ru-RU', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
}).format(new Date());
const methodologyPoints = [
	`Карточка обновлена ${updatedDate} и помогает быстро сравнить доход, график, оформление и ограничения до отклика.`,
	hasApplyLink
		? 'Кнопка отклика ведёт на внешний сайт работодателя или партнёра, где нужно ещё раз проверить актуальные условия.'
		: 'Прямая ссылка на внешний отклик пока не добавлена, поэтому условия стоит уточнять через страницу контактов.',
	'Если данные в анкете работодателя отличаются от карточки, ориентируйтесь на финальные условия при подключении.',
];
const pageSchemaGraph = [
	{
		'@type': 'WebPage',
		name: `${job.title} — Вакансия в ${job.company}`,
		description: vacancyDescription,
		url: Astro.url.href,
		dateModified: new Date().toISOString(),
		about: {
			'@type': 'Organization',
			name: job.company,
			url: new URL(companyUrl, Astro.site).toString(),
		},
	},
	{
		'@type': 'JobPosting',
		title: job.title,
		description: job.description,
		identifier: {
			'@type': 'PropertyValue',
			name: 'Курьерок',
			value: job.slug,
		},
		datePosted: new Date().toISOString(),
		employmentType: job.details.employment_type,
		hiringOrganization: {
			'@type': 'Organization',
			name: job.company,
			sameAs: new URL(companyUrl, Astro.site).toString(),
			logo: job.companyLogo,
		},
		jobLocation: jobLocationSchema,
		directApply: hasApplyLink,
		jobBenefits: job.benefits.join('; '),
		qualifications: [...job.requirements, ...job.requiredDocuments].join('; '),
		baseSalary: salaryValue
			? {
				'@type': 'MonetaryAmount',
				currency: 'RUB',
				value: {
					'@type': 'QuantitativeValue',
					maxValue: salaryValue,
					unitText: 'MONTH',
				},
			}
			: undefined,
	},
	{
		'@type': 'FAQPage',
		mainEntity: faqItems.map((item) => ({
			'@type': 'Question',
			name: item.question,
			acceptedAnswer: {
				'@type': 'Answer',
				text: item.answer,
			},
		})),
	},
	buildBreadcrumbSchema(
		[
			{ name: 'Главная', url: '/' },
			{ name: 'Компании', url: '/companies/' },
			{ name: job.company, url: companyUrl },
			{ name: job.title, url: Astro.url.pathname },
		],
		Astro.site,
	),
];
---

<BaseLayout 
	title={vacancyTitle}
	titleKey={`vacancies.${job.id}.page_title`}
	description={vacancyDescription}
	descriptionKey={`vacancies.${job.id}.page_description`}
	schemaGraph={pageSchemaGraph}
>
	<Header />

	<main class="vacancy-page">
		<div class="container container-narrow">
			<nav class="breadcrumb" aria-label="Breadcrumb">
				<a href="/" data-t="nav.main">Главная</a> &gt; <a href="/companies/" data-t="nav.companies">Компании</a> &gt; <a href={companyUrl} data-t={`vacancies.${job.id}.company`}>{job.company}</a> &gt; <span data-t={`vacancies.${job.id}.title`}>{job.title}</span>
			</nav>

			<section class="vacancy-header">
				<div class="vacancy-hero-main">
					<div class="vacancy-company-info">
						<img src={job.companyLogo} alt={job.company} class="vacancy-logo" width="80" height="80" loading="eager" decoding="async" />
						<div>
							<div class="vacancy-kicker" data-t="vacancy.card_kicker">Карточка вакансии</div>
							<h1 data-t={`vacancies.${job.id}.title`}>{job.title}</h1>
							<a href={companyUrl} class="vacancy-company-name" data-t={`vacancies.${job.id}.company`}>{job.company}</a>
						</div>
					</div>
					<p class="vacancy-ai-summary" data-t="vacancy.hero_summary">
						{job.title} в {job.company} — это вакансия для кандидатов, которые хотят заранее понять доход, график,
						требования и формат оформления перед переходом к отклику.
					</p>
					<div class="vacancy-meta-row">
						<span class="meta-pill"><span data-t="vacancy.updated">Обновлено</span>&nbsp;<span data-t={`vacancies.${job.id}.updated_date`}>{updatedDate}</span></span>
						{cityLinks.slice(0, 2).map((city) => (
							<a href={city.href} class="meta-pill meta-pill-link">{city.name}</a>
						))}
					</div>
				</div>
					<div class="vacancy-salary-card">
						<span data-t="vacancy.income">Доход</span>
						<strong data-t={`vacancies.${job.id}.salary`}>{job.salary}</strong>
						<small class="salary-rate" data-t={`vacancies.${job.id}.details_rate`}>{job.details.rate}</small>
						<small data-t="vacancy.final_terms_short">Финальные условия уточняются при отклике</small>
						{hasApplyLink ? (
							<a href={job.applyLink} target="_blank" rel="noopener noreferrer" class="apply-btn-large apply-btn-hero" data-t="vacancy.apply">
								Откликнуться сейчас
						</a>
					) : (
						<a href="/contacts/" class="apply-btn-large apply-btn-hero apply-btn-disabled" data-t="vacancy.apply_disabled">
							Уточнить условия
						</a>
					)}
					<p class="apply-note apply-note-hero" data-t={hasApplyLink ? 'vacancy.apply_note_hero' : 'vacancy.apply_disabled_note_hero'}>{hasApplyLink ? 'Переход на анкету работодателя или партнёра' : 'Оставьте контакт, чтобы уточнить условия'}</p>
				</div>
			</section>

			<section class="vacancy-facts" id="vacancy-facts" aria-label="Краткие факты о вакансии">
				{factCards.map((fact) => (
					<div class="fact-card">
						<span data-t={fact.labelKey}>{fact.label}</span>
						<strong data-t={fact.valueKey}>{fact.value}</strong>
					</div>
				))}
			</section>

			<div class="vacancy-content-grid">
				<div class="vacancy-main">
					<section class="vacancy-section vacancy-description-section">
						<h2 data-t="vacancy.desc_title">Описание вакансии</h2>
						<p class="vacancy-description" data-t={`vacancies.${job.id}.description`}>{job.description}</p>

						<div class="vacancy-subsection">
							<h3 data-t="vacancy.req_title">Требования</h3>
							<ul class="vacancy-list">
								{job.requirements.map((req: string, idx: number) => (
									<li data-t={`vacancies.${job.id}.req_${idx}`}>{req}</li>
								))}
							</ul>
						</div>

						{job.requiredDocuments.length > 0 && (
							<div class="vacancy-subsection">
								<h3 data-t="vacancy.docs_title">Документы для оформления</h3>
								<ul class="vacancy-list">
									{job.requiredDocuments.map((document: string, idx: number) => (
										<li data-t={`vacancies.${job.id}.doc_${idx}`}>{document}</li>
									))}
								</ul>
							</div>
						)}

						<div class="vacancy-subsection">
							<h3 data-t="vacancy.ben_title">Преимущества</h3>
							<ul class="vacancy-list">
								{job.benefits.map((benefit: string, idx: number) => (
									<li data-t={`vacancies.${job.id}.ben_${idx}`}>{benefit}</li>
								))}
							</ul>
						</div>
					</section>

					<section class="vacancy-section vacancy-guidance-section">
						<p class="section-eyebrow" data-t="vacancy.fit_eyebrow">Кому подходит</p>
						<h2 data-t="vacancy.fit_title">Кому лучше всего подходит эта вакансия?</h2>
						<div class="answer-grid">
							{['fit_point_0', 'fit_point_1', 'fit_point_2'].map((key, index) => (
								<div class="answer-card" data-t={`vacancy.${key}`}>{fitPoints[index]}</div>
							))}
						</div>
					</section>

					<section class="vacancy-section vacancy-guidance-section">
						<p class="section-eyebrow" data-t="vacancy.anti_eyebrow">Когда сравнить ещё варианты</p>
						<h2 data-t="vacancy.anti_title">Кому эта вакансия может не подойти?</h2>
						<div class="answer-grid answer-grid-two">
							{['anti_point_0', 'anti_point_1', 'anti_point_2'].map((key, index) => (
								<div class="answer-card answer-card-warning" data-t={`vacancy.${key}`}>{antiFitPoints[index]}</div>
							))}
						</div>
					</section>

					<section class="vacancy-section vacancy-guidance-section">
						<p class="section-eyebrow" data-t="vacancy.check_eyebrow">Перед откликом</p>
						<h2 data-t="vacancy.check_title">Что проверить до заполнения анкеты?</h2>
						<ol class="vacancy-list numbered-list">
							{['check_point_0', 'check_point_1', 'check_point_2'].map((key, index) => (
								<li data-t={`vacancy.${key}`}>{importantPoints[index]}</li>
							))}
						</ol>
					</section>

					<section class="vacancy-section vacancy-guidance-section" id="vacancy-faq">
						<p class="section-eyebrow" data-t="vacancy.faq_eyebrow">FAQ</p>
						<h2 data-t="vacancy.faq_title">Короткие ответы перед откликом</h2>
						<div class="faq-stack">
							{faqItems.map((item, index) => (
								<article class="faq-item">
									<h3 data-t={`vacancy.faq_q_${index}`}>{item.question}</h3>
									<p data-t={index === 2 ? (hasApplyLink ? 'vacancy.faq_a_2_apply' : 'vacancy.faq_a_2_no') : `vacancy.faq_a_${index}`}>{item.answer}</p>
								</article>
							))}
						</div>
					</section>

					<section class="vacancy-section vacancy-guidance-section">
						<p class="section-eyebrow" data-t="vacancy.transparency_eyebrow">Прозрачность</p>
						<h2 data-t="vacancy.transparency_title">Как собрана эта карточка?</h2>
						<div class="trust-stack">
							{methodologyPoints.map((point, index) => (
								<div class="trust-item" data-t={index === 1 ? (hasApplyLink ? 'vacancy.methodology_1_apply' : 'vacancy.methodology_1_no') : `vacancy.methodology_${index}`}>{point}</div>
							))}
						</div>
						<div class="trust-links">
							<a href="/compare/" class="hero-link" data-t="vacancy.compare_jobs">Сравнить с другими вакансиями</a>
							<a href={companyUrl} class="hero-link" data-t="vacancy.open_company">Открыть страницу компании</a>
						</div>
					</section>

					<section class="vacancy-section vacancy-guidance-section">
						<p class="section-eyebrow" data-t="vacancy.next_eyebrow">Дальше</p>
						<h2 data-t="vacancy.next_title">Что ещё открыть после этой вакансии?</h2>
						<div class="vacancy-route-grid">
							<article class="route-card">
								<h3 data-t="vacancy.useful_sections">Полезные разделы</h3>
								<div class="route-chip-row">
									<a href="/compare/" class="hero-link" data-t="nav.compare">Сравнение вакансий</a>
									<a href={companyUrl} class="hero-link" data-t="vacancy.open_company">Страница компании</a>
									<a href="/companies/" class="hero-link" data-t="vacancy.all_companies">Все компании</a>
									{cityLinks.map((city) => (
										<a href={city.href} class="hero-link"><span data-t="vacancy.city_jobs_prefix">Работа курьером в</span> {city.name}</a>
									))}
								</div>
							</article>

							<article class="route-card">
								<h3 data-t="vacancy.related_jobs">Похожие вакансии для сравнения</h3>
								<div class="related-jobs-grid">
									{relatedJobs.map((relatedJob) => (
										<a href={`/v/${relatedJob.slug}/`} class="related-job-card">
											<strong data-t={`vacancies.${relatedJob.id}.title`}>{relatedJob.title}</strong>
											<span data-t={`vacancies.${relatedJob.id}.company`}>{relatedJob.company}</span>
											<div class="related-job-meta">
												<span data-t={`vacancies.${relatedJob.id}.salary`}>{relatedJob.salary}</span>
												<span data-t={`vacancies.${relatedJob.id}.location`}>{relatedJob.location}</span>
											</div>
										</a>
									))}
								</div>
							</article>
						</div>
					</section>
				</div>

				<aside class="vacancy-sidebar">
					<div class="vacancy-card-sidebar">
						<h3 data-t="vacancy.details_title">Детали</h3>
						<div class="detail-item">
							<strong data-t="vacancy.location">Локация:</strong> <span data-t={`vacancies.${job.id}.location`}>{job.location}</span>
						</div>
						<div class="detail-item">
							<strong data-t="job.schedule">График:</strong> <span data-t={`vacancies.${job.id}.details_schedule`}>{job.details.schedule}</span>
						</div>
						<div class="detail-item">
							<strong data-t="vacancy.payment">Оплата:</strong> <span data-t={`vacancies.${job.id}.details_payment_freq`}>{job.details.payment_freq}</span>
						</div>
						<div class="detail-item">
							<strong data-t="vacancy.age">Возраст:</strong> <span data-t={`vacancies.${job.id}.details_age`}>{job.details.age}</span>
						</div>
						<div class="detail-item">
							<strong data-t="vacancy.employment">Оформление:</strong> <span data-t={`vacancies.${job.id}.details_employment_type`}>{job.details.employment_type}</span>
						</div>
						
						{hasApplyLink ? (
							<>
								<a href={job.applyLink} target="_blank" rel="noopener noreferrer" class="apply-btn-large" data-t="vacancy.apply">
									Откликнуться сейчас
								</a>
								<p class="apply-note" data-t="vacancy.apply_note">Вы перейдете на сайт прямого работодателя</p>
							</>
						) : (
							<>
								<a href="/contacts/" class="apply-btn-large apply-btn-disabled" data-t="vacancy.apply_disabled">
									Уточнить условия
								</a>
								<p class="apply-note" data-t="vacancy.apply_disabled_note">Для этой вакансии прямая ссылка пока не добавлена</p>
							</>
						)}
					</div>
				</aside>
			</div>

			<ReviewsBlock jobId={job.id} />

			<section class="vacancy-answer-panel vacancy-answer-panel-bottom" aria-label="Краткий вывод по вакансии">
				<div>
					<p class="section-eyebrow" data-t="vacancy.short_output">Короткий вывод</p>
					<h2 data-t="vacancy.important_title">Что важно знать об этой вакансии?</h2>
				</div>
				<p data-t="vacancy.answer_summary">
					{job.title} подходит тем, кто ищет работу курьером с условиями "{job.details.schedule}" и хочет заранее сравнить
					доход, оформление, возрастные требования и частоту выплат. На этой странице собраны основные факты, чтобы
					решение об отклике было быстрее и спокойнее.
				</p>
			</section>
		</div>
	</main>

	<Footer />
</BaseLayout>

<style>
	.vacancy-page {
		padding: 2rem 0 4rem;
		background: linear-gradient(180deg, #ffffff 0%, #f6faf8 100%);
	}
	.container-narrow {
		max-width: 1240px;
		margin: 0 auto;
		padding: 0 1rem;
	}
	.breadcrumb {
		margin-bottom: 2rem;
		font-size: 0.875rem;
		color: var(--text-muted);
	}
	.breadcrumb a {
		color: var(--accent-color);
		text-decoration: none;
	}
