---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ReviewsBlock from '../../components/ReviewsBlock.astro';
import jobsData from '../../data/jobs.json';
import { slugifyCompany } from '../../utils/companies';

export async function getStaticPaths() {
	return jobsData.map((job) => ({
		params: { slug: job.slug },
		props: { job },
	}));
}

const { job } = Astro.props;
const hasApplyLink = Boolean(job.applyLink && job.applyLink !== '#');
const companyUrl = `/companies/${slugifyCompany(job.company)}/`;
const factCards = [
	{ label: 'Доход', value: job.salary },
	{ label: 'График', value: job.details.schedule },
	{ label: 'Возраст', value: job.details.age },
	{ label: 'Выплаты', value: job.details.payment_freq },
	{ label: 'Гражданство', value: job.details.citizenship },
	{ label: 'Оформление', value: job.details.employment_type },
];
const fitPoints = [
	`Тем, кто хочет рассмотреть работу в ${job.company} без долгого отбора условий.`,
	`Кандидатам, которым важны ${job.details.schedule.toLowerCase()} и понятный формат оформления.`,
	`Соискателям, которые сравнивают вакансии курьера по выплатам, требованиям и графику.`,
];
const importantPoints = [
	`Перед откликом проверьте актуальные условия по выплатам: для этой вакансии указано "${job.details.payment_freq}".`,
	`Уточните требования к оформлению: сейчас в карточке указано "${job.details.employment_type}".`,
	`Если условия на сайте работодателя отличаются от карточки, ориентируйтесь на финальные условия при подключении.`,
];
const antiFitPoints = [
	`Если вам не подходит формат оформления "${job.details.employment_type}", лучше сразу сравнить эту вакансию с альтернативами.`,
	`Если критичны точные ограничения по возрасту, гражданству или медкнижке, подтверждайте эти условия до перехода к анкете.`,
	`Если нужен строго официальный формат по ТК РФ или другой тип выплат, карточку стоит сравнить с более подходящими вариантами.`,
];
const faqItems = [
	{
		question: `Кому подходит вакансия "${job.title}"?`,
		answer: `Эта вакансия подходит кандидатам, которые рассматривают работу в ${job.company}, готовы к формату "${job.details.schedule}" и хотят заранее сравнить доход, требования и оформление.`,
	},
	{
		question: 'Что нужно проверить перед откликом?',
		answer: `Перед откликом стоит проверить график, выплаты, требования к возрасту, гражданству и оформлению. Для этой вакансии указаны выплаты: ${job.details.payment_freq}.`,
	},
	{
		question: 'Куда ведёт кнопка отклика?',
		answer: hasApplyLink
			? 'Кнопка отклика ведёт на внешний сайт работодателя или партнёра, где нужно заполнить анкету и подтвердить актуальные условия.'
			: 'Для этой вакансии прямая ссылка пока не добавлена, поэтому кнопка ведёт на страницу контактов для уточнения условий.',
	},
];
const updatedDate = new Intl.DateTimeFormat('ru-RU', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
}).format(new Date());
const methodologyPoints = [
	`Карточка обновлена ${updatedDate} и помогает быстро сравнить доход, график, оформление и ограничения до отклика.`,
	hasApplyLink
		? 'Кнопка отклика ведёт на внешний сайт работодателя или партнёра, где нужно ещё раз проверить актуальные условия.'
		: 'Прямая ссылка на внешний отклик пока не добавлена, поэтому условия стоит уточнять через страницу контактов.',
	'Если данные в анкете работодателя отличаются от карточки, ориентируйтесь на финальные условия при подключении.',
];
const pageSchemaGraph = [
	{
		'@type': 'WebPage',
		name: `${job.title} — Вакансия в ${job.company}`,
		description: job.description.substring(0, 160),
		url: Astro.url.href,
		dateModified: new Date().toISOString(),
		about: {
			'@type': 'Organization',
			name: job.company,
			url: new URL(companyUrl, Astro.site).toString(),
		},
	},
	{
		'@type': 'FAQPage',
		mainEntity: faqItems.map((item) => ({
			'@type': 'Question',
			name: item.question,
			acceptedAnswer: {
				'@type': 'Answer',
				text: item.answer,
			},
		})),
	},
];
---

<BaseLayout 
	title={`${job.title} — Вакансия в ${job.company}`} 
	description={job.description.substring(0, 160)}
	schemaGraph={pageSchemaGraph}
>
	<Header />

	<main class="vacancy-page">
		<div class="container container-narrow">
			<nav class="breadcrumb">
				<a href="/" data-t="nav.main">Главная</a> &gt; <span data-t={`vacancies.${job.id}.title`}>{job.title}</span>
			</nav>

			<section class="vacancy-header">
				<div class="vacancy-hero-main">
					<div class="vacancy-company-info">
						<img src={job.companyLogo} alt={job.company} class="vacancy-logo" width="80" height="80" loading="eager" decoding="async" />
						<div>
							<div class="vacancy-kicker">AI-ready карточка вакансии</div>
							<h1 data-t={`vacancies.${job.id}.title`}>{job.title}</h1>
							<a href={companyUrl} class="vacancy-company-name" data-t={`vacancies.${job.id}.company`}>{job.company}</a>
						</div>
					</div>
					<p class="vacancy-ai-summary">
						{job.title} в {job.company} — это вакансия для кандидатов, которые хотят заранее понять доход, график,
						требования и формат оформления перед переходом к отклику.
					</p>
					<div class="vacancy-meta-row">
						<span class="meta-pill">Обновлено {updatedDate}</span>
						<span class="meta-pill">{hasApplyLink ? 'Есть прямая ссылка на отклик' : 'Ссылка на отклик уточняется'}</span>
						<span class="meta-pill">Финальные условия подтверждаются при отклике</span>
					</div>
					<div class="vacancy-hero-actions">
						<a href="#vacancy-facts" class="hero-link">Краткие факты</a>
						<a href="#vacancy-faq" class="hero-link">FAQ перед откликом</a>
					</div>
				</div>
				<div class="vacancy-salary-card">
					<span>Доход</span>
					<strong data-t={`vacancies.${job.id}.salary`}>{job.salary}</strong>
					<small>Финальные условия уточняются при отклике</small>
				</div>
			</section>

			<section class="vacancy-answer-panel" aria-label="Краткий вывод по вакансии">
				<div>
					<p class="section-eyebrow">Короткий вывод</p>
					<h2>Что важно знать об этой вакансии?</h2>
				</div>
				<p>
					{job.title} подходит тем, кто ищет работу курьером с условиями "{job.details.schedule}" и хочет заранее сравнить
					доход, оформление, возрастные требования и частоту выплат. На этой странице собраны основные факты, чтобы
					решение об отклике было быстрее и спокойнее.
				</p>
			</section>

			<section class="vacancy-facts" id="vacancy-facts" aria-label="Краткие факты о вакансии">
				{factCards.map((fact) => (
					<div class="fact-card">
						<span>{fact.label}</span>
						<strong>{fact.value}</strong>
					</div>
				))}
			</section>

			<div class="vacancy-content-grid">
				<div class="vacancy-main">
					<section class="vacancy-section">
						<h2 data-t="vacancy.desc_title">Описание вакансии</h2>
						<p class="vacancy-description" data-t={`vacancies.${job.id}.description`}>{job.description}</p>
					</section>

					<section class="vacancy-section">
						<h2 data-t="vacancy.req_title">Требования</h2>
						<ul class="vacancy-list">
							{job.requirements.map((req: string, idx: number) => (
								<li data-t={`vacancies.${job.id}.req_${idx}`}>{req}</li>
							))}
						</ul>
					</section>

					<section class="vacancy-section">
						<h2 data-t="vacancy.ben_title">Преимущества</h2>
						<ul class="vacancy-list">
							{job.benefits.map((benefit: string, idx: number) => (
								<li data-t={`vacancies.${job.id}.ben_${idx}`}>{benefit}</li>
							))}
						</ul>
					</section>

					<section class="vacancy-section ai-geo-section">
						<p class="section-eyebrow">AI GEO блок</p>
						<h2>Кому лучше всего подходит эта вакансия?</h2>
						<div class="answer-grid">
							{fitPoints.map((point) => (
								<div class="answer-card">{point}</div>
							))}
						</div>
					</section>

					<section class="vacancy-section ai-geo-section">
						<p class="section-eyebrow">Когда сравнить ещё варианты</p>
						<h2>Кому эта вакансия может не подойти?</h2>
						<div class="answer-grid answer-grid-two">
							{antiFitPoints.map((point) => (
								<div class="answer-card answer-card-warning">{point}</div>
							))}
						</div>
					</section>

					<section class="vacancy-section ai-geo-section">
						<p class="section-eyebrow">Перед откликом</p>
						<h2>Что проверить до заполнения анкеты?</h2>
						<ol class="vacancy-list numbered-list">
							{importantPoints.map((point) => (
								<li>{point}</li>
							))}
						</ol>
					</section>

					<section class="vacancy-section ai-geo-section" id="vacancy-faq">
						<p class="section-eyebrow">FAQ</p>
						<h2>Короткие ответы перед откликом</h2>
						<div class="faq-stack">
							{faqItems.map((item) => (
								<article class="faq-item">
									<h3>{item.question}</h3>
									<p>{item.answer}</p>
								</article>
							))}
						</div>
					</section>

					<section class="vacancy-section ai-geo-section">
						<p class="section-eyebrow">Прозрачность</p>
						<h2>Как собрана эта карточка?</h2>
						<div class="trust-stack">
							{methodologyPoints.map((point) => (
								<div class="trust-item">{point}</div>
							))}
						</div>
						<div class="trust-links">
							<a href="/compare/" class="hero-link">Сравнить с другими вакансиями</a>
							<a href={companyUrl} class="hero-link">Открыть страницу компании</a>
						</div>
					</section>
				</div>

				<aside class="vacancy-sidebar">
					<div class="vacancy-card-sidebar">
						<h3 data-t="vacancy.details_title">Детали</h3>
						<div class="detail-item">
							<strong data-t="vacancy.location">Локация:</strong> <span data-t={`vacancies.${job.id}.location`}>{job.location}</span>
						</div>
						<div class="detail-item">
							<strong data-t="job.schedule">График:</strong> <span data-t={`vacancies.${job.id}.details_schedule`}>{job.details.schedule}</span>
						</div>
						<div class="detail-item">
							<strong data-t="vacancy.payment">Оплата:</strong> <span data-t={`vacancies.${job.id}.details_payment_freq`}>{job.details.payment_freq}</span>
						</div>
						<div class="detail-item">
							<strong data-t="vacancy.age">Возраст:</strong> <span data-t={`vacancies.${job.id}.details_age`}>{job.details.age}</span>
						</div>
						<div class="detail-item">
							<strong data-t="vacancy.employment">Оформление:</strong> <span data-t={`vacancies.${job.id}.details_employment_type`}>{job.details.employment_type}</span>
						</div>
						
						{hasApplyLink ? (
							<>
								<a href={job.applyLink} target="_blank" rel="noopener noreferrer" class="apply-btn-large" data-t="vacancy.apply">
									Откликнуться сейчас
								</a>
								<p class="apply-note" data-t="vacancy.apply_note">Вы перейдете на сайт прямого работодателя</p>
							</>
						) : (
							<>
								<a href="/contacts/" class="apply-btn-large apply-btn-disabled" data-t="vacancy.apply_disabled">
									Уточнить условия
								</a>
								<p class="apply-note" data-t="vacancy.apply_disabled_note">Для этой вакансии прямая ссылка пока не добавлена</p>
							</>
						)}
					</div>
				</aside>
			</div>

			<ReviewsBlock jobId={job.id} />
		</div>
	</main>

	<Footer />
</BaseLayout>

<style>
	.vacancy-page {
		padding: 2rem 0 4rem;
		background:
			radial-gradient(circle at 12% 8%, rgba(79, 70, 229, 0.08), transparent 28rem),
			radial-gradient(circle at 88% 18%, rgba(34, 197, 94, 0.1), transparent 26rem);
	}
	.container-narrow {
		max-width: 1240px;
		margin: 0 auto;
		padding: 0 1rem;
	}
	.breadcrumb {
		margin-bottom: 2rem;
		font-size: 0.875rem;
		color: var(--text-muted);
	}
	.breadcrumb a {
		color: var(--accent-color);
		text-decoration: none;
	}
	.vacancy-header {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(250px, 0.32fr);
		gap: 2rem;
		align-items: stretch;
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(248, 250, 252, 0.86)),
			var(--bg-card);
		padding: clamp(1.5rem, 3vw, 2.75rem);
		border: 1px solid rgba(148, 163, 184, 0.18);
		border-radius: 2rem;
		margin-bottom: 2rem;
		box-shadow: 0 26px 80px rgba(15, 23, 42, 0.08);
		position: relative;
		overflow: hidden;
	}
	.vacancy-header::after {
		content: "";
		position: absolute;
		inset: auto -6rem -8rem auto;
		width: 18rem;
		height: 18rem;
		background: radial-gradient(circle, rgba(79, 70, 229, 0.13), transparent 68%);
		pointer-events: none;
	}
	.vacancy-hero-main {
		position: relative;
		z-index: 1;
		display: grid;
		gap: 1.25rem;
	}
	.vacancy-company-info {
		display: flex;
		gap: 1.5rem;
		align-items: flex-start;
	}
	.vacancy-logo {
		width: 80px;
		height: 80px;
		object-fit: contain;
		border-radius: 1rem;
		background: white;
		padding: 0.5rem;
		box-shadow: 0 14px 40px rgba(15, 23, 42, 0.08);
	}
	.vacancy-kicker,
	.section-eyebrow {
		margin-bottom: 0.55rem;
		font-size: 0.74rem;
		font-weight: 900;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--accent-color);
	}
	.vacancy-header h1 {
		max-width: 13ch;
		margin-bottom: 0.35rem;
		font-size: clamp(2rem, 4.2vw, 4.25rem);
		line-height: 0.98;
		letter-spacing: -0.055em;
		text-wrap: balance;
	}
	.vacancy-company-name {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		color: var(--accent-color);
		text-decoration: none;
		font-weight: 800;
	}
	.vacancy-company-name:hover {
		text-decoration: underline;
	}
	.vacancy-ai-summary {
		max-width: 70ch;
		margin: 0;
		color: var(--text-muted);
		font-size: clamp(1rem, 0.8vw + 0.9rem, 1.2rem);
		line-height: 1.75;
	}
	.vacancy-meta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
	}
	.meta-pill {
		display: inline-flex;
		align-items: center;
		min-height: 2.25rem;
		padding: 0.45rem 0.8rem;
		border-radius: 999px;
		border: 1px solid rgba(148, 163, 184, 0.16);
		background: rgba(255, 255, 255, 0.72);
		color: var(--text-muted);
		font-size: 0.82rem;
		font-weight: 700;
	}
	.vacancy-hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}
	.hero-link {
		display: inline-flex;
		align-items: center;
		min-height: 2.6rem;
		padding: 0.65rem 1rem;
		border: 1px solid rgba(99, 102, 241, 0.16);
		border-radius: 999px;
		background: rgba(99, 102, 241, 0.08);
		color: var(--text-main);
		text-decoration: none;
		font-weight: 800;
	}
	.vacancy-salary-card {
		position: relative;
		z-index: 1;
		display: grid;
		align-content: center;
		gap: 0.45rem;
		min-height: 100%;
		padding: 1.5rem;
		border-radius: 1.5rem;
		background: linear-gradient(160deg, #111827, #1f2937);
		color: white;
		box-shadow: 0 20px 55px rgba(15, 23, 42, 0.18);
	}
	.vacancy-salary-card span,
	.vacancy-salary-card small {
		color: rgba(255, 255, 255, 0.72);
	}
	.vacancy-salary-card strong {
		font-size: clamp(1.6rem, 2.6vw, 2.4rem);
		line-height: 1;
		letter-spacing: -0.04em;
	}
	.vacancy-answer-panel {
		display: grid;
		grid-template-columns: minmax(220px, 0.36fr) minmax(0, 1fr);
		gap: 1.5rem;
		align-items: start;
		margin-bottom: 1rem;
		padding: 1.5rem;
		border: 1px solid rgba(148, 163, 184, 0.16);
		border-radius: 1.5rem;
		background: rgba(255, 255, 255, 0.74);
		box-shadow: var(--shadow-sm);
	}
	.vacancy-answer-panel h2,
	.vacancy-answer-panel p {
		margin: 0;
	}
	.vacancy-answer-panel p {
		color: var(--text-muted);
		line-height: 1.8;
	}
	.vacancy-facts {
		display: grid;
		grid-template-columns: repeat(6, minmax(0, 1fr));
		gap: 0.8rem;
		margin-bottom: 2rem;
	}
	.fact-card {
		display: grid;
		gap: 0.35rem;
		min-height: 7.25rem;
		padding: 1rem;
		border: 1px solid rgba(148, 163, 184, 0.16);
		border-radius: 1.2rem;
		background: rgba(255, 255, 255, 0.82);
		box-shadow: var(--shadow-sm);
	}
	.fact-card span {
		font-size: 0.72rem;
		font-weight: 900;
		letter-spacing: 0.11em;
		text-transform: uppercase;
		color: var(--text-muted);
	}
	.fact-card strong {
		align-self: end;
		font-size: 0.98rem;
		line-height: 1.35;
	}
	.vacancy-description {
		white-space: pre-wrap;
	}
	.vacancy-content-grid {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 2rem;
	}
	@media (max-width: 768px) {
		.vacancy-content-grid {
			grid-template-columns: 1fr;
		}
		.vacancy-header {
			flex-direction: column;
			gap: 1rem;
		}
	}
	.vacancy-section {
		background: var(--bg-card);
		padding: 2rem;
		border-radius: 1.5rem;
		margin-bottom: 1.5rem;
		box-shadow: var(--shadow-sm);
	}
	.vacancy-section h2 {
		margin-top: 0;
		margin-bottom: 1rem;
		font-size: 1.5rem;
	}
	.vacancy-list {
		padding-left: 1.5rem;
	}
	.vacancy-list li {
		margin-bottom: 0.5rem;
	}
	.ai-geo-section {
		border: 1px solid rgba(99, 102, 241, 0.12);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.96)),
			var(--bg-card);
	}
	.answer-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}
	.answer-card {
		padding: 1rem;
		border-radius: 1rem;
		background: rgba(99, 102, 241, 0.07);
		color: var(--text-main);
		line-height: 1.6;
	}
	.answer-grid-two {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}
	.answer-card-warning {
		background: rgba(249, 115, 22, 0.08);
	}
	.numbered-list li::marker {
		color: var(--accent-color);
		font-weight: 900;
	}
	.faq-stack {
		display: grid;
		gap: 1rem;
	}
	.faq-item {
		padding: 1.1rem;
		border: 1px solid rgba(148, 163, 184, 0.16);
		border-radius: 1rem;
		background: rgba(255, 255, 255, 0.72);
	}
	.faq-item h3 {
		margin: 0 0 0.45rem;
		font-size: 1rem;
	}
	.faq-item p {
		margin: 0;
		color: var(--text-muted);
		line-height: 1.7;
	}
	.trust-stack {
		display: grid;
