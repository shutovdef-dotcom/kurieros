---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import articlesData from '../../data/articles.json';
import { buildBreadcrumbSchema } from '../../utils/schema';

export function getStaticPaths() {
	return articlesData.map((article) => ({
		params: { slug: article.slug },
		props: { article },
	}));
}

const { article } = Astro.props;
const formattedDate = new Intl.DateTimeFormat('ru-RU', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
}).format(new Date(article.date));
const relatedArticles = articlesData
	.filter((entry) => entry.slug !== article.slug)
	.slice(0, 3)
	.map((entry) => ({
		...entry,
		formattedDate: new Intl.DateTimeFormat('ru-RU', {
			day: 'numeric',
			month: 'long',
		}).format(new Date(entry.date)),
	}));

const pageSchemaGraph = [
	{
		'@type': 'BlogPosting',
		headline: article.title,
		description: article.description,
		datePublished: new Date(article.date).toISOString(),
		dateModified: new Date(article.date).toISOString(),
		mainEntityOfPage: Astro.url.href,
		image: article.image ? [new URL(article.image, Astro.site).toString()] : undefined,
		author: {
			'@type': 'Organization',
			name: 'Редакция Курьерос',
		},
		publisher: {
			'@type': 'Organization',
			name: 'Курьерос',
			url: Astro.site,
		},
	},
	buildBreadcrumbSchema(
		[
			{ name: 'Главная', url: '/' },
			{ name: 'Блог', url: '/blog/' },
			{ name: article.title, url: `/blog/${article.slug}/` },
		],
		Astro.site,
	),
];
---

<BaseLayout
	title={`${article.title} — Курьерос`}
	description={article.description}
	image={article.image}
	schemaGraph={pageSchemaGraph}
>
	<Header />

	<main>
		<article class="article-container">
			<header class="article-header">
				<div class="article-lead">
					<div class="article-kicker">Журнал Курьерос</div>
					<div class="article-meta">
						<time datetime={article.date}>{formattedDate}</time>
						<span aria-hidden="true">•</span>
						<span>{article.readTime} чтения</span>
					</div>
					<h1>{article.title}</h1>
					<p class="article-description">{article.description}</p>
				</div>
				{article.image && (
					<div class="article-cover-frame">
						<img src={article.image} alt={article.title} class="article-cover" loading="eager" />
					</div>
				)}
			</header>

			<section class="article-answer-panel">
				<div>
					<div class="article-kicker">SEO / GEO TL;DR</div>
					<h2>Что делать после прочтения?</h2>
				</div>
				<p>
					Этот материал помогает разобраться в теме, но следующее полезное действие обычно уже практическое: открыть
					сравнение вакансий, выбрать компанию или перейти в нужный город и посмотреть, как выводы статьи выглядят в
					реальных карточках вакансий.
				</p>
			</section>

			<section class="article-hub-links">
				<a href="/compare/" class="hub-link">Сравнение вакансий</a>
				<a href="/companies/" class="hub-link">Каталог компаний</a>
				<a href="/cities/" class="hub-link">Города</a>
			</section>
			
			<div class="article-body">
				<Fragment set:html={article.content} />
			</div>

			<section class="article-footer">
				<div class="editor-note">
					<div class="editor-note-label">Материал подготовлен редакцией</div>
					<h2>Курьерос Журнал</h2>
					<p>Мы собираем практические материалы о работе курьером: сравниваем вакансии, условия и реальные сценарии заработка без рекламных обещаний.</p>
				</div>

				<div class="article-next">
					<div class="related-header">
						<h2>Куда перейти дальше</h2>
						<p>Следующий логичный шаг после статьи — перейти в одну из рабочих поверхностей сайта.</p>
					</div>
					<div class="next-grid">
						<a href="/compare/" class="next-card">
							<strong>Сравнение вакансий</strong>
							<span>Смотреть условия рядом и выбирать формат быстрее.</span>
						</a>
						<a href="/companies/" class="next-card">
							<strong>Компании</strong>
							<span>Сначала выбрать бренд, потом открыть его вакансии и отзывы.</span>
						</a>
						<a href="/cities/" class="next-card">
							<strong>Города</strong>
							<span>Перейти в локальные подборки и посмотреть, где уже есть вакансии.</span>
						</a>
					</div>
				</div>

				<div class="related-stories">
					<div class="related-header">
						<h2>Похожие статьи</h2>
						<p>Ещё несколько материалов, которые стоит открыть следом.</p>
					</div>
					<div class="related-grid">
						{relatedArticles.map((related) => (
							<a href={`/blog/${related.slug}/`} class="related-card">
								<img src={related.image} alt={related.title} class="related-image" />
								<div class="related-copy">
									<div class="related-meta">
										<time datetime={related.date}>{related.formattedDate}</time>
										<span aria-hidden="true">•</span>
										<span>{related.readTime}</span>
									</div>
									<h3>{related.title}</h3>
								</div>
							</a>
						))}
					</div>
				</div>
			</section>
		</article>
	</main>

	<Footer />
</BaseLayout>

<style>
	.article-container {
		max-width: 1320px;
		margin: 2.5rem auto 4rem;
		padding: 0 1rem;
	}
	.article-header {
		display: grid;
		grid-template-columns: minmax(0, 0.88fr) minmax(320px, 1fr);
		gap: 2rem;
		align-items: end;
		margin-bottom: 2rem;
		position: relative;
		z-index: 1;
	}
	.article-lead {
		padding: 2rem 0;
		position: relative;
		z-index: 2;
		background: var(--bg-color);
	}
	.article-kicker {
		display: inline-flex;
		margin-bottom: 1rem;
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: var(--text-muted);
	}
	.article-cover-frame {
		overflow: clip;
		border-radius: 32px;
		background: #e2e8f0;
		border: 1px solid rgba(148, 163, 184, 0.25);
		box-shadow: 0 28px 70px rgba(15, 23, 42, 0.12);
		position: relative;
		z-index: 1;
		isolation: isolate;
		contain: paint;
	}
	.article-cover {
		display: block;
		width: 100%;
		height: 540px;
		object-fit: cover;
	}
	.article-header h1 {
		font-size: clamp(2.4rem, 5vw, 4.8rem);
		line-height: 0.96;
		letter-spacing: -0.055em;
		max-width: 11ch;
	}
	.article-meta {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.6rem;
		color: var(--text-muted);
		font-size: 0.98rem;
		line-height: 1.4;
		margin-bottom: 1rem;
	}
	.article-description,
	.article-answer-panel p,
	.next-card span {
		color: var(--text-muted);
	}
	.article-description {
		max-width: 54ch;
		font-size: 1.08rem;
		line-height: 1.85;
		margin-top: 1rem;
	}
	.article-answer-panel {
		max-width: 980px;
		margin: 0 auto 1rem;
		display: grid;
		grid-template-columns: minmax(220px, 0.35fr) minmax(0, 1fr);
		gap: 1.5rem;
		align-items: start;
		padding: 1.5rem;
		border-radius: 1.5rem;
		border: 1px solid rgba(148, 163, 184, 0.16);
		background: rgba(255, 255, 255, 0.82);
		box-shadow: var(--shadow-sm);
	}
	.article-answer-panel h2,
	.article-answer-panel p {
		margin: 0;
	}
	.article-answer-panel p {
		line-height: 1.8;
	}
	.article-hub-links {
		max-width: 980px;
		margin: 0 auto 2rem;
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}
	.hub-link {
		display: inline-flex;
		align-items: center;
		min-height: 2.5rem;
		padding: 0.65rem 1rem;
		border-radius: 999px;
		border: 1px solid rgba(99, 102, 241, 0.16);
		background: rgba(99, 102, 241, 0.08);
		color: var(--text-main);
		text-decoration: none;
		font-weight: 800;
	}
	.article-body {
		max-width: 760px;
		margin: 0 auto;
		position: relative;
		z-index: 3;
		background: var(--bg-color);
		font-size: 1.14rem;
		line-height: 1.95;
		color: var(--text-main);
	}
	:global(.article-body h2) {
		margin-top: 2.75rem;
		margin-bottom: 1rem;
		font-size: clamp(1.6rem, 2.4vw, 2.2rem);
		line-height: 1.2;
		letter-spacing: -0.03em;
	}
	:global(.article-body p) {
		margin-bottom: 1.35rem;
		color: #334155;
	}
	:global(.article-body > p:first-of-type::first-letter) {
		float: left;
		font-size: 4.4rem;
		line-height: 0.8;
		padding-right: 0.5rem;
		padding-top: 0.35rem;
		font-weight: 700;
		color: #0f172a;
	}
	:global(.article-body ul) {
		margin-bottom: 1.5rem;
		padding-left: 1.5rem;
	}
	:global(.article-body li) {
		margin-bottom: 0.5rem;
	}
	:global(.article-body strong) {
		color: #0f172a;
	}
	.article-footer {
		max-width: 980px;
		margin: 4rem auto 0;
		display: grid;
		gap: 2.5rem;
		position: relative;
		z-index: 3;
		background: var(--bg-color);
	}
	.editor-note,
	.next-card {
		padding: 2rem;
		border-radius: 28px;
		background: linear-gradient(180deg, rgba(255,255,255,0.92), rgba(248,250,252,0.96));
		border: 1px solid rgba(148, 163, 184, 0.18);
		box-shadow: 0 20px 60px rgba(15, 23, 42, 0.08);
	}
	.editor-note-label {
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: var(--text-muted);
		margin-bottom: 0.8rem;
	}
	.editor-note h2,
	.related-header h2 {
		font-size: clamp(1.7rem, 2.6vw, 2.4rem);
		letter-spacing: -0.04em;
	}
	.editor-note p,
	.related-header p {
		max-width: 62ch;
		color: var(--text-muted);
		line-height: 1.8;
	}
	.related-header {
		display: flex;
		justify-content: space-between;
		align-items: end;
		gap: 1rem;
		margin-bottom: 1.25rem;
	}
	.next-grid,
	.related-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}
	.next-card {
		display: grid;
		gap: 0.6rem;
		text-decoration: none;
		color: inherit;
		padding: 1.4rem;
	}
	.next-card strong,
	.related-copy h3 {
		font-size: 1.05rem;
		line-height: 1.3;
		letter-spacing: -0.02em;
	}
	.related-card {
		display: grid;
		text-decoration: none;
		color: inherit;
		background: rgba(255,255,255,0.88);
		border: 1px solid rgba(148, 163, 184, 0.16);
		border-radius: 24px;
		overflow: hidden;
		box-shadow: 0 18px 48px rgba(15, 23, 42, 0.07);
	}
	.related-image {
		width: 100%;
		height: 180px;
		object-fit: cover;
	}
	.related-copy {
		padding: 1rem 1rem 1.2rem;
	}
	.related-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.45rem;
		font-size: 0.85rem;
		color: var(--text-muted);
		margin-bottom: 0.7rem;
	}
	@media (max-width: 960px) {
		.article-header,
		.article-answer-panel,
		.next-grid,
		.related-grid {
			grid-template-columns: 1fr;
		}
	}
	@media (max-width: 768px) {
		.article-container {
			margin: 1rem auto 2.5rem;
			padding: 0 1rem;
		}
		.article-header {
			gap: 1.25rem;
			margin-bottom: 2rem;
		}
		.article-lead {
			padding: 0;
		}
		.article-cover-frame {
			border-radius: 24px;
		}
		.article-cover {
			height: 260px;
		}
		:global(.article-body > p:first-of-type::first-letter) {
			font-size: 3.2rem;
			padding-right: 0.35rem;
			padding-top: 0.2rem;
		}
		.editor-note {
			padding: 1.5rem;
			border-radius: 22px;
		}
		.related-header {
			display: grid;
		}
	}
</style>
