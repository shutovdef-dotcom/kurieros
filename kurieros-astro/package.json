{
  "name": "kurieros-astro",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "generate": "astro sync",
    "pregenerate": "npm run generate:data",
    "generate:data": "npm run generate:vacancy-translations && npm run generate:reviews",
    "generate:vacancy-translations": "tsx scripts/generate-vacancy-translations.ts",
    "generate:reviews": "tsx scripts/generate-reviews.ts",
    "predev": "npm run generate:data",
    "dev": "astro dev",
    "prebuild": "npm run generate:data",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "local:build": "./scripts/build-local.sh",
    "local:preview": "./scripts/preview-local.sh",
    "local:dev": "./scripts/dev-local.sh"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.1.3"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
